@page "/"
@using PaycheckCalc.Core.Pay
@inject PayCalculator PayCalc
@inject StateCalculatorRegistry StateRegistry
@inject LocalCalculatorRegistry LocalRegistry
@inject IPaycheckRepository Repository
@inject NavigationManager Nav

<PageTitle>PaycheckCalc — Calculator</PageTitle>

<h1>2026 Paycheck Calculator</h1>

<div class="layout two-col-wide">
    <section class="card">
        <h2>Pay</h2>
        <div class="grid two-col">
            <div class="field">
                <label>Pay frequency</label>
                <select class="input" @bind="_frequency">
                    @foreach (var f in Enum.GetValues<PayFrequency>())
                    {
                        <option value="@f">@FormatFrequency(f)</option>
                    }
                </select>
            </div>
            <div class="field">
                <label>Hourly rate ($)</label>
                <input class="input" type="number" step="0.01" inputmode="decimal" @bind="_hourlyRate" />
            </div>
            <div class="field">
                <label>Regular hours</label>
                <input class="input" type="number" step="0.01" inputmode="decimal" @bind="_regularHours" />
            </div>
            <div class="field">
                <label>Overtime hours</label>
                <input class="input" type="number" step="0.01" inputmode="decimal" @bind="_overtimeHours" />
            </div>
            <div class="field">
                <label>Overtime multiplier</label>
                <input class="input" type="number" step="0.01" inputmode="decimal" @bind="_overtimeMultiplier" />
            </div>
            <div class="field">
                <label>Paycheck # this year</label>
                <input class="input" type="number" step="1" inputmode="numeric" @bind="_paycheckNumber" />
            </div>
        </div>

        <h2>Federal W-4</h2>
        <FederalW4Editor Model="_w4" />

        <h2>State</h2>
        <div class="field">
            <label>State of residence/work</label>
            <select class="input" value="@_state" @onchange="OnStateChanged">
                @foreach (var s in Enum.GetValues<UsState>())
                {
                    <option value="@s">@s</option>
                }
            </select>
        </div>
        <SchemaFieldEditor Schema="_stateSchema" Values="_stateValues" IdPrefix="state" />

        @if (LocalRegistry.IsSupported(_state))
        {
            <h2>Locality</h2>
            <div class="field">
                <label>Locality (where you live)</label>
                <select class="input" value="@(_homeLocality ?? string.Empty)" @onchange="OnHomeLocalityChanged">
                    <option value="">(none)</option>
                    @foreach (var calc in LocalRegistry.GetCalculatorsForState(_state))
                    {
                        <option value="@calc.Locality.Code">@calc.Locality.Name</option>
                    }
                </select>
            </div>
            <div class="field">
                <label>Locality (where you work)</label>
                <select class="input" value="@(_workLocality ?? string.Empty)" @onchange="OnWorkLocalityChanged">
                    <option value="">(same as home)</option>
                    @foreach (var calc in LocalRegistry.GetCalculatorsForState(_state))
                    {
                        <option value="@calc.Locality.Code">@calc.Locality.Name</option>
                    }
                </select>
            </div>
            @if (_localSchema is not null && _localSchema.Count > 0)
            {
                <SchemaFieldEditor Schema="_localSchema" Values="_localValues" IdPrefix="local" />
            }
        }

        <h2>Year-to-date wages (optional)</h2>
        <div class="grid two-col">
            <div class="field">
                <label>YTD Social Security wages ($)</label>
                <input class="input" type="number" step="0.01" inputmode="decimal" @bind="_ytdSsWages" />
            </div>
            <div class="field">
                <label>YTD Medicare wages ($)</label>
                <input class="input" type="number" step="0.01" inputmode="decimal" @bind="_ytdMedicareWages" />
            </div>
        </div>

        <h2>Deductions</h2>
        <DeductionsEditor Items="_deductions" />

        <div class="actions">
            <button type="button" class="btn btn-primary" @onclick="Calculate">Calculate</button>
            <button type="button" class="btn" @onclick="Save" disabled="@(_lastResult is null)">Save…</button>
        </div>

        @if (_validationErrors.Count > 0)
        {
            <div class="errors">
                <strong>Cannot calculate:</strong>
                <ul>
                    @foreach (var err in _validationErrors)
                    {
                        <li>@err</li>
                    }
                </ul>
            </div>
        }

        @if (_saveDialogOpen)
        {
            <div class="save-dialog">
                <label>
                    Name:
                    <input class="input" @bind="_saveName" />
                </label>
                <button type="button" class="btn btn-primary" @onclick="ConfirmSave"
                        disabled="@string.IsNullOrWhiteSpace(_saveName)">Save</button>
                <button type="button" class="btn" @onclick="() => _saveDialogOpen = false">Cancel</button>
            </div>
        }

        @if (!string.IsNullOrEmpty(_savedMessage))
        {
            <p class="success">@_savedMessage</p>
        }
    </section>

    <section class="card sticky-results">
        <h2>Results</h2>
        @if (_lastResult is null)
        {
            <p class="muted">Enter your inputs and click <strong>Calculate</strong> to see the breakdown.</p>
        }
        else
        {
            <ResultsCard Result="_lastResult" />
        }
    </section>
</div>

@code {
    // ── Pay inputs ─────────────────────────────────────
    private PayFrequency _frequency = PayFrequency.Biweekly;
    private decimal _hourlyRate = 25m;
    private decimal _regularHours = 80m;
    private decimal _overtimeHours;
    private decimal _overtimeMultiplier = 1.5m;
    private int _paycheckNumber = 1;
    private decimal _ytdSsWages;
    private decimal _ytdMedicareWages;

    // ── Federal W-4 ────────────────────────────────────
    private FederalW4Editor.FederalW4Draft _w4 = new();

    // ── State ──────────────────────────────────────────
    private UsState _state = UsState.OK;
    private IReadOnlyList<StateFieldDefinition>? _stateSchema;
    private StateInputValues _stateValues = new();

    // ── Locality ───────────────────────────────────────
    private string? _homeLocality;
    private string? _workLocality;
    private IReadOnlyList<StateFieldDefinition>? _localSchema;
    private LocalInputValues _localValues = new();

    // ── Deductions ─────────────────────────────────────
    private List<DeductionsEditor.DeductionDraft> _deductions = new();

    // ── Output ─────────────────────────────────────────
    private PaycheckResult? _lastResult;
    private List<string> _validationErrors = new();

    // ── Save dialog state ──────────────────────────────
    private bool _saveDialogOpen;
    private string _saveName = string.Empty;
    private string? _savedMessage;
    private Guid? _loadedId;

    protected override async Task OnInitializedAsync()
    {
        RefreshStateSchema();

        // If the user opened us via "?load=<guid>" from the Saved page,
        // hydrate from storage before the first render.
        var uri = new Uri(Nav.Uri);
        var query = uri.Query.TrimStart('?');
        var loadParam = query.Split('&')
            .Select(p => p.Split('=', 2))
            .FirstOrDefault(kv => kv.Length == 2 && kv[0] == "load");
        if (loadParam is not null && Guid.TryParse(Uri.UnescapeDataString(loadParam[1]), out var id))
        {
            var saved = await Repository.GetByIdAsync(id);
            if (saved is not null)
                LoadFrom(saved);
        }
    }

    private void OnStateChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<UsState>(e.Value?.ToString(), out var s))
        {
            _state = s;
            // Reset locality choices when the state changes; the previous
            // locality codes may not exist in the new state.
            _homeLocality = null;
            _workLocality = null;
            _localSchema = null;
            _localValues = new LocalInputValues();
            RefreshStateSchema();
        }
    }

    private void RefreshStateSchema()
    {
        var calc = StateRegistry.GetCalculator(_state);
        _stateSchema = calc.GetInputSchema();

        // Seed defaults from the schema so first render shows useful values.
        var fresh = new StateInputValues();
        foreach (var field in _stateSchema)
        {
            if (field.DefaultValue is not null)
                fresh[field.Key] = field.DefaultValue;
        }
        _stateValues = fresh;
    }

    private void OnHomeLocalityChanged(ChangeEventArgs e)
    {
        _homeLocality = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value!.ToString();
        RefreshLocalSchema();
    }

    private void OnWorkLocalityChanged(ChangeEventArgs e)
    {
        _workLocality = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value!.ToString();
        RefreshLocalSchema();
    }

    private void RefreshLocalSchema()
    {
        // Schema comes from whichever calculator we'll actually invoke. We
        // pick the home locality calculator for schema purposes; if both
        // home and work share the same locality this is fine, and if they
        // differ the schema is still a superset for rendering.
        var code = _homeLocality ?? _workLocality;
        if (code is not null && LocalRegistry.TryGetCalculator(code, out var calc) && calc is not null)
        {
            _localSchema = calc.GetInputSchema();
            var fresh = new LocalInputValues();
            foreach (var field in _localSchema)
            {
                if (field.DefaultValue is not null)
                    fresh[field.Key] = field.DefaultValue;
            }
            _localValues = fresh;
        }
        else
        {
            _localSchema = null;
            _localValues = new LocalInputValues();
        }
    }

    private void Calculate()
    {
        _validationErrors.Clear();
        _savedMessage = null;

        var calc = StateRegistry.GetCalculator(_state);
        var stateErrors = calc.Validate(_stateValues);
        if (stateErrors.Count > 0)
        {
            _validationErrors.AddRange(stateErrors);
            _lastResult = null;
            return;
        }

        var input = BuildInput();
        try
        {
            _lastResult = PayCalc.Calculate(input);
        }
        catch (Exception ex)
        {
            _validationErrors.Add(ex.Message);
            _lastResult = null;
        }
    }

    private PaycheckInput BuildInput() => new()
    {
        Frequency = _frequency,
        HourlyRate = _hourlyRate,
        RegularHours = _regularHours,
        OvertimeHours = _overtimeHours,
        OvertimeMultiplier = _overtimeMultiplier,
        State = _state,
        StateInputValues = _stateValues,
        HomeLocalityCode = _homeLocality,
        WorkLocalityCode = _workLocality,
        LocalInputValues = _localValues.Count == 0 ? null : _localValues,
        FederalW4 = _w4.ToW4(),
        Deductions = _deductions.Select(d => d.ToDeduction()).ToList(),
        YtdSocialSecurityWages = _ytdSsWages,
        YtdMedicareWages = _ytdMedicareWages,
        PaycheckNumber = _paycheckNumber
    };

    private void Save()
    {
        _saveDialogOpen = true;
        if (string.IsNullOrEmpty(_saveName))
            _saveName = $"Paycheck {_state} {DateTimeOffset.UtcNow.LocalDateTime:yyyy-MM-dd}";
    }

    private async Task ConfirmSave()
    {
        if (_lastResult is null || string.IsNullOrWhiteSpace(_saveName))
            return;

        var paycheck = new SavedPaycheck
        {
            Id = _loadedId ?? Guid.NewGuid(),
            Name = _saveName.Trim(),
            CreatedAt = DateTimeOffset.UtcNow,
            UpdatedAt = DateTimeOffset.UtcNow,
            Input = BuildInput(),
            Result = _lastResult
        };
        await Repository.SaveAsync(paycheck);
        _loadedId = paycheck.Id;
        _saveDialogOpen = false;
        _savedMessage = $"Saved as \"{paycheck.Name}\".";
    }

    /// <summary>
    /// Hydrate the editor from an existing saved paycheck. Called by the
    /// SavedPaychecks page through navigation state.
    /// </summary>
    public void LoadFrom(SavedPaycheck saved)
    {
        var i = saved.Input;
        _frequency = i.Frequency;
        _hourlyRate = i.HourlyRate;
        _regularHours = i.RegularHours;
        _overtimeHours = i.OvertimeHours;
        _overtimeMultiplier = i.OvertimeMultiplier;
        _state = i.State;
        _stateSchema = StateRegistry.GetCalculator(_state).GetInputSchema();
        _stateValues = i.StateInputValues is not null
            ? new StateInputValues(i.StateInputValues)
            : new StateInputValues();
        _homeLocality = i.HomeLocalityCode;
        _workLocality = i.WorkLocalityCode;
        RefreshLocalSchema();
        if (i.LocalInputValues is not null)
            _localValues = new LocalInputValues(i.LocalInputValues);
        _w4 = FederalW4Editor.FederalW4Draft.From(i.FederalW4);
        _deductions = i.Deductions.Select(DeductionsEditor.DeductionDraft.From).ToList();
        _ytdSsWages = i.YtdSocialSecurityWages;
        _ytdMedicareWages = i.YtdMedicareWages;
        _paycheckNumber = i.PaycheckNumber;
        _lastResult = saved.Result;
        _loadedId = saved.Id;
        _saveName = saved.Name;
    }

    private static string FormatFrequency(PayFrequency f) => f switch
    {
        PayFrequency.Weekly => "Weekly (52/yr)",
        PayFrequency.Biweekly => "Biweekly (26/yr)",
        PayFrequency.Semimonthly => "Semi-monthly (24/yr)",
        PayFrequency.Monthly => "Monthly (12/yr)",
        PayFrequency.Quarterly => "Quarterly (4/yr)",
        PayFrequency.Semiannual => "Semi-annual (2/yr)",
        PayFrequency.Annual => "Annual (1/yr)",
        PayFrequency.Daily => "Daily (260/yr)",
        _ => f.ToString()
    };
}
