@*
    Editor for a Form W-4 (2020+) employee record. Mutates the supplied
    FederalW4Draft in place; convert to FederalW4Input via ToW4().
*@

<div class="grid two-col">
    <div class="field">
        <label>Filing Status</label>
        <select class="input" value="@Model.FilingStatus"
                @onchange="e => Model.FilingStatus = Enum.Parse<FederalFilingStatus>(e.Value?.ToString() ?? nameof(FederalFilingStatus.SingleOrMarriedSeparately))">
            <option value="@nameof(FederalFilingStatus.SingleOrMarriedSeparately)">Single or Married Filing Separately</option>
            <option value="@nameof(FederalFilingStatus.MarriedFilingJointly)">Married Filing Jointly</option>
            <option value="@nameof(FederalFilingStatus.HeadOfHousehold)">Head of Household</option>
        </select>
    </div>

    <div class="field check-field">
        <label>
            <input type="checkbox" checked="@Model.Step2Checked"
                   @onchange="e => Model.Step2Checked = (bool)(e.Value ?? false)" />
            Step 2(c) — multiple jobs / spouse works
        </label>
    </div>

    <div class="field">
        <label>Step 3 — Annual tax credits ($)</label>
        <input type="number" step="0.01" inputmode="decimal" class="input"
               value="@Model.Step3TaxCredits"
               @onchange="e => Model.Step3TaxCredits = ParseDecimal(e.Value?.ToString())" />
    </div>

    <div class="field">
        <label>Step 4(a) — Other annual income ($)</label>
        <input type="number" step="0.01" inputmode="decimal" class="input"
               value="@Model.Step4aOtherIncome"
               @onchange="e => Model.Step4aOtherIncome = ParseDecimal(e.Value?.ToString())" />
    </div>

    <div class="field">
        <label>Step 4(b) — Annual deductions ($)</label>
        <input type="number" step="0.01" inputmode="decimal" class="input"
               value="@Model.Step4bDeductions"
               @onchange="e => Model.Step4bDeductions = ParseDecimal(e.Value?.ToString())" />
    </div>

    <div class="field">
        <label>Step 4(c) — Extra withholding per pay period ($)</label>
        <input type="number" step="0.01" inputmode="decimal" class="input"
               value="@Model.Step4cExtraWithholding"
               @onchange="e => Model.Step4cExtraWithholding = ParseDecimal(e.Value?.ToString())" />
    </div>
</div>

@code {
    public sealed class FederalW4Draft
    {
        public FederalFilingStatus FilingStatus { get; set; } = FederalFilingStatus.SingleOrMarriedSeparately;
        public bool Step2Checked { get; set; }
        public decimal Step3TaxCredits { get; set; }
        public decimal Step4aOtherIncome { get; set; }
        public decimal Step4bDeductions { get; set; }
        public decimal Step4cExtraWithholding { get; set; }

        public FederalW4Input ToW4() => new()
        {
            FilingStatus = FilingStatus,
            Step2Checked = Step2Checked,
            Step3TaxCredits = Step3TaxCredits,
            Step4aOtherIncome = Step4aOtherIncome,
            Step4bDeductions = Step4bDeductions,
            Step4cExtraWithholding = Step4cExtraWithholding
        };

        public static FederalW4Draft From(FederalW4Input w4) => new()
        {
            FilingStatus = w4.FilingStatus,
            Step2Checked = w4.Step2Checked,
            Step3TaxCredits = w4.Step3TaxCredits,
            Step4aOtherIncome = w4.Step4aOtherIncome,
            Step4bDeductions = w4.Step4bDeductions,
            Step4cExtraWithholding = w4.Step4cExtraWithholding
        };
    }

    [Parameter, EditorRequired] public FederalW4Draft Model { get; set; } = new();

    private static decimal ParseDecimal(string? raw) =>
        decimal.TryParse(raw, System.Globalization.NumberStyles.Number,
                         System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : 0m;
}
