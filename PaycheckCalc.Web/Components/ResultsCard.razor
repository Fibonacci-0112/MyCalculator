@*
    Renders a PaycheckResult as a tidy two-column ledger.
*@

@if (Result is not null)
{
    var r = Result;
    <div class="result-card">
        <div class="result-row total">
            <span>Net pay</span>
            <span class="amount">@Money(r.NetPay)</span>
        </div>

        <hr />

        <h3>Earnings</h3>
        <div class="result-row"><span>Gross pay</span><span class="amount">@Money(r.GrossPay)</span></div>
        @if (r.PreTaxDeductions > 0)
        {
            <div class="result-row"><span>Pre-tax deductions</span><span class="amount">−@Money(r.PreTaxDeductions)</span></div>
        }
        @if (r.PostTaxDeductions > 0)
        {
            <div class="result-row"><span>Post-tax deductions</span><span class="amount">−@Money(r.PostTaxDeductions)</span></div>
        }

        <h3>Federal</h3>
        <div class="result-row"><span>Federal income tax</span><span class="amount">−@Money(r.FederalWithholding)</span></div>
        <div class="result-row"><span>Social Security</span><span class="amount">−@Money(r.SocialSecurityWithholding)</span></div>
        <div class="result-row"><span>Medicare</span><span class="amount">−@Money(r.MedicareWithholding)</span></div>
        @if (r.AdditionalMedicareWithholding > 0)
        {
            <div class="result-row"><span>Additional Medicare</span><span class="amount">−@Money(r.AdditionalMedicareWithholding)</span></div>
        }

        <h3>State (@r.State)</h3>
        <div class="result-row"><span>State income tax</span><span class="amount">−@Money(r.StateWithholding)</span></div>
        @if (r.StateDisabilityInsurance > 0)
        {
            <div class="result-row"><span>@r.StateDisabilityInsuranceLabel</span><span class="amount">−@Money(r.StateDisabilityInsurance)</span></div>
        }

        @if (!string.IsNullOrEmpty(r.LocalityLabel) && (r.LocalWithholding > 0 || r.LocalHeadTax > 0))
        {
            <h3>Local — @r.LocalityLabel</h3>
            @if (r.LocalWithholding > 0)
            {
                <div class="result-row"><span>Local income tax</span><span class="amount">−@Money(r.LocalWithholding)</span></div>
            }
            @if (r.LocalHeadTax > 0)
            {
                <div class="result-row"><span>@r.LocalHeadTaxLabel</span><span class="amount">−@Money(r.LocalHeadTax)</span></div>
            }
        }

        <hr />

        <div class="result-row"><span>Total taxes</span><span class="amount">@Money(r.TotalTaxes)</span></div>
        <div class="result-row total"><span>Net pay</span><span class="amount">@Money(r.NetPay)</span></div>
    </div>
}

@code {
    [Parameter] public PaycheckResult? Result { get; set; }

    private static string Money(decimal value) =>
        value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"));
}
