@inherits LayoutComponentBase

<div class="page">
    <nav class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">💰 PaycheckCalc</a>
            </div>
        </div>

        <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

        <div class="nav-scrollable">
            <nav class="flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="oi oi-home" aria-hidden="true"></span> Home
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="calculator">
                        <span class="oi oi-calculator" aria-hidden="true"></span> Calculator
                    </NavLink>
                </div>
            </nav>
        </div>
    </nav>

    <main>
        <div class="top-row px-4">
            <a href="https://github.com/Fibonacci-0112/MyCalculator" target="_blank">GitHub</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
