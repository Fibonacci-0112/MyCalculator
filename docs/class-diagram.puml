@startuml PaycheckCalc

' ──────────────────────────────────────────────
' PlantUML class diagram for the PaycheckCalc solution.
' Covers PaycheckCalc.Core (UI-agnostic payroll / tax engine) and
' PaycheckCalc.App (MAUI MVVM front end).
'
' Layout is grouped by package to mirror the folder structure:
'   PaycheckCalc.Core
'     ├─ Models            – domain inputs, results, profiles
'     ├─ Pay               – per-paycheck orchestration
'     ├─ Tax/Fica          – FICA (SS + Medicare)
'     ├─ Tax/Federal       – IRS Pub 15-T per-paycheck withholding
'     ├─ Tax/Federal/Annual – Form 1040 engine (annual)
'     ├─ Tax/SelfEmployment – Schedule C / SE tax / QBI
'     ├─ Tax/State         – state-tax plugin model + registry
'     ├─ Tax/<StateName>   – per-state calculators
'     ├─ Storage           – persistence abstraction
'     └─ Export            – CSV / PDF exporters
'   PaycheckCalc.App
'     ├─ ViewModels        – MVVM view models (CommunityToolkit.Mvvm)
'     ├─ Views             – XAML pages
'     ├─ Models            – UI/presentation DTOs
'     ├─ Mappers           – domain ⇄ UI translation
'     └─ Storage           – JSON paycheck repository
' ──────────────────────────────────────────────

skinparam classAttributeIconSize 0
skinparam linetype ortho
hide empty members

' ═══════════════════════════════════════════════
' PaycheckCalc.Core – Enums
' ═══════════════════════════════════════════════

package "Core.Models" as CoreModels {

    enum PayFrequency {
        Weekly
        Biweekly
        Semimonthly
        Monthly
        Quarterly
        Semiannual
        Annual
        Daily
    }

    enum FilingStatus {
        Single
        Married
    }

    enum DeductionType {
        PreTax
        PostTax
    }

    enum DeductionAmountType {
        Dollar
        Percentage
    }

    enum UsState {
        AL
        AK
        AR
        ' … all 50 states + DC …
        WV
        WY
    }

    enum W2JobHolder {
        Taxpayer
        Spouse
    }

    ' ═══════════════════════════════════════════
    ' Domain Inputs
    ' ═══════════════════════════════════════════

    class PaycheckInput <<sealed>> {
        +Frequency : PayFrequency
        +HourlyRate : decimal
        +RegularHours : decimal
        +OvertimeHours : decimal
        +OvertimeMultiplier : decimal
        +State : UsState
        +StateInputValues : StateInputValues?
        +FederalW4 : FederalW4Input
        +Deductions : IReadOnlyList<Deduction>
        +YtdSocialSecurityWages : decimal
        +YtdMedicareWages : decimal
        +PaycheckNumber : int
    }

    class Deduction <<sealed>> {
        +Name : string
        +Type : DeductionType
        +Amount : decimal
        +AmountType : DeductionAmountType
        +ReducesStateTaxableWages : bool
        +EffectiveAmount(grossPay) : decimal
    }

    class W2JobInput <<sealed>> {
        +Name : string
        +Holder : W2JobHolder
        +WagesBox1 : decimal
        +FederalWithholdingBox2 : decimal
        +SocialSecurityWagesBox3 : decimal
        +SocialSecurityTaxBox4 : decimal
        +MedicareWagesBox5 : decimal
        +MedicareTaxBox6 : decimal
        +StateWagesBox16 : decimal
        +StateWithholdingBox17 : decimal
        +SourceState : UsState?
    }

    class SelfEmploymentInput <<sealed>> {
        +GrossRevenue : decimal
        +CostOfGoodsSold : decimal
        +TotalBusinessExpenses : decimal
        +OtherIncome : decimal
        +W2SocialSecurityWages : decimal
        +W2MedicareWages : decimal
        +FilingStatus : FederalFilingStatus
        +State : UsState
        +StateInputValues : StateInputValues?
        +ItemizedDeductionsOverStandard : decimal
        +IsSpecifiedServiceBusiness : bool
        +QualifiedBusinessW2Wages : decimal
        +QualifiedPropertyUbia : decimal
        +EstimatedTaxPayments : decimal
    }

    class OtherIncomeInput <<sealed>>
    class AdjustmentsInput <<sealed>>
    class ChildTaxCreditInput <<sealed>>
    class EducationCreditsInput <<sealed>>
    class EducationStudentInput <<sealed>>
    class SaversCreditInput <<sealed>>
    class NetInvestmentIncomeInput <<sealed>>
    class CreditsInput <<sealed>>
    class OtherTaxesInput <<sealed>>

    class TaxYearProfile <<sealed>> {
        +TaxYear : int
        +FilingStatus : FederalFilingStatus
        +QualifyingChildren : int
        +ResidenceState : UsState
        +W2Jobs : IReadOnlyList<W2JobInput>
        +SelfEmployment : SelfEmploymentInput?
        +OtherIncome : OtherIncomeInput
        +Adjustments : AdjustmentsInput
        +ItemizedDeductionsOverStandard : decimal
        +Credits : CreditsInput
        +OtherTaxes : OtherTaxesInput
        +EstimatedTaxPayments : decimal
        +StateInputValues : StateInputValues?
    }

    ' ═══════════════════════════════════════════
    ' Domain Results
    ' ═══════════════════════════════════════════

    class PaycheckResult <<sealed>> {
        +GrossPay : decimal
        +PreTaxDeductions : decimal
        +PostTaxDeductions : decimal
        +State : UsState
        +StateTaxableWages : decimal
        +StateWithholding : decimal
        +StateDisabilityInsurance : decimal
        +StateDisabilityInsuranceLabel : string
        +SocialSecurityWithholding : decimal
        +MedicareWithholding : decimal
        +AdditionalMedicareWithholding : decimal
        +FederalTaxableIncome : decimal
        +FederalWithholding : decimal
        +TotalTaxes : decimal
        +NetPay : decimal
    }

    class SelfEmploymentResult <<sealed>>
    class AnnualProjection <<sealed>>
    class AnnualTaxResult <<sealed>>
    class AnnualStateTaxResult <<sealed>>

    class CalculationScenario <<sealed>> {
        +Input : PaycheckInput
        +Result : PaycheckResult
    }

    class SavedPaycheck <<sealed>> {
        +Id : Guid
        +Name : string
        +CreatedAt : DateTimeOffset
        +UpdatedAt : DateTimeOffset
        +Input : PaycheckInput
        +Result : PaycheckResult
    }
}

