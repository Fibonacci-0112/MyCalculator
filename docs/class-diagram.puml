' PaycheckCalc.Core – State plugin model
' ═══════════════════════════════════════════════

package "Core.Tax.State" as CoreState {

    enum StateFieldType {
        Text
        Integer
        Decimal
        Toggle
        Picker
    }

    class StateFieldDefinition <<sealed>> {
        +Key : string
        +Label : string
        +FieldType : StateFieldType
        +IsRequired : bool
        +DefaultValue : object?
        +Options : IReadOnlyList<string>?
    }

    class StateInputValues <<sealed>>
    note right of StateInputValues
        Extends Dictionary<string, object?>;
        bag of per-state values keyed by
        StateFieldDefinition.Key.
    end note

    class "CommonWithholdingContext\n<<record>>" as CommonWithholdingContext {
        +State : UsState
        +GrossWages : decimal
        +PayPeriod : PayFrequency
        +Year : int
        +PreTaxDeductionsReducingStateWages : decimal
        +FederalWithholdingPerPeriod : decimal
    }

    class StateWithholdingResult <<sealed>> {
        +TaxableWages : decimal
        +Withholding : decimal
        +DisabilityInsurance : decimal
        +DisabilityInsuranceLabel : string
        +Description : string?
    }

    interface IStateWithholdingCalculator {
        +State : UsState
        +GetInputSchema() : IReadOnlyList<StateFieldDefinition>
        +Validate(values) : IReadOnlyList<string>
        +Calculate(context, values) : StateWithholdingResult
    }

    class StateCalculatorRegistry <<sealed>> {
        +Register(calc : IStateWithholdingCalculator)
        +IsSupported(state : UsState) : bool
        +GetCalculator(state : UsState) : IStateWithholdingCalculator
        +SupportedStates : IReadOnlyList<UsState>
    }

    class NoIncomeTaxWithholdingAdapter <<sealed>>
    class PercentageMethodWithholdingAdapter <<sealed>>

    class TaxBracket <<sealed>> {
        +Floor : decimal
        +Ceiling : decimal?
        +Rate : decimal
    }

    class PercentageMethodConfig <<sealed>> {
        +StandardDeductionSingle : decimal
        +StandardDeductionMarried : decimal
        +AllowanceAmount : decimal
        +AllowanceCreditAmount : decimal
        +BracketsSingle : TaxBracket[]
        +BracketsMarried : TaxBracket[]
    }

    class PercentageMethodStateTaxCalculator <<sealed>> {
        +CalculateWithholding(input : StateTaxInput) : StateTaxResult
    }

    class StateTaxInput <<sealed>>
    class StateTaxResult <<sealed>>

    class StateTaxConfigs2026 <<static>> {
        +{static} Configs : IReadOnlyDictionary<UsState, PercentageMethodConfig>
    }
}

