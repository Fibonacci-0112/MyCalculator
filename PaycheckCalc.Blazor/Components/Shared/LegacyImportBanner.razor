@using PaycheckCalc.Blazor.Services
@inject LegacyDataImporter Importer

@if (_summary?.ShouldPrompt == true)
{
    <div class="alert alert-info d-flex flex-wrap align-items-center gap-3 mb-3">
        <div class="flex-grow-1">
            <strong>Import your saved data into this account?</strong>
            <div class="small text-muted">
                We found
                @if (_summary.PaycheckCount > 0)
                {
                    <span><strong>@_summary.PaycheckCount</strong> saved paycheck@(_summary.PaycheckCount == 1 ? "" : "s")</span>
                }
                @if (_summary.PaycheckCount > 0 && _summary.ScenarioCount > 0)
                {
                    <span> and </span>
                }
                @if (_summary.ScenarioCount > 0)
                {
                    <span><strong>@_summary.ScenarioCount</strong> annual scenario@(_summary.ScenarioCount == 1 ? "" : "s")</span>
                }
                <span> in this browser from before account-based sync.</span>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="ImportAsync" disabled="@_busy">
                @(_busy ? "Importing…" : "Import to my account")
            </button>
            <button class="btn btn-outline-secondary" @onclick="SkipAsync" disabled="@_busy">
                Don't import
            </button>
        </div>
    </div>
}

@if (_result is not null)
{
    <div class="alert alert-success mb-3">
        Imported <strong>@_result.ImportedPaychecks</strong> paycheck@(_result.ImportedPaychecks == 1 ? "" : "s") and
        <strong>@_result.ImportedScenarios</strong> scenario@(_result.ImportedScenarios == 1 ? "" : "s") into your account.
        @if (_result.Errors.Count > 0)
        {
            <div class="small text-warning mt-2">
                <strong>@_result.Errors.Count item@(_result.Errors.Count == 1 ? "" : "s") could not be imported:</strong>
                <ul class="mb-0">
                    @foreach (var err in _result.Errors)
                    {
                        <li>@err</li>
                    }
                </ul>
            </div>
        }
    </div>
}

@code {
    [Parameter] public EventCallback OnImported { get; set; }

    private LegacyDataSummary? _summary;
    private LegacyImportResult? _result;
    private bool _busy;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Defer to OnAfterRender so JS interop is available (it isn't during prerender).
        _summary = await Importer.InspectAsync();
        StateHasChanged();
    }

    private async Task ImportAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            _result = await Importer.ImportAsync();
            _summary = await Importer.InspectAsync();
            await OnImported.InvokeAsync();
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task SkipAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            await Importer.SkipAsync();
            _summary = await Importer.InspectAsync();
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }
}
