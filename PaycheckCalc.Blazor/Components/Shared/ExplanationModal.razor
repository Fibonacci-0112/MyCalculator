@using PaycheckCalc.Core.Explanation
@using System.Globalization

@if (Explanation is not null)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" role="dialog" aria-modal="true"
         aria-labelledby="explanationModalTitle" @onclick="OnBackdropClick">
        <div class="modal-dialog modal-dialog-scrollable modal-lg" role="document" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="explanationModalTitle">@Explanation.Title</h5>
                        <div class="text-muted small">
                            Show your work — @Explanation.FinalAmount.ToString("C", CultureInfo.GetCultureInfo("en-US"))
                        </div>
                    </div>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="HandleClose"></button>
                </div>
                <div class="modal-body">
                    <ol class="list-group list-group-numbered">
                        @foreach (var step in Explanation.Steps)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                <div class="ms-2 me-auto">
                                    <div class="fw-bold">@step.Label</div>
                                    <div class="small text-muted">@step.Detail</div>
                                    @if (!string.IsNullOrEmpty(step.Formula))
                                    {
                                        <div class="small font-monospace mt-1">@step.Formula</div>
                                    }
                                </div>
                                @if (step.Value is not null)
                                {
                                    <span class="badge bg-primary rounded-pill text-nowrap align-self-center">
                                        @step.Value.Value.ToString("C", CultureInfo.GetCultureInfo("en-US"))
                                    </span>
                                }
                            </li>
                        }
                    </ol>
                    @if (!string.IsNullOrEmpty(Explanation.Reference))
                    {
                        <div class="alert alert-light border mt-3 mb-0 small">
                            <strong>Source:</strong> @Explanation.Reference
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HandleClose">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public LineExplanation? Explanation { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Task HandleClose() => OnClose.InvokeAsync();
    private Task OnBackdropClick() => OnClose.InvokeAsync();
}
