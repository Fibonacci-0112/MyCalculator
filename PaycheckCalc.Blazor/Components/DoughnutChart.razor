@* SVG doughnut chart showing the composition of Gross Pay across taxes,
   deductions, and net pay. Mirrors the MAUI DoughnutChartDrawable's slice
   order, colors, and legend so the web head visually matches the app. *@

@if (Result is not null && Result.GrossPay > 0 && _slices.Count > 0)
{
    <div class="doughnut-chart">
        <svg viewBox="0 0 200 200" class="doughnut-chart-svg"
             role="img" aria-label="Paycheck composition chart">
            @{
                // Drawing parameters in the 200x200 viewBox.
                const double cx = 100;
                const double cy = 100;
                const double outerR = 90;
                const double innerR = outerR * 0.55;
                double startAngle = -90; // 12 o'clock
            }
            @foreach (var slice in _slices)
            {
                var sweep = (double)slice.Value / (double)Result.GrossPay * 360.0;
                var d = BuildSlicePath(cx, cy, outerR, innerR, startAngle, sweep);
                startAngle += sweep;
                <path d="@d" fill="@slice.Color" />
            }
        </svg>

        <ul class="doughnut-chart-legend">
            @foreach (var slice in _slices)
            {
                var pct = (double)slice.Value / (double)Result.GrossPay * 100.0;
                <li>
                    <span class="doughnut-chart-swatch" style="background-color:@slice.Color"></span>
                    <span class="doughnut-chart-label">@slice.Name</span>
                    <span class="doughnut-chart-pct">@pct.ToString("F1")%</span>
                </li>
            }
        </ul>
    </div>
}

@code {
    [Parameter, EditorRequired] public PaycheckResult? Result { get; set; }

    // Same palette/order as PaycheckCalc.App/Controls/DoughnutChartDrawable.cs
    // so the Blazor chart is visually consistent with the MAUI chart.
    private const string ColorFederal        = "#C62828"; // Federal Tax - red
    private const string ColorSocialSecurity = "#1565C0"; // Social Security - blue
    private const string ColorMedicare       = "#6A1B9A"; // Medicare - purple
    private const string ColorStateTax       = "#EF6C00"; // State Income Tax - orange
    private const string ColorSdi            = "#F9A825"; // State Disability Insurance - amber
    private const string ColorPreTax         = "#5D4037"; // Pre-Tax Deductions - brown
    private const string ColorPostTax        = "#795548"; // Post-Tax Deductions - light brown
    private const string ColorNetPay         = "#2E7D32"; // Net Pay - green

    private readonly List<Slice> _slices = new();

    protected override void OnParametersSet()
    {
        _slices.Clear();
        if (Result is null || Result.GrossPay <= 0) return;

        if (Result.FederalWithholding > 0)
            _slices.Add(new("Federal Tax", Result.FederalWithholding, ColorFederal));
        if (Result.SocialSecurityWithholding > 0)
            _slices.Add(new("Social Security", Result.SocialSecurityWithholding, ColorSocialSecurity));

        var medicareTotal = Result.MedicareWithholding + Result.AdditionalMedicareWithholding;
        if (medicareTotal > 0)
            _slices.Add(new("Medicare Tax", medicareTotal, ColorMedicare));

        if (Result.StateWithholding > 0)
            _slices.Add(new("State Income Tax", Result.StateWithholding, ColorStateTax));
        if (Result.StateDisabilityInsurance > 0)
            _slices.Add(new(Result.StateDisabilityInsuranceLabel, Result.StateDisabilityInsurance, ColorSdi));
        if (Result.PreTaxDeductions > 0)
            _slices.Add(new("Pre-Tax Deductions", Result.PreTaxDeductions, ColorPreTax));
        if (Result.PostTaxDeductions > 0)
            _slices.Add(new("Post-Tax Deductions", Result.PostTaxDeductions, ColorPostTax));
        if (Result.NetPay > 0)
            _slices.Add(new("Net Pay", Result.NetPay, ColorNetPay));
    }

    // Build an SVG path that traces a ring-shaped slice:
    //   outer arc (clockwise) → line to inner arc end → inner arc (counter-clockwise) → close.
    private static string BuildSlicePath(double cx, double cy, double outerR, double innerR,
                                         double startAngleDeg, double sweepDeg)
    {
        // Cap near-full-circle sweeps just under 360° so SVG's arc command
        // renders correctly (an exact 360° arc collapses to a point).
        if (sweepDeg >= 360.0) sweepDeg = 359.999;

        double endAngleDeg = startAngleDeg + sweepDeg;
        double startRad = startAngleDeg * Math.PI / 180.0;
        double endRad   = endAngleDeg   * Math.PI / 180.0;

        double outerStartX = cx + outerR * Math.Cos(startRad);
        double outerStartY = cy + outerR * Math.Sin(startRad);
        double outerEndX   = cx + outerR * Math.Cos(endRad);
        double outerEndY   = cy + outerR * Math.Sin(endRad);
        double innerEndX   = cx + innerR * Math.Cos(endRad);
        double innerEndY   = cy + innerR * Math.Sin(endRad);
        double innerStartX = cx + innerR * Math.Cos(startRad);
        double innerStartY = cy + innerR * Math.Sin(startRad);

        int largeArc = sweepDeg > 180.0 ? 1 : 0;

        var c = System.Globalization.CultureInfo.InvariantCulture;
        return string.Format(c,
            "M {0:F3} {1:F3} " +
            "A {2:F3} {2:F3} 0 {3} 1 {4:F3} {5:F3} " +
            "L {6:F3} {7:F3} " +
            "A {8:F3} {8:F3} 0 {3} 0 {9:F3} {10:F3} Z",
            outerStartX, outerStartY,
            outerR, largeArc, outerEndX, outerEndY,
            innerEndX, innerEndY,
            innerR, innerStartX, innerStartY);
    }

    private sealed record Slice(string Name, decimal Value, string Color);
}

<style>
    .doughnut-chart {
        background: #fff;
        border-radius: 12px;
        padding: 12px;
    }

    .doughnut-chart-svg {
        display: block;
        width: 100%;
        max-width: 360px;
        height: auto;
        margin: 0 auto;
    }

    .doughnut-chart-legend {
        list-style: none;
        padding: 0;
        margin: 16px 0 0;
    }

    .doughnut-chart-legend li {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 2px 0;
        font-size: 0.875rem;
        color: #37474F;
    }

    .doughnut-chart-swatch {
        display: inline-block;
        width: 12px;
        height: 12px;
        border-radius: 2px;
        flex: 0 0 auto;
    }

    .doughnut-chart-label {
        flex: 1 1 auto;
    }

    .doughnut-chart-pct {
        font-variant-numeric: tabular-nums;
        color: #546E7A;
    }
</style>
