@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        var current = new Uri(Nav.Uri).PathAndQuery;
        // forceLoad: true so the post-login navigation flushes the new cookie
        // through a fresh HTTP request before Blazor reconnects the circuit.
        Nav.NavigateTo(
            $"/account/login?returnUrl={Uri.EscapeDataString(current)}",
            forceLoad: true);
    }
}
