@page "/account/login"
@layout MainLayout

<PageTitle>Sign in — PaycheckCalc</PageTitle>

<div class="row">
    <div class="col-md-6 col-lg-5 mx-auto">
        <h1 class="mb-3">Sign in</h1>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger">@Error</div>
        }

        <form action="/account/login-cookie" method="post">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="mb-3">
                <label class="form-label" for="login-email">Email</label>
                <input id="login-email" class="form-control" name="email" type="email" autocomplete="username" required />
            </div>
            <div class="mb-3">
                <label class="form-label" for="login-password">Password</label>
                <input id="login-password" class="form-control" name="password" type="password" autocomplete="current-password" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Sign in</button>
        </form>

        <hr class="my-4" />
        <p class="text-muted small mb-2">Or sign in with</p>
        <form action="/account/external-login" method="post" class="d-flex gap-2">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <button type="submit" name="provider" value="Google" class="btn btn-outline-secondary flex-grow-1">Google</button>
            <button type="submit" name="provider" value="Microsoft" class="btn btn-outline-secondary flex-grow-1">Microsoft</button>
        </form>

        <p class="mt-4 mb-0">
            Don't have an account? <a href="/account/register">Create one</a>
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
}
