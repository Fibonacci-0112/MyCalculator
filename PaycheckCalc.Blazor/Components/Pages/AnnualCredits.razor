@page "/annual/credits"
@inject AnnualTaxSessionState Session
@inject StateCalculatorRegistry StateRegistry

<PageTitle>Credits — PaycheckCalc</PageTitle>

<h1>Credits &amp; Filing Basics</h1>
<p class="text-muted">
    Pick a tax year and filing status, then enter credit details. Each
    structured credit (CTC, Education, Saver's, NIIT) has a toggle — when
    off, only the legacy lump-sum entries below are used.
</p>

<div class="card mb-3">
    <div class="card-header"><strong>Filing Basics</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Tax year</label>
                <input type="number" min="2020" step="1" class="form-control"
                       @bind="Session.TaxYear" />
            </div>
            <div class="col-md-5">
                <label class="form-label">Filing status</label>
                <select class="form-select" @bind="Session.FilingStatus">
                    <option value="@FederalFilingStatus.SingleOrMarriedSeparately">
                        @EnumDisplay.FederalFilingStatus("SingleOrMarriedSeparately")
                    </option>
                    <option value="@FederalFilingStatus.MarriedFilingJointly">
                        @EnumDisplay.FederalFilingStatus("MarriedFilingJointly")
                    </option>
                    <option value="@FederalFilingStatus.HeadOfHousehold">
                        @EnumDisplay.FederalFilingStatus("HeadOfHousehold")
                    </option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Residence state</label>
                <select class="form-select" @bind="Session.ResidenceState">
                    @foreach (var s in StateRegistry.SupportedStates.OrderBy(x => x.ToString()))
                    {
                        <option value="@s">@EnumDisplay.UsStateName(s.ToString())</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Qualifying children (W-4 alignment)</label>
                <input type="number" min="0" step="1" class="form-control"
                       @bind="Session.QualifyingChildren" />
                <div class="form-text">
                    Used for W-4 / dependent tracking. CTC count below is independent.
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Itemized deductions over standard ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.ItemizedDeductionsOverStandard" />
                <div class="form-text">Zero means take the standard deduction.</div>
            </div>
        </div>
    </div>
</div>

<!-- Child Tax Credit -->
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Child Tax Credit / Credit for Other Dependents</strong>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="useCtc"
                   @bind="Session.UseStructuredChildTaxCredit" />
            <label class="form-check-label small" for="useCtc">
                Use structured CTC
            </label>
        </div>
    </div>
    <div class="card-body">
        @if (Session.UseStructuredChildTaxCredit)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Qualifying children (under 17)</label>
                    <input type="number" min="0" step="1" class="form-control"
                           @bind="Session.CtcQualifyingChildren" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Other dependents (ODC)</label>
                    <input type="number" min="0" step="1" class="form-control"
                           @bind="Session.CtcOtherDependents" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Earned income ($)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.CtcEarnedIncome" />
                    <div class="form-text">For ACTC refundable cap.</div>
                </div>
            </div>
        }
        else
        {
            <p class="text-muted small mb-0">
                Structured CTC is off. Enter a pre-computed amount in the
                Legacy Lump Sums section below if needed.
            </p>
        }
    </div>
</div>

<!-- Education Credits -->
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Education Credits (Form 8863)</strong>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="useEdu"
                   @bind="Session.UseStructuredEducationCredits" />
            <label class="form-check-label small" for="useEdu">
                Use structured education credits
            </label>
        </div>
    </div>
    <div class="card-body">
        @if (Session.UseStructuredEducationCredits)
        {
            @for (int i = 0; i < Session.EducationStudents.Count; i++)
            {
                var idx = i;
                var st = Session.EducationStudents[idx];
                <div class="border rounded p-3 mb-3 bg-light">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Student name</label>
                            <input class="form-control" @bind="st.Name" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Qualified expenses ($)</label>
                            <input type="number" min="0" step="0.01" class="form-control"
                                   @bind="st.QualifiedExpenses" />
                        </div>
                        <div class="col-md-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       id="@($"aotc{idx}")"
                                       @bind="st.ClaimAmericanOpportunityCredit" />
                                <label class="form-check-label small" for="@($"aotc{idx}")">
                                    AOTC
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       id="@($"llc{idx}")"
                                       @bind="st.ClaimLifetimeLearningCredit" />
                                <label class="form-check-label small" for="@($"llc{idx}")">
                                    LLC
                                </label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    @onclick="() => Session.EducationStudents.RemoveAt(idx)">
                                ✕ Remove student
                            </button>
                        </div>
                    </div>
                </div>
            }
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">MAGI override ($, optional)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.EducationModifiedAgiOverride" />
                    <div class="form-text">Leave 0 to use AGI for phase-out.</div>
                </div>
                <div class="col-md-6">
                    <button type="button" class="btn btn-outline-primary"
                            @onclick="AddStudent">
                        + Add Student
                    </button>
                </div>
            </div>
        }
        else
        {
            <p class="text-muted small mb-0">
                Structured education credits are off.
            </p>
        }
    </div>
</div>

<!-- Saver's Credit -->
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Saver's Credit (Form 8880)</strong>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="useSavers"
                   @bind="Session.UseStructuredSaversCredit" />
            <label class="form-check-label small" for="useSavers">
                Use structured Saver's Credit
            </label>
        </div>
    </div>
    <div class="card-body">
        @if (Session.UseStructuredSaversCredit)
        {
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Taxpayer contributions ($, max $2,000)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.SaversTaxpayerContributions" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Spouse contributions ($, MFJ only)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.SaversSpouseContributions" />
                </div>
            </div>
        }
        else
        {
            <p class="text-muted small mb-0">Structured Saver's Credit is off.</p>
        }
    </div>
</div>

<!-- NIIT (Form 8960) -->
<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Net Investment Income Tax (Form 8960)</strong>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="useNiit"
                   @bind="Session.UseStructuredNiit" />
            <label class="form-check-label small" for="useNiit">
                Use structured NIIT
            </label>
        </div>
    </div>
    <div class="card-body">
        @if (Session.UseStructuredNiit)
        {
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Net investment income ($)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.NiitNetInvestmentIncome" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">MAGI override ($, optional)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.NiitModifiedAgiOverride" />
                    <div class="form-text">Leave 0 to use AGI for the formula.</div>
                </div>
            </div>
        }
        else
        {
            <p class="text-muted small mb-0">Structured NIIT is off.</p>
        }
    </div>
</div>

<!-- Legacy lump sums -->
<div class="card mb-3">
    <div class="card-header"><strong>Legacy Lump Sums</strong></div>
    <div class="card-body">
        <p class="text-muted small">
            Pre-computed amounts that bypass the dedicated calculators above.
            Values here are added to anything produced by the structured inputs.
        </p>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Nonrefundable credits ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.NonrefundableCredits" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Refundable credits ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.RefundableCredits" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Pre-computed CTC ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.PrecomputedChildTaxCredit" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Pre-computed NIIT ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.NetInvestmentIncomeTax" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Other Schedule 2 taxes ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.OtherSchedule2Taxes" />
            </div>
        </div>
    </div>
</div>

<!-- Payments & withholding -->
<div class="card mb-3">
    <div class="card-header"><strong>Payments &amp; Expected Withholding</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">1040-ES estimated tax payments ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.EstimatedTaxPayments" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Additional expected withholding ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.AdditionalExpectedWithholding" />
                <div class="form-text">Beyond W-2 Box 2 (e.g., 1099-R voluntary WH).</div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2">
    <a class="btn btn-outline-primary" href="annual/quarterly">Continue to Quarterly Estimates →</a>
    <a class="btn btn-link" href="annual/results">Jump to Annual Results</a>
</div>

@code {
    private void AddStudent()
    {
        Session.EducationStudents.Add(new EducationStudentEntry
        {
            Name = $"Student {Session.EducationStudents.Count + 1}",
            ClaimAmericanOpportunityCredit = true
        });
    }
}
