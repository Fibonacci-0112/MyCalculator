@page "/annual/results"
@inject AnnualTaxSessionState Session
@inject Form1040Calculator Calculator
@inject IAnnualScenarioRepository Repo

<PageTitle>Annual Results — PaycheckCalc</PageTitle>

<h1>Annual Tax Results</h1>
<p class="text-muted">
    Full Form 1040 projection: AGI build-up, deductions, tax before/after
    credits, payments, and the final refund or balance due.
</p>

<div class="d-flex gap-2 flex-wrap mb-3 align-items-center">
    <button class="btn btn-primary btn-lg" @onclick="Recalculate">
        🧮 Calculate
    </button>
    <button class="btn btn-outline-secondary" @onclick="StartNew">
        ➕ New Scenario
    </button>
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-0 py-2 px-3">@_errorMessage</div>
    }
</div>

@if (Session.LastResult is null)
{
    <div class="alert alert-info">
        Click <strong>Calculate</strong> to project your annual tax. Make sure
        you've filled in
        <a href="annual/jobs">Jobs &amp; YTD</a>,
        <a href="annual/other-income">Other Income</a>, and
        <a href="annual/credits">Credits</a> first.
    </div>
}
else
{
    var r = Session.LastResult;
    var refund = r.RefundOrOwe;
    var refundLabel = refund >= 0m ? "Estimated Refund" : "Estimated Balance Due";
    var refundClass = refund >= 0m ? "table-success" : "table-danger";

    <div class="card mb-3">
        <div class="card-header"><strong>@refundLabel</strong></div>
        <div class="card-body">
            <h2 class="@(refund >= 0m ? "text-success" : "text-danger") mb-2">
                @Math.Abs(refund).ToString("C")
            </h2>
            <div class="text-muted small">
                @EnumDisplay.FederalFilingStatus(r.FilingStatus.ToString()) ·
                Tax year @r.TaxYear ·
                Effective rate @r.EffectiveTaxRate.ToString("F2")% ·
                Marginal rate @((r.MarginalTaxRate * 100m).ToString("F1"))%
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Income Build-up</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>W-2 wages (sum of Box 1)</td>
                        <td class="text-end">@r.TotalW2Wages.ToString("C")</td>
                    </tr>
                    @if (r.ScheduleCNetProfit != 0)
                    {
                        <tr>
                            <td>Schedule C net profit</td>
                            <td class="text-end">@r.ScheduleCNetProfit.ToString("C")</td>
                        </tr>
                    }
                    @if (r.AdditionalIncome != 0)
                    {
                        <tr>
                            <td>Schedule 1 additional income</td>
                            <td class="text-end">@r.AdditionalIncome.ToString("C")</td>
                        </tr>
                    }
                    <tr>
                        <td>Total income</td>
                        <td class="text-end">@r.TotalIncome.ToString("C")</td>
                    </tr>
                    @if (r.TotalAdjustments != 0)
                    {
                        <tr>
                            <td>Adjustments to income</td>
                            <td class="text-end text-danger">(@r.TotalAdjustments.ToString("C"))</td>
                        </tr>
                    }
                    <tr class="table-secondary">
                        <th>Adjusted Gross Income (AGI)</th>
                        <td class="text-end fw-bold">@r.AdjustedGrossIncome.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Deductions &amp; Taxable Income</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Standard deduction</td>
                        <td class="text-end text-danger">(@r.StandardDeduction.ToString("C"))</td>
                    </tr>
                    @if (r.ItemizedDeductionsOverStandard != 0)
                    {
                        <tr>
                            <td>Itemized over standard</td>
                            <td class="text-end text-danger">(@r.ItemizedDeductionsOverStandard.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.QbiDeduction != 0)
                    {
                        <tr>
                            <td>QBI deduction (Form 8995 / 8995-A)</td>
                            <td class="text-end text-danger">(@r.QbiDeduction.ToString("C"))</td>
                        </tr>
                    }
                    <tr class="table-secondary">
                        <th>Taxable Income</th>
                        <td class="text-end fw-bold">@r.TaxableIncome.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Tax &amp; Credits</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Income tax before credits</td>
                        <td class="text-end">@r.IncomeTaxBeforeCredits.ToString("C")</td>
                    </tr>
                    @if (r.ChildTaxCredit != 0)
                    {
                        <tr>
                            <td>Child Tax Credit (nonrefundable portion)</td>
                            <td class="text-end text-danger">(@r.ChildTaxCredit.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.EducationCreditsNonrefundable != 0)
                    {
                        <tr>
                            <td>Education credits (Form 8863 nonrefundable)</td>
                            <td class="text-end text-danger">(@r.EducationCreditsNonrefundable.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.SaversCredit != 0)
                    {
                        <tr>
                            <td>Saver's Credit (Form 8880)</td>
                            <td class="text-end text-danger">(@r.SaversCredit.ToString("C"))</td>
                        </tr>
                    }
                    <tr>
                        <td>Total nonrefundable credits</td>
                        <td class="text-end text-danger">(@r.NonrefundableCredits.ToString("C"))</td>
                    </tr>
                    <tr>
                        <td>Income tax after credits</td>
                        <td class="text-end">@r.IncomeTaxAfterCredits.ToString("C")</td>
                    </tr>
                    @if (r.SelfEmploymentTax != 0)
                    {
                        <tr>
                            <td>Self-employment tax (Schedule SE)</td>
                            <td class="text-end">@r.SelfEmploymentTax.ToString("C")</td>
                        </tr>
                    }
                    @if (r.NetInvestmentIncomeTax != 0)
                    {
                        <tr>
                            <td>Net Investment Income Tax (Form 8960)</td>
                            <td class="text-end">@r.NetInvestmentIncomeTax.ToString("C")</td>
                        </tr>
                    }
                    @if (r.OtherSchedule2Taxes != 0)
                    {
                        <tr>
                            <td>Other Schedule 2 taxes</td>
                            <td class="text-end">@r.OtherSchedule2Taxes.ToString("C")</td>
                        </tr>
                    }
                    <tr class="table-secondary">
                        <th>Total Tax (Form 1040 line 24)</th>
                        <td class="text-end fw-bold">@r.TotalTax.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Payments</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Federal withholding from W-2s</td>
                        <td class="text-end">@r.FederalWithholdingFromW2s.ToString("C")</td>
                    </tr>
                    @if (r.EstimatedTaxPayments != 0)
                    {
                        <tr>
                            <td>Estimated tax payments</td>
                            <td class="text-end">@r.EstimatedTaxPayments.ToString("C")</td>
                        </tr>
                    }
                    @if (r.ExcessSocialSecurityCredit != 0)
                    {
                        <tr>
                            <td>Excess Social Security credit</td>
                            <td class="text-end">@r.ExcessSocialSecurityCredit.ToString("C")</td>
                        </tr>
                    }
                    @if (r.RefundableEducationCredit != 0)
                    {
                        <tr>
                            <td>Refundable AOTC</td>
                            <td class="text-end">@r.RefundableEducationCredit.ToString("C")</td>
                        </tr>
                    }
                    @if (r.RefundableAdditionalChildTaxCredit != 0)
                    {
                        <tr>
                            <td>Additional Child Tax Credit (refundable)</td>
                            <td class="text-end">@r.RefundableAdditionalChildTaxCredit.ToString("C")</td>
                        </tr>
                    }
                    @if (r.RefundableCredits != 0)
                    {
                        <tr>
                            <td>Total refundable credits</td>
                            <td class="text-end">@r.RefundableCredits.ToString("C")</td>
                        </tr>
                    }
                    <tr class="table-secondary">
                        <th>Total Payments</th>
                        <td class="text-end fw-bold">@r.TotalPayments.ToString("C")</td>
                    </tr>
                    <tr class="@refundClass fw-bold">
                        <th>@refundLabel</th>
                        <td class="text-end">@Math.Abs(r.RefundOrOwe).ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @if (r.StateTax is { } st && !st.IsNoIncomeTaxState)
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>State Tax — @EnumDisplay.UsStateName(st.State.ToString())</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <tbody>
                        <tr>
                            <td>State wages</td>
                            <td class="text-end">@st.StateWages.ToString("C")</td>
                        </tr>
                        <tr>
                            <td>Estimated state income tax</td>
                            <td class="text-end">@st.StateIncomeTax.ToString("C")</td>
                        </tr>
                        @if (st.StateDisabilityInsurance != 0)
                        {
                            <tr>
                                <td>@st.StateDisabilityInsuranceLabel</td>
                                <td class="text-end">@st.StateDisabilityInsurance.ToString("C")</td>
                            </tr>
                        }
                        <tr>
                            <td>State tax withheld</td>
                            <td class="text-end">@st.StateTaxWithheld.ToString("C")</td>
                        </tr>
                        <tr class="@(st.StateRefundOrOwe >= 0 ? "table-success" : "table-danger") fw-bold">
                            <th>@(st.StateRefundOrOwe >= 0 ? "State refund" : "State balance due")</th>
                            <td class="text-end">@Math.Abs(st.StateRefundOrOwe).ToString("C")</td>
                        </tr>
                    </tbody>
                </table>
                @if (!string.IsNullOrWhiteSpace(st.Description))
                {
                    <div class="card-footer text-muted small">@st.Description</div>
                }
            </div>
        </div>
    }
}

<!-- Save / Load -->
<AuthorizeView>
    <Authorized Context="auth">
        <div class="card mb-3">
            <div class="card-header"><strong>Save Scenario</strong></div>
            <div class="card-body">
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <input class="form-control" style="max-width: 280px;"
                           placeholder="Scenario name"
                           @bind="_saveName" />
                    <button class="btn btn-success" @onclick="SaveAsync" disabled="@_saving">
                        💾 @(_saving ? "Saving…" : (Session.LoadedScenarioId is null ? "Save as new" : "Overwrite"))
                    </button>
                    @if (_saveMessage is not null)
                    {
                        <span class="text-success small">@_saveMessage</span>
                    }
                </div>
                @if (Session.LoadedScenarioId is not null)
                {
                    <div class="form-text mt-2">
                        Loaded scenario: <strong>@Session.LoadedScenarioName</strong>.
                        Save will overwrite this scenario; click "New Scenario" above to start fresh.
                    </div>
                }
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-info">
            <a href="/account/login?returnUrl=/annual/results">Sign in</a> to save and reload this scenario across devices.
        </div>
    </NotAuthorized>
</AuthorizeView>

<AuthorizeView>
    <Authorized Context="auth">
<div class="card mb-3">
    <div class="card-header"><strong>Saved Scenarios</strong></div>
    <div class="card-body p-0">
        @if (_loadingList)
        {
            <p class="text-muted fst-italic m-3">Loading…</p>
        }
        else if (_savedScenarios.Count == 0)
        {
            <p class="text-muted fst-italic m-3">No saved scenarios yet.</p>
        }
        else
        {
            <table class="table table-striped mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>State</th>
                        <th>Updated</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _savedScenarios)
                    {
                        <tr>
                            <td>
                                <strong>@(string.IsNullOrWhiteSpace(s.Name) ? "(Unnamed)" : s.Name)</strong>
                            </td>
                            <td>@EnumDisplay.FederalFilingStatus(s.Profile.FilingStatus.ToString())</td>
                            <td>@s.Profile.ResidenceState</td>
                            <td>@s.UpdatedAt.LocalDateTime.ToString("g")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        @onclick="() => LoadAsync(s.Id)">
                                    Load
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeleteAsync(s.Id)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
    </Authorized>
</AuthorizeView>

@code {
    private string _saveName = "";
    private bool _saving;
    private string? _saveMessage;
    private string? _errorMessage;

    private List<SavedAnnualScenario> _savedScenarios = new();
    private bool _loadingList = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await ReloadListAsync();
        // If the user navigated here from a Load button on another page, seed
        // the save-name input from the loaded scenario name.
        if (!string.IsNullOrEmpty(Session.LoadedScenarioName) && string.IsNullOrEmpty(_saveName))
        {
            _saveName = Session.LoadedScenarioName;
            StateHasChanged();
        }
    }

    private void Recalculate()
    {
        _errorMessage = null;
        try
        {
            var profile = Session.BuildProfile();
            Session.LastResult = Calculator.Calculate(profile);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void StartNew()
    {
        Session.Reset();
        _saveName = "";
        _saveMessage = null;
        _errorMessage = null;
    }

    private async Task SaveAsync()
    {
        if (_saving) return;
        _saving = true;
        _saveMessage = null;
        try
        {
            var name = string.IsNullOrWhiteSpace(_saveName)
                ? $"Scenario {DateTime.Now:g}"
                : _saveName.Trim();

            var now = DateTimeOffset.UtcNow;
            var existing = Session.LoadedScenarioId is { } id
                ? await Repo.GetByIdAsync(id)
                : null;

            var scenario = new SavedAnnualScenario
            {
                Id = existing?.Id ?? Guid.NewGuid(),
                Name = name,
                CreatedAt = existing?.CreatedAt ?? now,
                UpdatedAt = now,
                Profile = Session.BuildProfile(),
                Result = Session.LastResult
            };

            await Repo.SaveAsync(scenario);
            Session.LoadedScenarioId = scenario.Id;
            Session.LoadedScenarioName = scenario.Name;
            _saveMessage = $"Saved as \"{name}\".";
            await ReloadListAsync();
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task LoadAsync(Guid id)
    {
        var scenario = await Repo.GetByIdAsync(id);
        if (scenario is null) return;
        Session.LoadFromScenario(scenario);
        _saveName = scenario.Name;
        _saveMessage = null;
        // Re-run the engine on the loaded inputs so the results card reflects
        // current tax tables even if the saved Result is stale.
        Recalculate();
    }

    private async Task DeleteAsync(Guid id)
    {
        await Repo.DeleteAsync(id);
        if (Session.LoadedScenarioId == id)
        {
            Session.LoadedScenarioId = null;
            Session.LoadedScenarioName = "";
        }
        await ReloadListAsync();
    }

    private async Task ReloadListAsync()
    {
        _loadingList = true;
        StateHasChanged();
        var all = await Repo.GetAllAsync();
        _savedScenarios = all.OrderByDescending(s => s.UpdatedAt).ToList();
        _loadingList = false;
        StateHasChanged();
    }
}
