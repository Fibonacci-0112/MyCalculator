@page "/annual/other-income"
@inject AnnualTaxSessionState Session

<PageTitle>Other Income &amp; Adjustments — PaycheckCalc</PageTitle>

<h1>Other Income &amp; Adjustments</h1>
<p class="text-muted">
    Schedule 1 — non-wage income (Part I) and above-the-line adjustments to
    income (Part II). The deductible half of self-employment tax is computed
    automatically by the engine; do not enter it here.
</p>

<div class="card mb-3">
    <div class="card-header"><strong>Additional Income (Schedule 1 Part I)</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Taxable interest ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.TaxableInterest" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Ordinary dividends ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.OrdinaryDividends" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Qualified dividends ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.QualifiedDividends" />
                <div class="form-text">
                    Subset of ordinary dividends taxed at preferential rates.
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Capital gain or (loss) ($)</label>
                <input type="number" step="0.01" class="form-control"
                       @bind="Session.CapitalGainOrLoss" />
                <div class="form-text">May be negative (capital loss).</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Unemployment compensation ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.UnemploymentCompensation" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Taxable state/local refunds ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.TaxableStateLocalRefunds" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Taxable Social Security benefits ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.TaxableSocialSecurity" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Other additional income ($)</label>
                <input type="number" step="0.01" class="form-control"
                       @bind="Session.OtherAdditionalIncome" />
                <div class="form-text">Gambling winnings, prizes, jury duty, etc.</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Adjustments to Income (Schedule 1 Part II)</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Student loan interest ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.StudentLoanInterest" />
                <div class="form-text">Max $2,500; MAGI phase-outs apply.</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">HSA deduction ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.HsaDeduction" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Traditional IRA deduction ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.TraditionalIraDeduction" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Educator expenses ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.EducatorExpenses" />
                <div class="form-text">Max $300 per educator ($600 MFJ).</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Self-employed health insurance ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.SelfEmployedHealthInsurance" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Self-employed retirement (SEP/SIMPLE/qualified) ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.SelfEmployedRetirement" />
            </div>
            <div class="col-md-12">
                <label class="form-label">Other adjustments ($)</label>
                <input type="number" step="0.01" class="form-control"
                       @bind="Session.OtherAdjustments" />
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2">
    <a class="btn btn-outline-primary" href="annual/credits">Continue to Credits →</a>
</div>
