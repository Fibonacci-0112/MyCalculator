@page "/inputs"
@inject StateCalculatorRegistry StateRegistry
@inject PayCalculator PayCalculator
@inject CalculatorSessionState Session
@inject NavigationManager Nav

<PageTitle>Inputs — PaycheckCalc</PageTitle>

<h1>Paycheck Inputs</h1>

<!-- Tab header -->
<ul class="nav nav-tabs mb-3" role="tablist">
    @foreach (var tab in _tabs)
    {
        var isActive = _activeTab == tab;
        <li class="nav-item" role="presentation">
            <button type="button"
                    class="nav-link @(isActive ? "active" : "")"
                    @onclick="() => _activeTab = tab">
                @tab
            </button>
        </li>
    }
</ul>

<div class="tab-content">

    @if (_activeTab == "Pay & Hours")
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Pay Frequency</label>
                        <select class="form-select" @bind="Session.Frequency">
                            @foreach (var f in Enum.GetValues<PayFrequency>())
                            {
                                <option value="@f">@FrequencyLabel(f)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Hourly Rate ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.HourlyRate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Regular Hours</label>
                        <input type="number" min="0" step="0.5" class="form-control"
                               @bind="Session.RegularHours" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Overtime Hours</label>
                        <input type="number" min="0" step="0.5" class="form-control"
                               @bind="Session.OvertimeHours" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">OT Multiplier</label>
                        <input type="number" min="1" step="0.1" class="form-control"
                               @bind="Session.OvertimeMultiplier" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Paycheck # (this year)</label>
                        <input type="number" min="1" step="1" class="form-control"
                               @bind="Session.PaycheckNumber" />
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_activeTab == "Federal")
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Filing Status</label>
                        <select class="form-select" @bind="Session.FederalFilingStatus">
                            <option value="@FederalFilingStatus.SingleOrMarriedSeparately">Single / Married Filing Separately</option>
                            <option value="@FederalFilingStatus.MarriedFilingJointly">Married Filing Jointly</option>
                            <option value="@FederalFilingStatus.HeadOfHousehold">Head of Household</option>
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="fedStep2"
                                   @bind="Session.FederalStep2Checked" />
                            <label class="form-check-label" for="fedStep2">
                                Step 2: Multiple jobs / spouse works
                            </label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Step 3 credits (annual, $)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.FederalStep3Credits" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Step 4(a) other income (annual, $)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.FederalStep4aOtherIncome" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Step 4(b) deductions (annual, $)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.FederalStep4bDeductions" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Step 4(c) extra per pay period ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.FederalStep4cExtraWithholding" />
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_activeTab == "State")
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">State</label>
                    <select class="form-select" value="@Session.State"
                            @onchange="OnStateChanged">
                        @foreach (var s in StateRegistry.SupportedStates.OrderBy(x => x.ToString()))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>

                @if (_stateSchema is null || _stateSchema.Count == 0)
                {
                    <p class="text-muted fst-italic mb-0">
                        No extra inputs required for this state.
                    </p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var field in _stateSchema)
                        {
                            <div class="col-md-6">
                                <label class="form-label">@field.Label</label>
                                @switch (field.FieldType)
                                {
                                    case StateFieldType.Picker:
                                        <select class="form-select"
                                                value="@(GetStateValue(field)?.ToString() ?? "")"
                                                @onchange="e => SetStateValue(field, e.Value?.ToString())">
                                            @if (field.Options is not null)
                                            {
                                                @foreach (var opt in field.Options)
                                                {
                                                    <option value="@opt">@opt</option>
                                                }
                                            }
                                        </select>
                                        break;
                                    case StateFieldType.Toggle:
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@Convert.ToBoolean(GetStateValue(field) ?? false)"
                                                   @onchange="e => SetStateValue(field, e.Value)" />
                                        </div>
                                        break;
                                    case StateFieldType.Integer:
                                        <input type="number" step="1" class="form-control"
                                               value="@(GetStateValue(field)?.ToString() ?? "0")"
                                               @onchange="e => SetStateValue(field, e.Value?.ToString())" />
                                        break;
                                    case StateFieldType.Decimal:
                                        <input type="number" step="0.01" class="form-control"
                                               value="@(GetStateValue(field)?.ToString() ?? "0")"
                                               @onchange="e => SetStateValue(field, e.Value?.ToString())" />
                                        break;
                                    default:
                                        <input type="text" class="form-control"
                                               value="@(GetStateValue(field)?.ToString() ?? "")"
                                               @onchange="e => SetStateValue(field, e.Value?.ToString())" />
                                        break;
                                }
                            </div>
                        }
                    </div>

                    @if (_stateValidationErrors.Count > 0)
                    {
                        <div class="alert alert-danger mt-3 mb-0">
                            <ul class="mb-0">
                                @foreach (var err in _stateValidationErrors)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (_activeTab == "Deductions")
    {
        <div class="card mb-3">
            <div class="card-body">
                @if (Session.Deductions.Count == 0)
                {
                    <p class="text-muted fst-italic">No deductions added.</p>
                }
                @for (int i = 0; i < Session.Deductions.Count; i++)
                {
                    var idx = i;
                    var d = Session.Deductions[idx];
                    <div class="border rounded p-3 mb-3 bg-light">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label">Name</label>
                                <input class="form-control" placeholder="e.g. 401(k)"
                                       @bind="d.Name" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Amount</label>
                                <input type="number" min="0" step="0.01" class="form-control"
                                       @bind="d.Amount" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Amount Type</label>
                                <select class="form-select" @bind="d.AmountType">
                                    <option value="@DeductionAmountType.Dollar">$</option>
                                    <option value="@DeductionAmountType.Percentage">%</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Type</label>
                                <select class="form-select" @bind="d.Type">
                                    <option value="@DeductionType.PreTax">Pre-Tax</option>
                                    <option value="@DeductionType.PostTax">Post-Tax</option>
                                </select>
                            </div>
                            <div class="col-md-2 d-flex flex-column">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox"
                                           id="@($"rsw{idx}")"
                                           @bind="d.ReducesStateTaxableWages" />
                                    <label class="form-check-label small" for="@($"rsw{idx}")">
                                        Reduces State Wages
                                    </label>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        @onclick="() => Session.Deductions.RemoveAt(idx)">
                                    ✕ Remove
                                </button>
                            </div>
                        </div>
                    </div>
                }
                <button type="button" class="btn btn-outline-primary"
                        @onclick="() => Session.Deductions.Add(new DeductionEntry())">
                    + Add Deduction
                </button>
            </div>
        </div>
    }

</div>

<div class="d-flex gap-2 mt-3">
    <button type="button" class="btn btn-primary btn-lg" @onclick="Calculate">
        Calculate →
    </button>
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-0 py-2 px-3">@_errorMessage</div>
    }
</div>

@code {
    private static readonly string[] _tabs =
        { "Pay & Hours", "Federal", "State", "Deductions" };

    private string _activeTab = "Pay & Hours";
    private IReadOnlyList<StateFieldDefinition>? _stateSchema;
    private List<string> _stateValidationErrors = new();
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        RefreshStateSchema();
    }

    private void OnStateChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<UsState>(e.Value?.ToString(), out var state))
        {
            Session.State = state;
            // New state ⇒ new schema, so replace stored values with defaults.
            Session.StateInputValues = new StateInputValues();
            RefreshStateSchema();
        }
    }

    private void RefreshStateSchema()
    {
        var calc = StateRegistry.IsSupported(Session.State)
            ? StateRegistry.GetCalculator(Session.State)
            : null;
        _stateSchema = calc?.GetInputSchema() ?? Array.Empty<StateFieldDefinition>();

        // Seed defaults for any fields not already set (e.g. first visit to this state).
        foreach (var field in _stateSchema)
        {
            if (!Session.StateInputValues.ContainsKey(field.Key))
                Session.StateInputValues[field.Key] = field.DefaultValue;
        }

        _stateValidationErrors.Clear();
    }

    private object? GetStateValue(StateFieldDefinition field) =>
        Session.StateInputValues.TryGetValue(field.Key, out var v) ? v : field.DefaultValue;

    private void SetStateValue(StateFieldDefinition field, object? raw)
    {
        // Coerce raw string values from <input> into the appropriate primitive
        // so Core's calculators don't have to re-parse them every calculation.
        object? typed = field.FieldType switch
        {
            StateFieldType.Integer => int.TryParse(raw?.ToString(), out var i) ? i : 0,
            StateFieldType.Decimal => decimal.TryParse(raw?.ToString(), out var d) ? d : 0m,
            StateFieldType.Toggle  => raw is bool b ? b
                                      : bool.TryParse(raw?.ToString(), out var pb) && pb,
            _ => raw?.ToString()
        };
        Session.StateInputValues[field.Key] = typed;
    }

    private void Calculate()
    {
        _errorMessage = null;
        _stateValidationErrors.Clear();

        // Validate state inputs through the schema-driven calculator contract.
        var calc = StateRegistry.IsSupported(Session.State)
            ? StateRegistry.GetCalculator(Session.State)
            : null;
        if (calc is not null)
        {
            var errors = calc.Validate(Session.StateInputValues);
            if (errors.Count > 0)
            {
                _stateValidationErrors.AddRange(errors);
                _activeTab = "State";
                return;
            }
        }

        try
        {
            var input = Session.BuildInput();
            Session.LastResult = PayCalculator.Calculate(input);
            Nav.NavigateTo("results");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private static string FrequencyLabel(PayFrequency f) => f switch
    {
        PayFrequency.Weekly      => "Weekly (52/yr)",
        PayFrequency.Biweekly    => "Bi-Weekly (26/yr)",
        PayFrequency.Semimonthly => "Semi-Monthly (24/yr)",
        PayFrequency.Monthly     => "Monthly (12/yr)",
        PayFrequency.Quarterly   => "Quarterly (4/yr)",
        PayFrequency.Semiannual  => "Semi-Annual (2/yr)",
        PayFrequency.Annual      => "Annual (1/yr)",
        PayFrequency.Daily       => "Daily (260/yr)",
        _                        => f.ToString()
    };
}
