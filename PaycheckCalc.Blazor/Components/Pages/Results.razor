@page "/results"
@using PaycheckCalc.Core.Explanation
@using PaycheckCalc.Core.Storage
@using PaycheckCalc.Blazor.Components.Shared
@inject CalculatorSessionState Session
@inject IPaycheckRepository Repo
@inject NavigationManager Nav

<PageTitle>Results — PaycheckCalc</PageTitle>

<h1>Your Paycheck Summary</h1>

@if (Session.LastResult is null)
{
    <div class="alert alert-info">
        No calculation yet. Head to <a href="inputs">Inputs</a>, enter your pay
        details, and click <strong>Calculate</strong>.
    </div>
}
else
{
    var r = Session.LastResult;
    var payRate = PayRate(Session.Frequency);

    <!-- Income -->
    <div class="card mb-3">
        <div class="card-header"><strong>Income (this pay period)</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr class="table-success">
                        <th>
                            Gross Pay
                            @ExplainButton(r.Explanation, ExplanationLineKey.GrossPay)
                        </th>
                        <td class="text-end fw-bold">@r.GrossPay.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Federal Taxable Income</td>
                        <td class="text-end">@r.FederalTaxableIncome.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>State Taxable Wages</td>
                        <td class="text-end">@r.StateTaxableWages.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Deductions & Taxes -->
    <div class="card mb-3">
        <div class="card-header"><strong>Deductions &amp; Taxes</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    @if (r.PreTaxDeductions != 0)
                    {
                        <tr>
                            <td>Pre-Tax Deductions</td>
                            <td class="text-end text-danger">(@r.PreTaxDeductions.ToString("C"))</td>
                        </tr>
                    }
                    <tr>
                        <td>
                            Federal Withholding
                            @ExplainButton(r.Explanation, ExplanationLineKey.FederalWithholding)
                        </td>
                        <td class="text-end text-danger">(@r.FederalWithholding.ToString("C"))</td>
                    </tr>
                    <tr>
                        <td>
                            Social Security (6.2%)
                            @ExplainButton(r.Explanation, ExplanationLineKey.SocialSecurity)
                        </td>
                        <td class="text-end text-danger">(@r.SocialSecurityWithholding.ToString("C"))</td>
                    </tr>
                    <tr>
                        <td>
                            Medicare (1.45%)
                            @ExplainButton(r.Explanation, ExplanationLineKey.Medicare)
                        </td>
                        <td class="text-end text-danger">(@r.MedicareWithholding.ToString("C"))</td>
                    </tr>
                    @if (r.AdditionalMedicareWithholding != 0)
                    {
                        <tr>
                            <td>
                                Additional Medicare (0.9%)
                                @ExplainButton(r.Explanation, ExplanationLineKey.AdditionalMedicare)
                            </td>
                            <td class="text-end text-danger">(@r.AdditionalMedicareWithholding.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.StateWithholding != 0)
                    {
                        <tr>
                            <td>
                                State Tax (@r.State)
                                @ExplainButton(r.Explanation, ExplanationLineKey.StateWithholding)
                            </td>
                            <td class="text-end text-danger">(@r.StateWithholding.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.StateDisabilityInsurance != 0)
                    {
                        <tr>
                            <td>
                                @r.StateDisabilityInsuranceLabel
                                @ExplainButton(r.Explanation, ExplanationLineKey.StateDisability)
                            </td>
                            <td class="text-end text-danger">(@r.StateDisabilityInsurance.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.LocalWithholding != 0)
                    {
                        <tr>
                            <td>
                                Local Tax@(string.IsNullOrEmpty(r.LocalityLabel) ? "" : $" ({r.LocalityLabel})")
                                @ExplainButton(r.Explanation, ExplanationLineKey.LocalWithholding)
                            </td>
                            <td class="text-end text-danger">(@r.LocalWithholding.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.LocalHeadTax != 0)
                    {
                        <tr>
                            <td>@r.LocalHeadTaxLabel</td>
                            <td class="text-end text-danger">(@r.LocalHeadTax.ToString("C"))</td>
                        </tr>
                    }
                    @if (r.PostTaxDeductions != 0)
                    {
                        <tr>
                            <td>Post-Tax Deductions</td>
                            <td class="text-end text-danger">(@r.PostTaxDeductions.ToString("C"))</td>
                        </tr>
                    }
                    <tr class="table-secondary">
                        <th>Total Taxes</th>
                        <td class="text-end">(@r.TotalTaxes.ToString("C"))</td>
                    </tr>
                    <tr class="table-primary fw-bold">
                        <th>
                            Net Pay (this period)
                            @ExplainButton(r.Explanation, ExplanationLineKey.NetPay)
                        </th>
                        <td class="text-end">@r.NetPay.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @if (r.LocalBreakdown.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Local Tax Breakdown</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Locality</th>
                            <th class="text-end">Taxable Wages</th>
                            <th class="text-end">Withholding</th>
                            <th class="text-end">Head Tax</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in r.LocalBreakdown)
                        {
                            <tr>
                                <td>
                                    <strong>@line.LocalityName</strong>
                                    @if (!string.IsNullOrEmpty(line.Description))
                                    {
                                        <div class="small text-muted">@line.Description</div>
                                    }
                                </td>
                                <td class="text-end">@line.TaxableWages.ToString("C")</td>
                                <td class="text-end">@line.Withholding.ToString("C")</td>
                                <td class="text-end">@line.HeadTax.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Doughnut chart: visual breakdown of gross pay -->
    <div class="card mb-3">
        <div class="card-header"><strong>Paycheck Breakdown</strong></div>
        <div class="card-body">
            <DoughnutChart Result="r" />
        </div>
    </div>

    <!-- Annualized view (informational only, based on this period × frequency) -->
    <div class="card mb-3">
        <div class="card-header"><strong>Annualized (× @payRate/yr)</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Gross</td>
                        <td class="text-end">@((r.GrossPay * payRate).ToString("C"))</td>
                    </tr>
                    <tr>
                        <td>Total Taxes</td>
                        <td class="text-end text-danger">(@((r.TotalTaxes * payRate).ToString("C")))</td>
                    </tr>
                    <tr class="table-primary fw-bold">
                        <th>Net</th>
                        <td class="text-end">@((r.NetPay * payRate).ToString("C"))</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex gap-2 align-items-center flex-wrap">
        <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("inputs")'>
            ← Edit Inputs
        </button>
        <AuthorizeView>
            <Authorized>
                <input class="form-control" style="max-width: 220px;" placeholder="Paycheck name"
                       @bind="_saveName" />
                <button class="btn btn-success" @onclick="SaveAsync" disabled="@_saving">
                    💾 @(_saving ? "Saving…" : "Save Paycheck")
                </button>
                @if (_saveMessage is not null)
                {
                    <span class="text-success small">@_saveMessage</span>
                }
                <a class="btn btn-link" href="saved">View saved →</a>
            </Authorized>
            <NotAuthorized>
                <a class="btn btn-outline-primary" href="/account/login?returnUrl=/results">
                    Sign in to save
                </a>
                <span class="text-muted small">— accounts let you save calculations across devices.</span>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <ExplanationModal Explanation="_selectedExplanation" OnClose="CloseExplanation" />
}

@code {
    private string _saveName = "";
    private bool _saving;
    private string? _saveMessage;
    private LineExplanation? _selectedExplanation;

    private RenderFragment ExplainButton(PaycheckExplanation explanation, ExplanationLineKey key) => builder =>
    {
        var line = explanation.Get(key);
        if (line is null) return;
        builder.OpenElement(0, "button");
        builder.AddAttribute(1, "type", "button");
        builder.AddAttribute(2, "class", "btn btn-link btn-sm p-0 ms-1 align-baseline");
        builder.AddAttribute(3, "title", $"Show how {line.Title} was calculated");
        builder.AddAttribute(4, "aria-label", $"Show how {line.Title} was calculated");
        builder.AddAttribute(5, "onclick", EventCallback.Factory.Create(this, () => OpenExplanation(line)));
        builder.AddMarkupContent(6, "<span aria-hidden=\"true\">&#9432;</span>");
        builder.CloseElement();
    };

    private void OpenExplanation(LineExplanation line) => _selectedExplanation = line;
    private void CloseExplanation() => _selectedExplanation = null;

    private async Task SaveAsync()
    {
        if (Session.LastResult is null) return;
        _saving = true;
        _saveMessage = null;
        try
        {
            var name = string.IsNullOrWhiteSpace(_saveName)
                ? $"Paycheck {DateTime.Now:g}"
                : _saveName.Trim();
            var paycheck = new SavedPaycheck
            {
                Name   = name,
                Input  = Session.BuildInput(),
                Result = Session.LastResult,
            };
            await Repo.SaveAsync(paycheck);
            _saveMessage = $"Saved as \"{name}\".";
            _saveName = "";
        }
        finally
        {
            _saving = false;
        }
    }

    // Paychecks-per-year multiplier for the annualized preview card.
    private static int PayRate(PayFrequency f) => f switch
    {
        PayFrequency.Weekly      => 52,
        PayFrequency.Biweekly    => 26,
        PayFrequency.Semimonthly => 24,
        PayFrequency.Monthly     => 12,
        PayFrequency.Quarterly   => 4,
        PayFrequency.Semiannual  => 2,
        PayFrequency.Annual      => 1,
        PayFrequency.Daily       => 260,
        _                        => 1
    };
}
