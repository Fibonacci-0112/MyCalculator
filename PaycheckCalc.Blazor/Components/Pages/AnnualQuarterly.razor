@page "/annual/quarterly"
@inject AnnualTaxSessionState Session
@inject Form1040ESCalculator Calculator

<PageTitle>Quarterly Estimates — PaycheckCalc</PageTitle>

<h1>Quarterly Estimates (Form 1040-ES)</h1>
<p class="text-muted">
    Estimates the four 1040-ES installments needed to satisfy the IRS safe
    harbor. Defaults are derived from the latest Annual Results computation;
    you can override projected tax and expected withholding to test scenarios.
</p>

<div class="card mb-3">
    <div class="card-header"><strong>Overrides</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox"
                           id="useProjTax"
                           @bind="UseProjectedTotalTaxOverride" />
                    <label class="form-check-label" for="useProjTax">
                        Override projected total tax
                    </label>
                </div>
                <input type="number" min="0" step="0.01" class="form-control"
                       disabled="@(!UseProjectedTotalTaxOverride)"
                       @bind="ProjectedTotalTaxOverride" />
                <div class="form-text">
                    Default: latest Annual Results <code>TotalTax</code>
                    (@(Session.LastResult?.TotalTax.ToString("C") ?? "$0.00")).
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox"
                           id="useExpWh"
                           @bind="UseExpectedWithholdingOverride" />
                    <label class="form-check-label" for="useExpWh">
                        Override expected withholding
                    </label>
                </div>
                <input type="number" min="0" step="0.01" class="form-control"
                       disabled="@(!UseExpectedWithholdingOverride)"
                       @bind="ExpectedWithholdingOverride" />
                <div class="form-text">
                    Default: sum of W-2 Box 2 + Additional Expected Withholding.
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Prior-Year Safe Harbor</strong></div>
    <div class="card-body">
        <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox"
                   id="usePySh"
                   @bind="Session.UsePriorYearSafeHarbor" />
            <label class="form-check-label" for="usePySh">
                Apply prior-year safe harbor (100% / 110%)
            </label>
        </div>
        @if (Session.UsePriorYearSafeHarbor)
        {
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Prior-year total tax ($)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.PriorYearTotalTax" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Prior-year AGI ($)</label>
                    <input type="number" min="0" step="0.01" class="form-control"
                           @bind="Session.PriorYearAdjustedGrossIncome" />
                    <div class="form-text">Above $150k triggers 110% rule.</div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               id="pyFull"
                               @bind="Session.PriorYearWasFullYear" />
                        <label class="form-check-label" for="pyFull">
                            Prior year was full 12 months
                        </label>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-primary btn-lg" @onclick="Calculate">
        Calculate Installments →
    </button>
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-0 py-2 px-3">@_errorMessage</div>
    }
</div>

@if (_result is not null)
{
    var r = _result;

    <div class="card mb-3">
        <div class="card-header"><strong>Worksheet Summary</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Tax year</td>
                        <td class="text-end">@r.TaxYear</td>
                    </tr>
                    <tr>
                        <td>Current-year projected tax</td>
                        <td class="text-end">@r.CurrentYearProjectedTax.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Prior-year total tax (for safe harbor)</td>
                        <td class="text-end">@r.PriorYearTotalTax.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Expected withholding</td>
                        <td class="text-end">@r.ExpectedWithholding.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Required annual payment</td>
                        <td class="text-end">@r.RequiredAnnualPayment.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Safe-harbor basis</td>
                        <td class="text-end">@EnumDisplay.SafeHarborBasis(r.SafeHarborBasis)</td>
                    </tr>
                    <tr class="@(r.EstimatesRequired ? "table-warning" : "table-success") fw-bold">
                        <th>@(r.EstimatesRequired ? "Total Estimated Payments Due" : "No estimates required")</th>
                        <td class="text-end">@r.TotalEstimatedPayments.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Installments</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Quarter</th>
                        <th>Due Date</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Cumulative</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inst in r.Installments)
                    {
                        <tr>
                            <td><strong>@inst.Period</strong></td>
                            <td>@inst.DueDate.ToString("MMM d, yyyy")</td>
                            <td class="text-end">@inst.Amount.ToString("C")</td>
                            <td class="text-end">@inst.CumulativeAmount.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a class="btn btn-outline-primary" href="annual/what-if">Continue to What-If →</a>
    <a class="btn btn-link" href="annual/results">Jump to Annual Results</a>
</div>

@code {
    private bool UseProjectedTotalTaxOverride;
    private decimal ProjectedTotalTaxOverride;
    private bool UseExpectedWithholdingOverride;
    private decimal ExpectedWithholdingOverride;

    private QuarterlyEstimatesResult? _result;
    private string? _errorMessage;

    private void Calculate()
    {
        _errorMessage = null;
        try
        {
            var projectedTax = UseProjectedTotalTaxOverride
                ? Math.Max(0m, ProjectedTotalTaxOverride)
                : Session.LastResult?.TotalTax ?? 0m;

            var defaultWithholding = Session.LastResult?.FederalWithholdingFromW2s
                ?? Session.W2Jobs.Sum(j => Math.Max(0m, j.FederalWithholdingBox2));
            defaultWithholding += Math.Max(0m, Session.AdditionalExpectedWithholding);

            var expectedWithholding = UseExpectedWithholdingOverride
                ? Math.Max(0m, ExpectedWithholdingOverride)
                : defaultWithholding;

            PriorYearSafeHarborInput? prior = Session.UsePriorYearSafeHarbor
                ? new PriorYearSafeHarborInput
                {
                    PriorYearTotalTax = Math.Max(0m, Session.PriorYearTotalTax),
                    PriorYearAdjustedGrossIncome = Math.Max(0m, Session.PriorYearAdjustedGrossIncome),
                    PriorYearWasFullYear = Session.PriorYearWasFullYear
                }
                : null;

            _result = Calculator.Calculate(
                Session.TaxYear,
                Session.FilingStatus,
                projectedTax,
                expectedWithholding,
                prior);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
