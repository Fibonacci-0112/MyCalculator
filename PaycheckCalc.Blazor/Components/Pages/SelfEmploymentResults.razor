@page "/self-employment-results"
@inject SelfEmploymentSessionState Session
@inject NavigationManager Nav

<PageTitle>SE Results — PaycheckCalc</PageTitle>

<h1>Self-Employment Tax Summary</h1>

@if (Session.LastResult is null)
{
    <div class="alert alert-info">
        No calculation yet. Head to <a href="self-employment">Self-Employment</a>,
        enter your Schedule C details, and click <strong>Calculate</strong>.
    </div>
}
else
{
    var r = Session.LastResult;

    <ul class="nav nav-tabs mb-3" role="tablist">
        @foreach (var tab in _tabs)
        {
            var isActive = _activeTab == tab;
            <li class="nav-item" role="presentation">
                <button type="button"
                        class="nav-link @(isActive ? "active" : "")"
                        @onclick="() => _activeTab = tab">
                    @tab
                </button>
            </li>
        }
    </ul>

    @if (_activeTab == "Tax Breakdown")
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Schedule C — Net Profit</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <tbody>
                        <tr><td>Gross Revenue</td><td class="text-end">@r.GrossRevenue.ToString("C")</td></tr>
                        <tr><td>Cost of Goods Sold</td><td class="text-end text-danger">(@r.CostOfGoodsSold.ToString("C"))</td></tr>
                        <tr><td>Total Expenses</td><td class="text-end text-danger">(@r.TotalExpenses.ToString("C"))</td></tr>
                        <tr class="table-success fw-bold"><th>Net Profit</th><td class="text-end">@r.NetProfit.ToString("C")</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>Self-Employment Tax (Schedule SE)</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <tbody>
                        <tr><td>SE Taxable Earnings (× 0.9235)</td><td class="text-end">@r.SeTaxableEarnings.ToString("C")</td></tr>
                        <tr><td>Social Security Tax (12.4%)</td><td class="text-end text-danger">(@r.SocialSecurityTax.ToString("C"))</td></tr>
                        <tr><td>Medicare Tax (2.9%)</td><td class="text-end text-danger">(@r.MedicareTax.ToString("C"))</td></tr>
                        @if (r.AdditionalMedicareTax != 0)
                        {
                            <tr><td>Additional Medicare (0.9%)</td><td class="text-end text-danger">(@r.AdditionalMedicareTax.ToString("C"))</td></tr>
                        }
                        <tr class="table-secondary fw-bold"><th>Total SE Tax</th><td class="text-end">@r.TotalSeTax.ToString("C")</td></tr>
                        <tr><td>Deductible ½ of SE Tax (above-the-line)</td><td class="text-end">@r.DeductibleHalfOfSeTax.ToString("C")</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>Income Tax</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <tbody>
                        <tr><td>Other Income</td><td class="text-end">@r.OtherIncome.ToString("C")</td></tr>
                        <tr><td>Adjusted Gross Income</td><td class="text-end">@r.AdjustedGrossIncome.ToString("C")</td></tr>
                        <tr><td>Standard / Itemized Deduction</td><td class="text-end text-danger">(@r.StandardDeduction.ToString("C"))</td></tr>
                        @if (r.QbiDeduction != 0)
                        {
                            <tr><td>QBI Deduction (§199A)</td><td class="text-end text-danger">(@r.QbiDeduction.ToString("C"))</td></tr>
                        }
                        <tr class="table-secondary"><th>Taxable Income</th><td class="text-end">@r.TaxableIncome.ToString("C")</td></tr>
                        <tr><td>Federal Income Tax</td><td class="text-end text-danger">(@r.FederalIncomeTax.ToString("C"))</td></tr>
                        @if (r.StateIncomeTax != 0)
                        {
                            <tr><td>State Income Tax (@r.State)</td><td class="text-end text-danger">(@r.StateIncomeTax.ToString("C"))</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>Summary</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <tbody>
                        <tr><td>Total Federal Tax (income + SE)</td><td class="text-end text-danger">(@r.TotalFederalTax.ToString("C"))</td></tr>
                        <tr><td>Total State Tax</td><td class="text-end text-danger">(@r.TotalStateTax.ToString("C"))</td></tr>
                        <tr class="table-primary fw-bold"><th>Total Tax</th><td class="text-end">@r.TotalTax.ToString("C")</td></tr>
                        <tr><td>Effective Tax Rate</td><td class="text-end">@r.EffectiveTaxRate.ToString("0.00")%</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (_activeTab == "Quarterly Estimates")
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Quarterly Estimated Payments (Form 1040-ES)</strong></div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0 align-middle">
                    <tbody>
                        <tr><td>Estimated Quarterly Payment (Total ÷ 4)</td><td class="text-end fw-bold">@r.EstimatedQuarterlyPayment.ToString("C")</td></tr>
                        <tr>
                            <td>
                                @(r.OverUnderPayment >= 0 ? "Overpaid (refund expected)" : "Underpaid (balance due)")
                            </td>
                            <td class="text-end @(r.OverUnderPayment >= 0 ? "text-success" : "text-danger")">
                                @r.OverUnderPayment.ToString("C")
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="alert alert-secondary small">
            Quarterly due dates for 2026: <strong>Apr 15</strong>, <strong>Jun 15</strong>,
            <strong>Sep 15</strong>, <strong>Jan 15, 2027</strong>.
        </div>
    }

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("self-employment")'>
            ← Edit Inputs
        </button>
    </div>
}

@code {
    private static readonly string[] _tabs = { "Tax Breakdown", "Quarterly Estimates" };
    private string _activeTab = "Tax Breakdown";
}
