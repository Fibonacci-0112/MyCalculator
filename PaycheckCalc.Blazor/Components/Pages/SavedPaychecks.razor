@page "/saved"
@attribute [Authorize]
@using PaycheckCalc.Core.Storage
@inject IPaycheckRepository Repo
@inject CalculatorSessionState Session
@inject NavigationManager Nav

<PageTitle>Saved Paychecks — PaycheckCalc</PageTitle>

<h1>Saved Paychecks</h1>

@if (_loading)
{
    <p class="text-muted fst-italic">Loading…</p>
}
else if (_paychecks.Count == 0)
{
    <div class="alert alert-info">
        No saved paychecks yet. Calculate a paycheck on the
        <a href="inputs">Inputs</a> page, then click
        <strong>Save Paycheck</strong> on the Results screen.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>State</th>
                    <th class="text-end">Net Pay</th>
                    <th>Last Updated</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _paychecks)
                {
                    <tr>
                        <td>
                            <strong>@(string.IsNullOrWhiteSpace(p.Name) ? "(Unnamed)" : p.Name)</strong>
                        </td>
                        <td>@p.Input.State</td>
                        <td class="text-end">@p.Result.NetPay.ToString("C")</td>
                        <td>@p.UpdatedAt.LocalDateTime.ToString("g")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    @onclick="() => LoadAsync(p.Id)">
                                Load
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeleteAsync(p.Id)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<SavedPaycheck> _paychecks = new();
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        StateHasChanged();
        var all = await Repo.GetAllAsync();
        _paychecks = all.OrderByDescending(p => p.UpdatedAt).ToList();
        _loading = false;
        StateHasChanged();
    }

    private async Task LoadAsync(Guid id)
    {
        var paycheck = await Repo.GetByIdAsync(id);
        if (paycheck is null) return;
        Session.LoadFromInput(paycheck.Input);
        Session.LastResult = paycheck.Result;
        Nav.NavigateTo("inputs");
    }

    private async Task DeleteAsync(Guid id)
    {
        await Repo.DeleteAsync(id);
        await ReloadAsync();
    }
}
