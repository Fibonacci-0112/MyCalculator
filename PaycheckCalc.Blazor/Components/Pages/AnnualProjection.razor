@page "/annual/projection"
@inject CalculatorSessionState PaycheckSession
@inject PayCalculator PayCalculator
@inject AnnualProjectionCalculator Projector
@inject NavigationManager Nav

<PageTitle>Annual Projection — PaycheckCalc</PageTitle>

<h1>Annual Projection</h1>
<p class="text-muted">
    Annualizes your latest paycheck across the year, projects your year-to-date
    totals, and estimates how much you're over- or under-withheld.
</p>

@if (PaycheckSession.LastResult is null)
{
    <div class="alert alert-info">
        No paycheck yet. Head to <a href="inputs">Paycheck Inputs</a>, enter
        your details, and click <strong>Calculate</strong>. Then come back here
        for your annualized view.
    </div>
}
else if (_projection is null)
{
    <p class="text-muted fst-italic">Calculating…</p>
}
else
{
    var p = _projection;

    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-outline-secondary" @onclick="Recalculate">
            🔄 Refresh from latest paycheck
        </button>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Pay Period</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Pay frequency</td>
                        <td class="text-end">@p.PayPeriodsPerYear paychecks / year</td>
                    </tr>
                    <tr>
                        <td>This paycheck</td>
                        <td class="text-end">#@p.CurrentPaycheckNumber of @p.PayPeriodsPerYear</td>
                    </tr>
                    <tr>
                        <td>Remaining paychecks</td>
                        <td class="text-end">@p.RemainingPaychecks</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Annualized (× @p.PayPeriodsPerYear paychecks)</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr class="table-success">
                        <th>Gross Pay</th>
                        <td class="text-end fw-bold">@p.AnnualizedGrossPay.ToString("C")</td>
                    </tr>
                    @if (p.AnnualizedPreTaxDeductions != 0)
                    {
                        <tr>
                            <td>Pre-Tax Deductions</td>
                            <td class="text-end text-danger">(@p.AnnualizedPreTaxDeductions.ToString("C"))</td>
                        </tr>
                    }
                    <tr>
                        <td>Federal Withholding</td>
                        <td class="text-end text-danger">(@p.AnnualizedFederalWithholding.ToString("C"))</td>
                    </tr>
                    <tr>
                        <td>State Withholding</td>
                        <td class="text-end text-danger">(@p.AnnualizedStateWithholding.ToString("C"))</td>
                    </tr>
                    <tr>
                        <td>FICA</td>
                        <td class="text-end text-danger">(@p.AnnualizedFica.ToString("C"))</td>
                    </tr>
                    @if (p.AnnualizedPostTaxDeductions != 0)
                    {
                        <tr>
                            <td>Post-Tax Deductions</td>
                            <td class="text-end text-danger">(@p.AnnualizedPostTaxDeductions.ToString("C"))</td>
                        </tr>
                    }
                    <tr class="table-primary fw-bold">
                        <th>Annualized Net Pay</th>
                        <td class="text-end">@p.AnnualizedNetPay.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Projected YTD (× @p.CurrentPaycheckNumber paychecks so far)</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Gross to date</td>
                        <td class="text-end">@p.ProjectedYtdGrossPay.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Federal withheld</td>
                        <td class="text-end">@p.ProjectedYtdFederalWithholding.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>State withheld</td>
                        <td class="text-end">@p.ProjectedYtdStateWithholding.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>FICA withheld</td>
                        <td class="text-end">@p.ProjectedYtdFica.ToString("C")</td>
                    </tr>
                    <tr class="table-primary fw-bold">
                        <th>Net to date</th>
                        <td class="text-end">@p.ProjectedYtdNetPay.ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Withholding Position</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <tbody>
                    <tr>
                        <td>Estimated annual federal liability</td>
                        <td class="text-end">@p.EstimatedAnnualFederalLiability.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Estimated annual FICA liability</td>
                        <td class="text-end">@p.EstimatedAnnualFicaLiability.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Annualized total withholding</td>
                        <td class="text-end">@p.AnnualizedTotalWithholding.ToString("C")</td>
                    </tr>
                    <tr>
                        <td>Estimated total liability</td>
                        <td class="text-end">@p.EstimatedTotalLiability.ToString("C")</td>
                    </tr>
                    <tr class="@(p.OverUnderWithholding >= 0 ? "table-success" : "table-danger") fw-bold">
                        <th>@(p.OverUnderWithholding >= 0 ? "Estimated Refund" : "Estimated Balance Due")</th>
                        <td class="text-end">@Math.Abs(p.OverUnderWithholding).ToString("C")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" href="annual/jobs">Continue to Jobs &amp; YTD →</a>
        <a class="btn btn-link" href="annual/results">Jump to Annual Results</a>
    </div>
}

@code {
    // Fully qualified: this file's generated class is also named AnnualProjection.
    private PaycheckCalc.Core.Models.AnnualProjection? _projection;

    protected override void OnInitialized() => Recalculate();

    private void Recalculate()
    {
        if (PaycheckSession.LastResult is null)
        {
            _projection = null;
            return;
        }
        // Re-run the engine so the projection reflects any updates to inputs
        // since the last Calculate, matching the Dashboard's behavior.
        var input = PaycheckSession.BuildInput();
        var fresh = PayCalculator.Calculate(input);
        PaycheckSession.LastResult = fresh;
        _projection = Projector.Calculate(input, fresh);
    }
}
