@page "/annual/what-if"
@inject AnnualTaxSessionState Session
@inject Form1040Calculator Calculator
@inject StateCalculatorRegistry StateRegistry

<PageTitle>What-If — PaycheckCalc</PageTitle>

<h1>What-If Comparison</h1>
<p class="text-muted">
    Snapshot your current scenario as the baseline, then tweak a few
    high-signal levers to see the side-by-side impact on AGI, taxable
    income, total tax, and refund/owe.
</p>

<div class="card mb-3">
    <div class="card-header"><strong>Step 1 — Capture Baseline</strong></div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            Captures the current Annual Tax inputs as the baseline. Re-running
            this overwrites the existing baseline.
        </p>
        <button class="btn btn-primary" @onclick="CaptureBaseline">
            📸 Capture Baseline
        </button>
        @if (Session.WhatIfBaselineResult is not null)
        {
            <span class="text-success small ms-3">
                Baseline captured · Total Tax @Session.WhatIfBaselineResult.TotalTax.ToString("C") · Refund/Owe @Session.WhatIfBaselineResult.RefundOrOwe.ToString("C")
            </span>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Step 2 — Variant Deltas</strong></div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Variant filing status</label>
                <select class="form-select" @bind="VariantFilingStatus">
                    <option value="@FederalFilingStatus.SingleOrMarriedSeparately">
                        @EnumDisplay.FederalFilingStatus("SingleOrMarriedSeparately")
                    </option>
                    <option value="@FederalFilingStatus.MarriedFilingJointly">
                        @EnumDisplay.FederalFilingStatus("MarriedFilingJointly")
                    </option>
                    <option value="@FederalFilingStatus.HeadOfHousehold">
                        @EnumDisplay.FederalFilingStatus("HeadOfHousehold")
                    </option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Variant residence state</label>
                <select class="form-select" @bind="VariantState">
                    @foreach (var s in StateRegistry.SupportedStates.OrderBy(x => x.ToString()))
                    {
                        <option value="@s">@EnumDisplay.UsStateName(s.ToString())</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Additional pre-tax 401(k) ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="AdditionalPreTax401k" />
                <div class="form-text">
                    Reduces first W-2's Box 1 and Box 16; FICA unchanged.
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label">Additional expected withholding ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="AdditionalExpectedWithholding" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Δ qualifying children</label>
                <input type="number" step="1" class="form-control"
                       @bind="QualifyingChildrenDelta" />
                <div class="form-text">Can be negative.</div>
            </div>
        </div>
    </div>
</div>

<div class="mb-3">
    <button class="btn btn-primary btn-lg" @onclick="RunVariant"
            disabled="@(Session.WhatIfBaselineProfile is null)">
        Run Variant →
    </button>
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-2 mb-0 py-2 px-3">@_errorMessage</div>
    }
</div>

@if (Session.WhatIfBaselineResult is not null && _variantResult is not null)
{
    var baseR = Session.WhatIfBaselineResult;
    var varR = _variantResult;

    <div class="card mb-3">
        <div class="card-header"><strong>Comparison</strong></div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Metric</th>
                        <th class="text-end">Baseline</th>
                        <th class="text-end">What-If</th>
                        <th class="text-end">Δ</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var rows = new[]
                        {
                            ("Total Income",   baseR.TotalIncome,         varR.TotalIncome,         true),
                            ("AGI",            baseR.AdjustedGrossIncome, varR.AdjustedGrossIncome, true),
                            ("Taxable Income", baseR.TaxableIncome,       varR.TaxableIncome,       true),
                            ("Total Tax",      baseR.TotalTax,            varR.TotalTax,            false),
                            ("Total Payments", baseR.TotalPayments,       varR.TotalPayments,       true),
                            ("Refund / (Owe)", baseR.RefundOrOwe,         varR.RefundOrOwe,         true),
                            ("State Tax",      baseR.StateTax?.StateIncomeTax ?? 0m,
                                               varR.StateTax?.StateIncomeTax  ?? 0m, false)
                        };
                    }
                    @foreach (var (label, b, v, higherIsBetter) in rows)
                    {
                        var delta = v - b;
                        var improved = higherIsBetter ? delta > 0m : delta < 0m;
                        var deltaClass = delta == 0m ? "" : (improved ? "text-success" : "text-danger");
                        <tr>
                            <td>@label</td>
                            <td class="text-end">@b.ToString("C")</td>
                            <td class="text-end">@v.ToString("C")</td>
                            <td class="text-end @deltaClass">
                                @(delta >= 0m ? "+" : "")@delta.ToString("C")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private FederalFilingStatus VariantFilingStatus = FederalFilingStatus.SingleOrMarriedSeparately;
    private UsState VariantState = UsState.TX;
    private decimal AdditionalPreTax401k;
    private decimal AdditionalExpectedWithholding;
    private int QualifyingChildrenDelta;

    private AnnualTaxResult? _variantResult;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        // Seed variant pickers from the session so deltas start at parity.
        VariantFilingStatus = Session.FilingStatus;
        VariantState = Session.ResidenceState;
    }

    private void CaptureBaseline()
    {
        _errorMessage = null;
        try
        {
            var profile = Session.BuildProfile();
            Session.WhatIfBaselineProfile = profile;
            Session.WhatIfBaselineResult = Calculator.Calculate(profile);
            VariantFilingStatus = profile.FilingStatus;
            VariantState = profile.ResidenceState;
            _variantResult = null;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void RunVariant()
    {
        _errorMessage = null;
        if (Session.WhatIfBaselineProfile is null) return;
        try
        {
            var variant = CloneWithVariant(
                Session.WhatIfBaselineProfile,
                VariantFilingStatus,
                VariantState,
                AdditionalPreTax401k,
                AdditionalExpectedWithholding,
                QualifyingChildrenDelta);
            _variantResult = Calculator.Calculate(variant);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    /// <summary>
    /// Apply variant deltas to a clone of the baseline profile. Mirrors
    /// the MAUI <c>WhatIfViewModel.CloneWithVariant</c> rules: extra pre-tax
    /// 401(k) reduces the first W-2's Box 1 and Box 16 (keeping FICA wages
    /// unchanged), and the qualifying-children delta flows into both the
    /// W-4 alignment count and the structured CTC count when present.
    /// </summary>
    private static TaxYearProfile CloneWithVariant(
        TaxYearProfile baseline,
        FederalFilingStatus newStatus,
        UsState newState,
        decimal addPreTax401k,
        decimal addWithholding,
        int qcDelta)
    {
        var adjustedJobs = baseline.W2Jobs
            .Select((j, i) => i == 0
                ? new W2JobInput
                {
                    Name = j.Name,
                    Holder = j.Holder,
                    WagesBox1 = Math.Max(0m, j.WagesBox1 - addPreTax401k),
                    FederalWithholdingBox2 = j.FederalWithholdingBox2,
                    SocialSecurityWagesBox3 = j.SocialSecurityWagesBox3,
                    SocialSecurityTaxBox4 = j.SocialSecurityTaxBox4,
                    MedicareWagesBox5 = j.MedicareWagesBox5,
                    MedicareTaxBox6 = j.MedicareTaxBox6,
                    StateWagesBox16 = Math.Max(0m,
                        (j.StateWagesBox16 > 0m ? j.StateWagesBox16 : j.WagesBox1) - addPreTax401k),
                    StateWithholdingBox17 = j.StateWithholdingBox17,
                    SourceState = j.SourceState
                }
                : j)
            .ToList();

        int newQc = Math.Max(0, baseline.QualifyingChildren + qcDelta);
        var newCtc = baseline.Credits.ChildTaxCreditInput is { } oldCtc
            ? new ChildTaxCreditInput
            {
                QualifyingChildren = Math.Max(0, oldCtc.QualifyingChildren + qcDelta),
                OtherDependents = oldCtc.OtherDependents,
                EarnedIncome = oldCtc.EarnedIncome
            }
            : baseline.Credits.ChildTaxCreditInput;

        return new TaxYearProfile
        {
            TaxYear = baseline.TaxYear,
            FilingStatus = newStatus,
            QualifyingChildren = newQc,
            ResidenceState = newState,
            W2Jobs = adjustedJobs,
            SelfEmployment = baseline.SelfEmployment,
            OtherIncome = baseline.OtherIncome,
            Adjustments = baseline.Adjustments,
            ItemizedDeductionsOverStandard = baseline.ItemizedDeductionsOverStandard,
            Credits = new CreditsInput
            {
                NonrefundableCredits = baseline.Credits.NonrefundableCredits,
                RefundableCredits = baseline.Credits.RefundableCredits,
                PrecomputedChildTaxCredit = baseline.Credits.PrecomputedChildTaxCredit,
                ChildTaxCreditInput = newCtc,
                EducationCredits = baseline.Credits.EducationCredits,
                SaversCredit = baseline.Credits.SaversCredit
            },
            OtherTaxes = baseline.OtherTaxes,
            EstimatedTaxPayments = baseline.EstimatedTaxPayments,
            AdditionalExpectedWithholding = Math.Max(0m,
                baseline.AdditionalExpectedWithholding + addWithholding),
            PriorYearSafeHarbor = baseline.PriorYearSafeHarbor,
            StateInputValues = baseline.StateInputValues
        };
    }
}
