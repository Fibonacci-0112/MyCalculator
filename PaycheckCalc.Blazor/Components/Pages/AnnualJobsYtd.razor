@page "/annual/jobs"
@inject AnnualTaxSessionState Session
@inject CalculatorSessionState PaycheckSession

<PageTitle>Jobs &amp; YTD — PaycheckCalc</PageTitle>

<h1>W-2 Jobs &amp; YTD</h1>
<p class="text-muted">
    Add one row per W-2 you expect to receive this year. Aggregate annual
    figures here — boxes feed the Form 1040 engine directly.
</p>

<div class="card mb-3">
    <div class="card-body">
        @if (Session.W2Jobs.Count == 0)
        {
            <p class="text-muted fst-italic mb-3">No W-2 jobs added.</p>
        }
        @for (int i = 0; i < Session.W2Jobs.Count; i++)
        {
            var idx = i;
            var j = Session.W2Jobs[idx];
            <div class="border rounded p-3 mb-3 bg-light">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="flex-grow-1 me-3">
                        <label class="form-label">Job Name</label>
                        <input class="form-control" placeholder="e.g. Day job"
                               @bind="j.Name" />
                    </div>
                    <div class="form-check form-switch mt-3 me-3">
                        <input class="form-check-input" type="checkbox"
                               id="@($"spouse{idx}")"
                               @bind="j.IsSpouse" />
                        <label class="form-check-label" for="@($"spouse{idx}")">
                            Spouse's job
                        </label>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger mt-3"
                            @onclick="() => RemoveJob(idx)">
                        ✕ Remove
                    </button>
                </div>
                <div class="row g-2">
                    <div class="col-md-3">
                        <label class="form-label small">Box 1: Wages ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.WagesBox1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 2: Fed WH ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.FederalWithholdingBox2" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 3: SS Wages ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.SocialSecurityWagesBox3" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 4: SS Tax ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.SocialSecurityTaxBox4" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 5: Medicare Wages ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.MedicareWagesBox5" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 6: Medicare Tax ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.MedicareTaxBox6" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 16: State Wages ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.StateWagesBox16" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Box 17: State WH ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="j.StateWithholdingBox17" />
                    </div>
                </div>
            </div>
        }
        <div class="d-flex gap-2 flex-wrap">
            <button type="button" class="btn btn-outline-primary"
                    @onclick="AddJob">
                + Add W-2 Job
            </button>
            @if (PaycheckSession.LastResult is not null)
            {
                <button type="button" class="btn btn-outline-secondary"
                        @onclick="ImportFromPaycheck">
                    📥 Import from current paycheck
                </button>
            }
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header"><strong>Summary — @Session.W2Jobs.Count @(Session.W2Jobs.Count == 1 ? "job" : "jobs")</strong></div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0 align-middle">
            <tbody>
                <tr>
                    <td>Total Box 1 wages</td>
                    <td class="text-end">@TotalBox1Wages.ToString("C")</td>
                </tr>
                <tr>
                    <td>Total federal withholding</td>
                    <td class="text-end">@TotalFederalWithholding.ToString("C")</td>
                </tr>
                <tr>
                    <td>Total SS wages / tax</td>
                    <td class="text-end">@TotalSsWages.ToString("C") / @TotalSsTax.ToString("C")</td>
                </tr>
                <tr>
                    <td>Total Medicare wages / tax</td>
                    <td class="text-end">@TotalMedWages.ToString("C") / @TotalMedTax.ToString("C")</td>
                </tr>
                <tr>
                    <td>Total state wages / withholding</td>
                    <td class="text-end">@TotalStateWages.ToString("C") / @TotalStateWh.ToString("C")</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex gap-2">
    <a class="btn btn-outline-primary" href="annual/other-income">Continue to Other Income →</a>
</div>

@code {
    private decimal TotalBox1Wages => Session.W2Jobs.Sum(j => Math.Max(0m, j.WagesBox1));
    private decimal TotalFederalWithholding => Session.W2Jobs.Sum(j => Math.Max(0m, j.FederalWithholdingBox2));
    private decimal TotalSsWages => Session.W2Jobs.Sum(j => Math.Max(0m, j.SocialSecurityWagesBox3));
    private decimal TotalSsTax => Session.W2Jobs.Sum(j => Math.Max(0m, j.SocialSecurityTaxBox4));
    private decimal TotalMedWages => Session.W2Jobs.Sum(j => Math.Max(0m, j.MedicareWagesBox5));
    private decimal TotalMedTax => Session.W2Jobs.Sum(j => Math.Max(0m, j.MedicareTaxBox6));
    private decimal TotalStateWages => Session.W2Jobs.Sum(j => Math.Max(0m, j.StateWagesBox16));
    private decimal TotalStateWh => Session.W2Jobs.Sum(j => Math.Max(0m, j.StateWithholdingBox17));

    private void AddJob()
    {
        var n = Session.W2Jobs.Count + 1;
        Session.W2Jobs.Add(new W2JobEntry { Name = $"Employer {n}" });
    }

    private void RemoveJob(int index)
    {
        if (index >= 0 && index < Session.W2Jobs.Count)
            Session.W2Jobs.RemoveAt(index);
    }

    /// <summary>
    /// Seed a new W-2 row from the current paycheck, annualized by the
    /// paycheck frequency. Pre-tax deductions on the paycheck reduce Box 1
    /// (federal taxable) and Box 16 (state taxable) but keep FICA wages
    /// (Box 3/5) at gross — same convention as a real W-2.
    /// </summary>
    private void ImportFromPaycheck()
    {
        var input = PaycheckSession.BuildInput();
        var result = PaycheckSession.LastResult;
        if (result is null) return;

        int periods = PayPeriodsPerYear(input.Frequency);
        var n = Session.W2Jobs.Count + 1;
        Session.W2Jobs.Add(new W2JobEntry
        {
            Name = $"Current paycheck (× {periods})",
            WagesBox1 = result.FederalTaxableIncome * periods,
            FederalWithholdingBox2 = result.FederalWithholding * periods,
            SocialSecurityWagesBox3 = result.FicaTaxableWages * periods,
            SocialSecurityTaxBox4 = result.SocialSecurityWithholding * periods,
            MedicareWagesBox5 = result.FicaTaxableWages * periods,
            MedicareTaxBox6 = (result.MedicareWithholding + result.AdditionalMedicareWithholding) * periods,
            StateWagesBox16 = result.StateTaxableWages * periods,
            StateWithholdingBox17 = result.StateWithholding * periods
        });
        // Mirror residence state from the paycheck so the annual state-tax
        // projection picks the same calculator.
        Session.ResidenceState = input.State;
    }

    private static int PayPeriodsPerYear(PayFrequency f) => f switch
    {
        PayFrequency.Weekly      => 52,
        PayFrequency.Biweekly    => 26,
        PayFrequency.Semimonthly => 24,
        PayFrequency.Monthly     => 12,
        PayFrequency.Quarterly   => 4,
        PayFrequency.Semiannual  => 2,
        PayFrequency.Annual      => 1,
        PayFrequency.Daily       => 260,
        _                        => 1
    };
}
