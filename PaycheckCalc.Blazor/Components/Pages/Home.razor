@page "/"
@using PaycheckCalc.Core.Models
@using PaycheckCalc.Core.Pay
@using PaycheckCalc.Core.Storage
@inject IPaycheckRepository Repo
@inject CalculatorSessionState Session
@inject PayCalculator Pay
@inject AnnualProjectionCalculator Projector
@inject YtdSummaryCalculator Ytd
@inject NavigationManager Nav

<PageTitle>PaycheckCalc — Dashboard</PageTitle>

<div class="dashboard">
    <div class="dashboard-header">
        <h1>💰 Dashboard</h1>
        <p class="text-muted mb-0">
            Quick actions, your most recent paycheck, and year-to-date progress
            at a glance.
        </p>
    </div>

    @* ── Quick Actions ──────────────────────────────────────── *@
    <section class="dashboard-section">
        <h2 class="section-title">Quick Actions</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <a href="inputs" class="quick-action card h-100 text-decoration-none">
                    <div class="card-body">
                        <div class="quick-icon">📝</div>
                        <div class="quick-title">New Paycheck</div>
                        <div class="quick-desc text-muted">
                            Enter hours, W-4, and deductions to calculate take-home pay.
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="saved" class="quick-action card h-100 text-decoration-none">
                    <div class="card-body">
                        <div class="quick-icon">💾</div>
                        <div class="quick-title">Saved Paychecks</div>
                        <div class="quick-desc text-muted">
                            Reload, rename, or delete the paychecks you've saved.
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="self-employment" class="quick-action card h-100 text-decoration-none">
                    <div class="card-body">
                        <div class="quick-icon">🧾</div>
                        <div class="quick-title">Self-Employment</div>
                        <div class="quick-desc text-muted">
                            Schedule C, SE tax, QBI, and quarterly estimates.
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    @if (_loading)
    {
        <p class="text-muted fst-italic mt-4">Loading your paycheck history…</p>
    }
    else if (_latest is null)
    {
        @* ── Empty state ─────────────────────────────────────── *@
        <section class="dashboard-section">
            <div class="card empty-state">
                <div class="card-body text-center">
                    <div class="empty-icon">👋</div>
                    <h3 class="card-title">Welcome to PaycheckCalc</h3>
                    <p class="text-muted">
                        You haven't saved a paycheck yet. Start one now and
                        we'll begin tracking your YTD progress automatically.
                    </p>
                    <a href="inputs" class="btn btn-primary btn-lg">
                        Start your first paycheck →
                    </a>
                </div>
            </div>
        </section>
    }
    else
    {
        @* ── Previous Paycheck ──────────────────────────────── *@
        <section class="dashboard-section">
            <h2 class="section-title">Previous Paycheck</h2>
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                        <div>
                            <h3 class="paycheck-name mb-1">
                                @(string.IsNullOrWhiteSpace(_latest.Name) ? "(Unnamed paycheck)" : _latest.Name)
                            </h3>
                            <div class="text-muted small">
                                <span class="badge bg-secondary">@_latest.Input.State</span>
                                <span class="ms-2">Saved @_latest.UpdatedAt.LocalDateTime.ToString("g")</span>
                            </div>
                        </div>
                        <button class="btn btn-outline-primary" @onclick="LoadLatestAsync">
                            Load into calculator →
                        </button>
                    </div>

                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div class="metric">
                                <div class="metric-label">Gross</div>
                                <div class="metric-value">@_latest.Result.GrossPay.ToString("C")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="metric">
                                <div class="metric-label">Federal</div>
                                <div class="metric-value text-danger">
                                    @($"-{_latest.Result.FederalWithholding:C}")
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="metric">
                                <div class="metric-label">State</div>
                                <div class="metric-value text-danger">
                                    @($"-{_latest.Result.StateWithholding:C}")
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="metric">
                                <div class="metric-label">FICA</div>
                                <div class="metric-value text-danger">
                                    @($"-{(_latest.Result.SocialSecurityWithholding + _latest.Result.MedicareWithholding + _latest.Result.AdditionalMedicareWithholding):C}")
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="net-row">
                                <span>Net Pay</span>
                                <span class="net-amount">@_latest.Result.NetPay.ToString("C")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        @* ── Year-to-Date Trackers ──────────────────────────── *@
        <section class="dashboard-section">
            <h2 class="section-title">Year-to-Date — @_ytd!.Year</h2>
            <div class="row g-3">
                <div class="col-lg-6">
                    <div class="card h-100 ytd-card">
                        <div class="card-body">
                            <div class="ytd-header">
                                <div class="ytd-title">YTD Actual</div>
                                <div class="ytd-sub text-muted">
                                    From @_ytd.PaycheckCount saved
                                    @(_ytd.PaycheckCount == 1 ? "paycheck" : "paychecks")
                                </div>
                            </div>
                            <dl class="ytd-list">
                                <div>
                                    <dt>Gross earned</dt>
                                    <dd>@_ytd.TotalGross.ToString("C")</dd>
                                </div>
                                <div>
                                    <dt>Taxes withheld</dt>
                                    <dd class="text-danger">@_ytd.TotalTaxes.ToString("C")</dd>
                                </div>
                                <div class="ytd-net">
                                    <dt>Net take-home</dt>
                                    <dd>@_ytd.TotalNet.ToString("C")</dd>
                                </div>
                            </dl>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card h-100 ytd-card">
                        <div class="card-body">
                            <div class="ytd-header">
                                <div class="ytd-title">Projected Annual</div>
                                <div class="ytd-sub text-muted">
                                    Based on your most recent paycheck —
                                    @_projection!.RemainingPaychecks remaining
                                    of @_projection.PayPeriodsPerYear
                                </div>
                            </div>
                            <dl class="ytd-list">
                                <div>
                                    <dt>Annualized gross</dt>
                                    <dd>@_projection.AnnualizedGrossPay.ToString("C")</dd>
                                </div>
                                <div>
                                    <dt>Annualized net</dt>
                                    <dd>@_projection.AnnualizedNetPay.ToString("C")</dd>
                                </div>
                                <div class="ytd-net">
                                    <dt>@(_projection.OverUnderWithholding >= 0 ? "Estimated refund" : "Estimated amount owed")</dt>
                                    <dd class="@(_projection.OverUnderWithholding >= 0 ? "text-success" : "text-danger")">
                                        @Math.Abs(_projection.OverUnderWithholding).ToString("C")
                                    </dd>
                                </div>
                            </dl>
                            <div class="progress mt-3" style="height: 8px;" role="progressbar"
                                 aria-label="Year progress"
                                 aria-valuenow="@_projection.CurrentPaycheckNumber"
                                 aria-valuemin="0"
                                 aria-valuemax="@_projection.PayPeriodsPerYear">
                                <div class="progress-bar"
                                     style="width: @(YearProgressPercent.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))%;">
                                </div>
                            </div>
                            <div class="text-muted small mt-1">
                                Paycheck @_projection.CurrentPaycheckNumber of @_projection.PayPeriodsPerYear
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
</div>

@code {
    private bool _loading = true;
    private SavedPaycheck? _latest;
    private YtdSummary? _ytd;
    private AnnualProjection? _projection;

    private double YearProgressPercent =>
        _projection is null || _projection.PayPeriodsPerYear == 0
            ? 0d
            : (double)_projection.CurrentPaycheckNumber / _projection.PayPeriodsPerYear * 100d;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        StateHasChanged();

        var all = await Repo.GetAllAsync();
        _latest = all.OrderByDescending(p => p.UpdatedAt).FirstOrDefault();
        _ytd = Ytd.Calculate(all, DateTime.Now.Year);

        if (_latest is not null)
        {
            // Re-run the engine so the projection picks up any tax-table
            // updates since the paycheck was saved.
            var fresh = Pay.Calculate(_latest.Input);
            _projection = Projector.Calculate(_latest.Input, fresh);
        }
        else
        {
            _projection = null;
        }

        _loading = false;
        StateHasChanged();
    }

    private void LoadLatestAsync()
    {
        if (_latest is null) return;
        Session.LoadFromInput(_latest.Input);
        Session.LastResult = _latest.Result;
        Nav.NavigateTo("inputs");
    }
}
