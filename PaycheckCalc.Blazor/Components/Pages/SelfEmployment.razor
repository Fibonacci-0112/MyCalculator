@page "/self-employment"
@using PaycheckCalc.Core.Tax.SelfEmployment
@inject StateCalculatorRegistry StateRegistry
@inject SelfEmploymentCalculator SeCalculator
@inject SelfEmploymentSessionState Session
@inject NavigationManager Nav

<PageTitle>Self-Employment — PaycheckCalc</PageTitle>

<h1>Self-Employment Inputs</h1>

<ul class="nav nav-tabs mb-3" role="tablist">
    @foreach (var tab in _tabs)
    {
        var isActive = _activeTab == tab;
        <li class="nav-item" role="presentation">
            <button type="button"
                    class="nav-link @(isActive ? "active" : "")"
                    @onclick="() => _activeTab = tab">
                @tab
            </button>
        </li>
    }
</ul>

<div class="tab-content">

    @if (_activeTab == "Income")
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Schedule C — Business Income</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Gross Revenue ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.GrossRevenue" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cost of Goods Sold ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.CostOfGoodsSold" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Total Business Expenses ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.TotalBusinessExpenses" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Other Income ($, non-SE)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.OtherIncome" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Estimated Tax Payments Already Made ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.EstimatedTaxPayments" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>W-2 FICA Coordination (optional)</strong></div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    If you also have W-2 wages, enter them so SE Social Security tax
                    respects the shared $184,500 wage base and Additional Medicare
                    threshold ($200,000).
                </p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">W-2 Social Security Wages (Box 3, $)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.W2SocialSecurityWages" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">W-2 Medicare Wages (Box 5, $)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.W2MedicareWages" />
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_activeTab == "Tax Info")
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Filing Status &amp; State</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Federal Filing Status</label>
                        <select class="form-select" @bind="Session.FilingStatus">
                            <option value="@FederalFilingStatus.SingleOrMarriedSeparately">Single / Married Filing Separately</option>
                            <option value="@FederalFilingStatus.MarriedFilingJointly">Married Filing Jointly</option>
                            <option value="@FederalFilingStatus.HeadOfHousehold">Head of Household</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">State</label>
                        <select class="form-select" value="@Session.State"
                                @onchange="OnStateChanged">
                            @foreach (var s in StateRegistry.SupportedStates.OrderBy(x => x.ToString()))
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                </div>

                @if (_stateSchema is null || _stateSchema.Count == 0)
                {
                    <p class="text-muted fst-italic mt-3 mb-0">
                        No extra inputs required for this state.
                    </p>
                }
                else
                {
                    <div class="row g-3 mt-2">
                        @foreach (var field in _stateSchema)
                        {
                            <div class="col-md-6">
                                <label class="form-label">@field.Label</label>
                                @switch (field.FieldType)
                                {
                                    case StateFieldType.Picker:
                                        <select class="form-select"
                                                value="@(GetStateValue(field)?.ToString() ?? "")"
                                                @onchange="e => SetStateValue(field, e.Value?.ToString())">
                                            @if (field.Options is not null)
                                            {
                                                @foreach (var opt in field.Options)
                                                {
                                                    <option value="@opt">@opt</option>
                                                }
                                            }
                                        </select>
                                        break;
                                    case StateFieldType.Toggle:
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@Convert.ToBoolean(GetStateValue(field) ?? false)"
                                                   @onchange="e => SetStateValue(field, e.Value)" />
                                        </div>
                                        break;
                                    case StateFieldType.Integer:
                                        <input type="number" step="1" class="form-control"
                                               value="@(GetStateValue(field)?.ToString() ?? "0")"
                                               @onchange="e => SetStateValue(field, e.Value?.ToString())" />
                                        break;
                                    case StateFieldType.Decimal:
                                        <input type="number" step="0.01" class="form-control"
                                               value="@(GetStateValue(field)?.ToString() ?? "0")"
                                               @onchange="e => SetStateValue(field, e.Value?.ToString())" />
                                        break;
                                    default:
                                        <input type="text" class="form-control"
                                               value="@(GetStateValue(field)?.ToString() ?? "")"
                                               @onchange="e => SetStateValue(field, e.Value?.ToString())" />
                                        break;
                                }
                            </div>
                        }
                    </div>

                    @if (_stateValidationErrors.Count > 0)
                    {
                        <div class="alert alert-danger mt-3 mb-0">
                            <ul class="mb-0">
                                @foreach (var err in _stateValidationErrors)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><strong>Deductions</strong></div>
            <div class="card-body">
                <label class="form-label">Itemized Deductions Over Standard ($)</label>
                <input type="number" min="0" step="0.01" class="form-control"
                       @bind="Session.ItemizedDeductionsOverStandard" />
                <div class="form-text">
                    Zero means take the standard deduction. Otherwise enter the
                    amount by which your itemized deductions exceed the standard.
                </div>
            </div>
        </div>
    }

    @if (_activeTab == "QBI / 8995")
    {
        <div class="card mb-3">
            <div class="card-header"><strong>Qualified Business Income (Form 8995 / 8995-A)</strong></div>
            <div class="card-body">
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="seSstb"
                           @bind="Session.IsSpecifiedServiceBusiness" />
                    <label class="form-check-label" for="seSstb">
                        Specified Service Trade or Business (SSTB) — phases out above income threshold
                    </label>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Qualified Business W-2 Wages Paid ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.QualifiedBusinessW2Wages" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Qualified Property UBIA ($)</label>
                        <input type="number" min="0" step="0.01" class="form-control"
                               @bind="Session.QualifiedPropertyUbia" />
                    </div>
                </div>
            </div>
        </div>
    }

</div>

<div class="d-flex gap-2 mt-3">
    <button type="button" class="btn btn-primary btn-lg" @onclick="Calculate">
        Calculate →
    </button>
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-0 py-2 px-3">@_errorMessage</div>
    }
</div>

@code {
    private static readonly string[] _tabs = { "Income", "Tax Info", "QBI / 8995" };

    private string _activeTab = "Income";
    private IReadOnlyList<StateFieldDefinition>? _stateSchema;
    private List<string> _stateValidationErrors = new();
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        RefreshStateSchema();
    }

    private void OnStateChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<UsState>(e.Value?.ToString(), out var state))
        {
            Session.State = state;
            Session.StateInputValues = new StateInputValues();
            RefreshStateSchema();
        }
    }

    private void RefreshStateSchema()
    {
        var calc = StateRegistry.IsSupported(Session.State)
            ? StateRegistry.GetCalculator(Session.State)
            : null;
        _stateSchema = calc?.GetInputSchema() ?? Array.Empty<StateFieldDefinition>();

        foreach (var field in _stateSchema)
        {
            if (!Session.StateInputValues.ContainsKey(field.Key))
                Session.StateInputValues[field.Key] = field.DefaultValue;
        }

        _stateValidationErrors.Clear();
    }

    private object? GetStateValue(StateFieldDefinition field) =>
        Session.StateInputValues.TryGetValue(field.Key, out var v) ? v : field.DefaultValue;

    private void SetStateValue(StateFieldDefinition field, object? raw)
    {
        object? typed = field.FieldType switch
        {
            StateFieldType.Integer => int.TryParse(raw?.ToString(), out var i) ? i : 0,
            StateFieldType.Decimal => decimal.TryParse(raw?.ToString(), out var d) ? d : 0m,
            StateFieldType.Toggle  => raw is bool b ? b
                                      : bool.TryParse(raw?.ToString(), out var pb) && pb,
            _ => raw?.ToString()
        };
        Session.StateInputValues[field.Key] = typed;
    }

    private void Calculate()
    {
        _errorMessage = null;
        _stateValidationErrors.Clear();

        var calc = StateRegistry.IsSupported(Session.State)
            ? StateRegistry.GetCalculator(Session.State)
            : null;
        if (calc is not null)
        {
            var errors = calc.Validate(Session.StateInputValues);
            if (errors.Count > 0)
            {
                _stateValidationErrors.AddRange(errors);
                _activeTab = "Tax Info";
                return;
            }
        }

        try
        {
            var input = Session.BuildInput();
            Session.LastResult = SeCalculator.Calculate(input);
            Nav.NavigateTo("self-employment-results");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
