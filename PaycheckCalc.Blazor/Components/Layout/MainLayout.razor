@inherits LayoutComponentBase
@*
    SessionStateLifecycle subscribes to AuthenticationStateChanged for the
    duration of the circuit; injecting it here is what causes it to be
    instantiated (and disposed when the circuit ends).
*@
@inject SessionStateLifecycle _sessionLifecycle

<div class="page">
    <nav class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">💰 PaycheckCalc</a>
            </div>
        </div>

        <NavMenu />
    </nav>

    <main>
        <div class="top-row px-4">
            <a href="https://github.com/Fibonacci-0112/MyCalculator" target="_blank" rel="noopener">GitHub</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
