<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:PaycheckCalc.App.Controls"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             x:Class="PaycheckCalc.App.Views.ResultsPage"
             Title="Results"
             BackgroundColor="#F0F4FF">

    <ContentPage.Resources>
        <helpers:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#1565C0" Padding="16,20,16,20">
            <Label Text="Your Paycheck Summary"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <!-- Results Tab Bar -->
        <Grid Grid.Row="1" BackgroundColor="#1976D2" Padding="10,8,10,8"
              ColumnDefinitions="*,*" ColumnSpacing="6">
            <Border Grid.Column="0" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab0Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab0Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectResultTabCommand}" CommandParameter="0" />
                </Border.GestureRecognizers>
                <Label Text="Period" Padding="4,8"
                       FontSize="13" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab0Visible}" Value="True">
                            <Setter Property="TextColor" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab0Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
            <Border Grid.Column="1" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab1Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab1Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectResultTabCommand}" CommandParameter="1" />
                </Border.GestureRecognizers>
                <Label Text="Annual" Padding="4,8"
                       FontSize="13" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab1Visible}" Value="True">
                            <Setter Property="TextColor" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab1Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </Grid>

        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- Period Tab Content                                 -->
                <!-- ═══════════════════════════════════════════════════ -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsResultTab0Visible}">

                <!-- Income card: Gross Pay, Federal Taxable Income, State Taxable Income -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Gross Pay" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.GrossPay, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="16" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Federal Taxable Income" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.FederalTaxableIncome, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="State Taxable Income" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.StateTaxableWages, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Taxes Section Header -->
                <Label Text="TAX WITHHOLDINGS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <!-- Tax rows card: Federal Tax, Social Security Tax, Medicare Tax, State Tax -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Federal Tax" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.FederalWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Social Security Tax" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.SocialSecurityWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Medicare Tax" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.MedicareWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="State Income Tax" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.StateWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"
                                 IsVisible="{Binding ResultCard.StateDisabilityInsurance, Converter={StaticResource GreaterThanZeroConverter}}" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10"
                              IsVisible="{Binding ResultCard.StateDisabilityInsurance, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="{Binding ResultCard.StateDisabilityInsuranceLabel}" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.StateDisabilityInsurance, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Deductions Section Header -->
                <Label Text="DEDUCTIONS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0"
                       IsVisible="{Binding ShowDeductions}" />

                <!-- Deductions card: Pre-Tax, Post-Tax -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8"
                        IsVisible="{Binding ShowDeductions}">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10"
                              IsVisible="{Binding ResultCard.PreTaxDeductions, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Pre-Tax Deductions" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.PreTaxDeductions, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#5D4037" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"
                                 IsVisible="{Binding ShowBothDeductions}" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10"
                              IsVisible="{Binding ResultCard.PostTaxDeductions, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Post-Tax Deductions" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding ResultCard.PostTaxDeductions, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#5D4037" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Net Pay card -->
                <Border BackgroundColor="#2E7D32" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20,18">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="NET PAY" TextColor="#A5D6A7"
                               FontSize="12" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding ResultCard.NetPay, StringFormat='{0:C}'}"
                               TextColor="White" FontAttributes="Bold" FontSize="36"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Save to Compare button -->
                <Button Text="Save to Compare"
                        Command="{Binding SaveForCompareCommand}"
                        BackgroundColor="#1565C0"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Padding="16,12"
                        HorizontalOptions="FillAndExpand" />

                <!-- Save Paycheck button (overwrite when loaded, prompt for name when new) -->
                <Button x:Name="SavePaycheckBtn"
                        Text="{Binding SaveButtonText}"
                        Clicked="OnSavePaycheckClicked"
                        IsVisible="{Binding CanExport}"
                        BackgroundColor="#7B1FA2"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        Padding="16,12"
                        HorizontalOptions="FillAndExpand" />

                <!-- Loaded paycheck indicator -->
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasLoadedPaycheck}" Padding="4,0">
                    <Label Text="{Binding LoadedPaycheckName, StringFormat='Editing: {0}'}"
                           TextColor="#7B1FA2" FontSize="12" FontAttributes="Italic"
                           VerticalTextAlignment="Center" />
                    <Button Grid.Column="1" Text="Save as New"
                            Clicked="OnSaveAsNewClicked"
                            BackgroundColor="#E1BEE7" TextColor="#7B1FA2"
                            FontSize="11" FontAttributes="Bold"
                            CornerRadius="8" Padding="10,4" HeightRequest="28" />
                </Grid>

                <!-- Export buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8"
                      IsVisible="{Binding CanExport}">
                    <Button Grid.Column="0"
                            Text="Export CSV"
                            Command="{Binding ExportCsvCommand}"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Padding="16,12" />
                    <Button Grid.Column="1"
                            Text="Export PDF"
                            Command="{Binding ExportPdfCommand}"
                            BackgroundColor="#C62828"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Padding="16,12" />
                </Grid>

                <!-- Doughnut Chart -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="12">
                    <GraphicsView x:Name="DoughnutChart"
                                  HeightRequest="380"
                                  HorizontalOptions="FillAndExpand" />
                </Border>

                </VerticalStackLayout>
                <!-- End Period Tab -->

                <!-- ═══════════════════════════════════════════════════ -->
                <!-- Annual Tab Content                                 -->
                <!-- ═══════════════════════════════════════════════════ -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsResultTab1Visible}">

                <!-- Projection Header -->
                <Label Text="ANNUAL PROJECTIONS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,8,0,0" />

                <!-- Pay periods info card -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Pay Periods Per Year" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.PayPeriodsPerYear}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Current Paycheck #" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.CurrentPaycheckNumber}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Remaining Paychecks" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.RemainingPaychecks}"
                                   Grid.Column="1"
                                   TextColor="#1565C0" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Annualized amounts card -->
                <Label Text="ANNUALIZED AMOUNTS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Gross Pay" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedGrossPay, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10"
                              IsVisible="{Binding Projection.AnnualizedPreTaxDeductions, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Pre-Tax Deductions" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedPreTaxDeductions, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#5D4037" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"
                                 IsVisible="{Binding Projection.AnnualizedPreTaxDeductions, Converter={StaticResource GreaterThanZeroConverter}}" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10"
                              IsVisible="{Binding Projection.AnnualizedPostTaxDeductions, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Post-Tax Deductions" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedPostTaxDeductions, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#5D4037" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0"
                                 IsVisible="{Binding Projection.AnnualizedPostTaxDeductions, Converter={StaticResource GreaterThanZeroConverter}}" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Federal Taxable Wages" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedFederalTaxableWages, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="FICA Taxable Wages" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedFicaTaxableWages, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="State Taxable Wages" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedStateTaxableWages, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Federal Withholding" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedFederalWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="State Withholding" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedStateWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="FICA (SS + Medicare)" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedFica, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Net Pay" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedNetPay, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#2E7D32" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Projected YTD card -->
                <Label Text="PROJECTED YEAR-TO-DATE" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="YTD Gross Pay" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.ProjectedYtdGrossPay, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="YTD Federal Withholding" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.ProjectedYtdFederalWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="YTD State Withholding" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.ProjectedYtdStateWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="YTD FICA" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.ProjectedYtdFica, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="YTD Net Pay" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.ProjectedYtdNetPay, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#2E7D32" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Over/Under Withholding card -->
                <Label Text="WITHHOLDING ESTIMATE" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Annualized Total Withholding" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.AnnualizedTotalWithholding, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#C62828" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Est. Federal Tax Liability" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.EstimatedAnnualFederalLiability, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Est. FICA Liability" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.EstimatedAnnualFicaLiability, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,Auto" Padding="0,10">
                            <Label Text="Est. Total Tax Liability" TextColor="#37474F" FontSize="15" VerticalTextAlignment="Center" />
                            <Label Text="{Binding Projection.EstimatedTotalLiability, StringFormat='{0:C}'}"
                                   Grid.Column="1"
                                   TextColor="#37474F" FontAttributes="Bold"
                                   FontSize="15" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Over/Under summary card -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20,18">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding Projection.IsOverWithholding}" Value="True">
                            <Setter Property="BackgroundColor" Value="#2E7D32" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding Projection.IsUnderWithholding}" Value="True">
                            <Setter Property="BackgroundColor" Value="#C62828" />
                        </DataTrigger>
                    </Border.Triggers>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Projection.OverUnderLabel}"
                               TextColor="#FFFFFFCC"
                               FontSize="12" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Projection.OverUnderAmount, StringFormat='{0:C}'}"
                               TextColor="White" FontAttributes="Bold" FontSize="28"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                </VerticalStackLayout>
                <!-- End Annual Tab -->

            </VerticalStackLayout>
        </ScrollView>

