<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaycheckCalc.App.Views.ResultsPage"
             Title="Results">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="8">
            <Label Text="Results" FontAttributes="Bold" FontSize="18" />

            <!-- Net Pay: prominent green button-like display -->
            <Frame BackgroundColor="#4CAF50" CornerRadius="10" Padding="16" Margin="0,4,0,8"
                   BorderColor="Transparent">
                <Label Text="{Binding Result.NetPay, StringFormat='Net Pay: {0:C}'}"
                       TextColor="White" FontAttributes="Bold" FontSize="22"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <Label Text="{Binding Result.GrossPay, StringFormat='Gross Pay: {0:C}'}" />

            <!-- Tax withholdings: amounts displayed in red -->
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Federal Tax: " />
                        <Span Text="{Binding Result.FederalWithholding, StringFormat='{0:C}'}" TextColor="Red" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label Text="{Binding Result.StateTaxableWages, StringFormat='State Taxable Wages: {0:C}'}" />
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="State Withholding: " />
                        <Span Text="{Binding Result.StateWithholding, StringFormat='{0:C}'}" TextColor="Red" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Social Security Tax: " />
                        <Span Text="{Binding Result.SocialSecurityWithholding, StringFormat='{0:C}'}" TextColor="Red" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Medicare Tax: " />
                        <Span Text="{Binding Result.MedicareWithholding, StringFormat='{0:C}'}" TextColor="Red" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Additional Medicare Tax: " />
                        <Span Text="{Binding Result.AdditionalMedicareWithholding, StringFormat='{0:C}'}" TextColor="Red" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
