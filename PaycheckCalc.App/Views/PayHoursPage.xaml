<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             x:Class="PaycheckCalc.App.Views.PayHoursPage"
             Title="Pay &amp; Hours"
             BackgroundColor="#FAFAFA">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="14">
                    <Label Text="Pay Frequency" Grid.Row="0" Grid.Column="0"
                           VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                    <Picker ItemsSource="{Binding Frequencies}" SelectedItem="{Binding SelectedFrequencyPickerItem}"
                            Grid.Row="0" Grid.Column="1" TextColor="Black" />
                    <Label Text="Hourly Rate" Grid.Row="1" Grid.Column="0"
                           VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                    <Entry Text="{Binding HourlyRate}" Keyboard="Numeric" Grid.Row="1" Grid.Column="1"
                           TextColor="Black" BackgroundColor="#E0F2F1">
                        <Entry.Behaviors>
                            <behaviors:DecimalFormatBehavior IsCurrency="True" />
                        </Entry.Behaviors>
                    </Entry>
                    <Label Text="Regular Hours" Grid.Row="2" Grid.Column="0"
                           VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                    <Entry Text="{Binding RegularHours}" Keyboard="Numeric" Grid.Row="2" Grid.Column="1"
                           TextColor="Black" BackgroundColor="#E0F2F1">
                        <Entry.Behaviors>
                            <behaviors:DecimalFormatBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <Label Text="Overtime Hours" Grid.Row="3" Grid.Column="0"
                           VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                    <Entry Text="{Binding OvertimeHours}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1"
                           TextColor="Black" BackgroundColor="#E0F2F1">
                        <Entry.Behaviors>
                            <behaviors:DecimalFormatBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <Label Text="OT Multiplier" Grid.Row="4" Grid.Column="0"
                           VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                    <Entry Text="{Binding OvertimeMultiplier}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1"
                           TextColor="Black" BackgroundColor="#E0F2F1">
                        <Entry.Behaviors>
                            <behaviors:DecimalFormatBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <Label Text="Paycheck # (this year)" Grid.Row="5" Grid.Column="0"
                           VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                    <Entry Text="{Binding PaycheckNumber}" Keyboard="Numeric" Grid.Row="5" Grid.Column="1"
                           TextColor="Black" BackgroundColor="#E0F2F1" />
                    <Button Text="Calculate" Command="{Binding CalculateCommand}"
                            Grid.Row="6" Grid.ColumnSpan="2"
                            BackgroundColor="#00897B" TextColor="White"
                            FontAttributes="Bold" CornerRadius="8"
                            Margin="0,6,0,0" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
