<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             x:Class="PaycheckCalc.App.Views.OtherIncomeAdjustmentsPage"
             Title="Other Income &amp; Adjustments"
             BackgroundColor="#FAFAFA">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Schedule 1 Part I: Additional Income -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Schedule 1 Part I — Additional Income" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Text="Taxable Interest" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.TaxableInterest}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="1" Grid.Column="0" Text="Ordinary Dividends" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.OrdinaryDividends}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="2" Grid.Column="0" Text="Qualified Dividends" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Session.QualifiedDividends}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="3" Grid.Column="0" Text="Capital Gain / (Loss)" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Session.CapitalGainOrLoss}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="4" Grid.Column="0" Text="Unemployment" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Session.UnemploymentCompensation}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="5" Grid.Column="0" Text="Taxable State/Local Refunds" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="5" Grid.Column="1" Text="{Binding Session.TaxableStateLocalRefunds}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="6" Grid.Column="0" Text="Taxable Social Security" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="6" Grid.Column="1" Text="{Binding Session.TaxableSocialSecurity}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="7" Grid.Column="0" Text="Other Additional Income" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="7" Grid.Column="1" Text="{Binding Session.OtherAdditionalIncome}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Schedule 1 Part II: Adjustments -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Schedule 1 Part II — Adjustments" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Text="Student Loan Interest" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.StudentLoanInterest}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="1" Grid.Column="0" Text="HSA Deduction" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.HsaDeduction}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="2" Grid.Column="0" Text="Traditional IRA" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Session.TraditionalIraDeduction}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="3" Grid.Column="0" Text="Educator Expenses" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Session.EducatorExpenses}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="4" Grid.Column="0" Text="SE Health Insurance" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Session.SelfEmployedHealthInsurance}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="5" Grid.Column="0" Text="SE Retirement" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="5" Grid.Column="1" Text="{Binding Session.SelfEmployedRetirement}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>

                        <Label Grid.Row="6" Grid.Column="0" Text="Other Adjustments" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="6" Grid.Column="1" Text="{Binding Session.OtherAdjustments}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
