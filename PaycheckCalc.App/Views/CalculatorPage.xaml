<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             x:Class="PaycheckCalc.App.Views.CalculatorPage"
             Title="Paycheck Calculator">
    
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">
        <Label Text="Inputs" FontAttributes="Bold" FontSize="18" />
        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
            <Label Text="Pay Frequency" Grid.Row="0" Grid.Column="0" />
            <Picker ItemsSource="{Binding Frequencies}" SelectedItem="{Binding Frequency}" Grid.Row="0" Grid.Column="1" />
            <Label Text="Hourly Rate" Grid.Row="1" Grid.Column="0" />
            <Entry Text="{Binding HourlyRate}" Keyboard="Numeric" Grid.Row="1" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
                <Label Text="Regular Hours" Grid.Row="2" Grid.Column="0" />
            <Entry Text="{Binding RegularHours}" Keyboard="Numeric" Grid.Row="2" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior />
                </Entry.Behaviors>
            </Entry>
            <Label Text="Overtime Hours" Grid.Row="3" Grid.Column="0" />
            <Entry Text="{Binding OvertimeHours}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior />
                </Entry.Behaviors>
            </Entry>
            <Label Text="OT Multiplier" Grid.Row="4" Grid.Column="0" />
            <Entry Text="{Binding OvertimeMultiplier}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior />
                </Entry.Behaviors>
            </Entry>
            <Label Text="Pre-tax Deductions" Grid.Row="5" Grid.Column="0" />
            <Entry Text="{Binding PretaxDeductions}" Keyboard="Numeric" Grid.Row="5" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
            <Label Text="Post-tax Deductions" Grid.Row="6" Grid.Column="0" />
            <Entry Text="{Binding PosttaxDeductions}" Keyboard="Numeric" Grid.Row="6" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
            </Grid>

        <Label Text="Federal Withholding" FontAttributes="Bold" FontSize="18" Margin="0,10,0,0" />
        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
            <Label Text="Filing Status" Grid.Row="0" Grid.Column="0" />
            <Picker ItemsSource="{Binding FederalStatuses}" SelectedItem="{Binding SelectedFederalPickerItem}" Grid.Row="0" Grid.Column="1" />
            <Label Text="Step 2 checked?" Grid.Row="1" Grid.Column="0" />
            <Switch IsToggled="{Binding FederalStep2Checked}" Grid.Row="1" Grid.Column="1" />
            <Label Text="Step 3 credits (annual)" Grid.Row="2" Grid.Column="0" />
            <Entry Text="{Binding FederalStep3Credits}" Keyboard="Numeric" Grid.Row="2" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
            <Label Text="Step 4(a) other income (annual)" Grid.Row="3" Grid.Column="0" />
            <Entry Text="{Binding FederalStep4aOtherIncome}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
            <Label Text="Step 4(b) deductions (annual)" Grid.Row="4" Grid.Column="0" />
            <Entry Text="{Binding FederalStep4bDeductions}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
            <Label Text="Step 4(c) extra per pay" Grid.Row="5" Grid.Column="0" />
            <Entry Text="{Binding FederalStep4cExtraWithholding}" Keyboard="Numeric" Grid.Row="5" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
        </Grid>


        <Label Text="State Withholding" FontAttributes="Bold" FontSize="18" Margin="0,10,0,0" />
        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
            <Label Text="State" Grid.Row="0" Grid.Column="0" />
            <Picker ItemsSource="{Binding SupportedStates}" SelectedItem="{Binding SelectedState}" Grid.Row="0" Grid.Column="1" />
            <Label Text="Filing Status" Grid.Row="2" Grid.Column="0" />
            <Picker ItemsSource="{Binding Statuses}" SelectedItem="{Binding FilingStatus}" Grid.Row="2" Grid.Column="1" />
            <Label Text="State Allowances" Grid.Row="3" Grid.Column="0" />
            <Entry Text="{Binding StateAllowances}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1" />
            <Label Text="Extra State Withholding" Grid.Row="4" Grid.Column="0" />
            <Entry Text="{Binding StateAdditionalWithholding}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1">
                <Entry.Behaviors>
                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                </Entry.Behaviors>
            </Entry>
        </Grid>
        <Button Text="Calculate" Command="{Binding CalculateCommand}" />

        <Border Stroke="#DDDDDD" Padding="12">
            <VerticalStackLayout Spacing="6">
                <Label Text="Results" FontAttributes="Bold" FontSize="18" />
                <Label Text="{Binding Result.GrossPay, StringFormat='Gross Pay: {0:C}'}" />
                <Label Text="{Binding Result.FederalWithholding, StringFormat='Federal Tax: {0:C}'}" />
                <Label Text="{Binding Result.StateTaxableWages, StringFormat='State Taxable Wages: {0:C}'}" />
                <Label Text="{Binding Result.StateWithholding, StringFormat='State Withholding: {0:C}'}" />
                <Label Text="{Binding Result.SocialSecurityWithholding, StringFormat='Social Security Tax: {0:C}'}" />
                <Label Text="{Binding Result.MedicareWithholding, StringFormat='Medicare Tax: {0:C}'}" />
                <Label Text="{Binding Result.AdditionalMedicareWithholding, StringFormat='Additional Medicare Tax: {0:C}'}" />
                <Label Text="{Binding Result.NetPay, StringFormat='Net Pay: {0:C}'}" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Border>

        </VerticalStackLayout>
  </ScrollView>
</ContentPage>
