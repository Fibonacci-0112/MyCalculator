<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             x:Class="PaycheckCalc.App.Views.SavedPaychecksPage"
             Title="Saved Paychecks"
             BackgroundColor="#F0F4FF">

    <ContentPage.Resources>
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#1565C0" Padding="16,20,16,20"
              ColumnDefinitions="*,Auto">
            <Label Text="Saved Paychecks"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Center" />
            <!-- Selection-mode toggle -->
            <Button Grid.Column="1"
                    Command="{Binding ToggleSelectionModeCommand}"
                    BackgroundColor="#0D47A1" TextColor="White"
                    FontSize="12" FontAttributes="Bold"
                    CornerRadius="8" Padding="12,6" HeightRequest="32"
                    IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsSelectionMode}" Value="True">
                        <Setter Property="Text" Value="Done" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsSelectionMode}" Value="False">
                        <Setter Property="Text" Value="Select" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- Selection-mode helper banner -->
        <Border Grid.Row="1" BackgroundColor="#E3F2FD" StrokeThickness="0"
                Padding="16,10" IsVisible="{Binding IsSelectionMode}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Label VerticalTextAlignment="Center"
                       TextColor="#0D47A1" FontSize="13">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Selected: " />
                            <Span Text="{Binding SelectedCount}" FontAttributes="Bold" />
                            <Span Text=" — pick 2 or more scenarios to compare side-by-side." />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
        </Border>

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="2" IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="32">
            <Label Text="No Saved Paychecks"
                   TextColor="#78909C" FontSize="20" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Go to the Results page and tap &quot;Save as New Paycheck&quot; to save your first paycheck calculation."
                   TextColor="#90A4AE" FontSize="14"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Saved paychecks list -->
        <CollectionView Grid.Row="2"
                         ItemsSource="{Binding SavedPaychecks}"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}"
                         SelectionMode="None"
                         Margin="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 12" Padding="16,12"
                            Margin="16,6,16,6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPaycheckTapped" CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="10">

                            <!-- Selection checkbox (visible only in selection mode) -->
                            <CheckBox Grid.RowSpan="2"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Color="#1565C0"
                                      VerticalOptions="Center"
                                      IsVisible="{Binding BindingContext.IsSelectionMode, Source={RelativeSource AncestorType={x:Type CollectionView}}}" />

                            <!-- Name -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Name}"
                                   TextColor="#37474F" FontSize="16" FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />

                            <!-- Net Pay -->
                            <Label Grid.Row="0" Grid.Column="2"
                                   Text="{Binding NetPay, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="End" />

                            <!-- State + Gross -->
                            <Label Grid.Row="1" Grid.Column="1"
                                   TextColor="#78909C" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding StateName}" />
                                        <Span Text=" · Gross " />
                                        <Span Text="{Binding GrossPay, StringFormat='{0:C}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Date -->
                            <Label Grid.Row="1" Grid.Column="2"
                                   Text="{Binding DateDisplay}"
                                   TextColor="#90A4AE" FontSize="11"
                                   HorizontalTextAlignment="End" />

                            <!-- Action buttons (hidden in selection mode) -->
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                   Spacing="8" Margin="0,4,0,0"
                                                   IsVisible="{Binding BindingContext.ShowActionButtons, Source={RelativeSource AncestorType={x:Type CollectionView}}}">
                                <Button Text="Load"
                                        Clicked="OnLoadClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#1565C0" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="Compare"
                                        Clicked="OnCompareClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#7B1FA2" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="CSV"
                                        Clicked="OnExportCsvClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#2E7D32" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="PDF"
                                        Clicked="OnExportPdfClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#C62828" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="Rename"
                                        Clicked="OnRenameClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#F57C00" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#EF5350" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Compare Selected CTA (only in selection mode) -->
        <Button Grid.Row="3"
                Text="Compare Selected"
                Clicked="OnCompareSelectedClicked"
                IsEnabled="{Binding CanCompareSelected}"
                IsVisible="{Binding IsSelectionMode}"
                BackgroundColor="#7B1FA2" TextColor="White"
                FontSize="15" FontAttributes="Bold"
                CornerRadius="12" Padding="16,12"
                Margin="16,8,16,16" HeightRequest="48" />

    </Grid>

</ContentPage>
