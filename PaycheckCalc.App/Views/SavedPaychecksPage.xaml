<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             x:Class="PaycheckCalc.App.Views.SavedPaychecksPage"
             Title="Saved Paychecks"
             BackgroundColor="#F0F4FF">

    <ContentPage.Resources>
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#1565C0" Padding="16,20,16,20">
            <Label Text="Saved Paychecks"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="32">
            <Label Text="No Saved Paychecks"
                   TextColor="#78909C" FontSize="20" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Go to the Results tab and tap &quot;Save as New Paycheck&quot; to save your first paycheck calculation."
                   TextColor="#90A4AE" FontSize="14"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Saved paychecks list -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding SavedPaychecks}"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}"
                         SelectionMode="None"
                         Margin="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 12" Padding="16,12"
                            Margin="16,6,16,6">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPaycheckTapped" CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">

                            <!-- Name -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   TextColor="#37474F" FontSize="16" FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />

                            <!-- Net Pay -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding NetPay, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="End" />

                            <!-- State + Gross -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   TextColor="#78909C" FontSize="13">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding StateName}" />
                                        <Span Text=" · Gross " />
                                        <Span Text="{Binding GrossPay, StringFormat='{0:C}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Date -->
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding DateDisplay}"
                                   TextColor="#90A4AE" FontSize="11"
                                   HorizontalTextAlignment="End" />

                            <!-- Action buttons -->
                            <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8" Margin="0,4,0,0">
                                <Button Text="Load"
                                        Clicked="OnLoadClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#1565C0" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="Compare"
                                        Clicked="OnCompareClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#7B1FA2" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="CSV"
                                        Clicked="OnExportCsvClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#2E7D32" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="PDF"
                                        Clicked="OnExportPdfClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#C62828" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="Rename"
                                        Clicked="OnRenameClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#F57C00" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked" CommandParameter="{Binding Id}"
                                        BackgroundColor="#EF5350" TextColor="White"
                                        FontSize="12" FontAttributes="Bold"
                                        CornerRadius="8" Padding="12,6" HeightRequest="32" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
