<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaycheckCalc.App.Views.LoginPage"
             Title="Sign in"
             BackgroundColor="#F0F4FF">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24" MaximumWidthRequest="480"
                             HorizontalOptions="Center">

            <VerticalStackLayout Spacing="4">
                <Label Text="🔐 Sign in"
                       TextColor="#0D47A1" FontSize="26" FontAttributes="Bold" />
                <Label Text="Your saved paychecks and annual scenarios sync to your account so they're there on every device."
                       TextColor="#78909C" FontSize="13" LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Email" TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                    <Entry Text="{Binding Email}"
                           Placeholder="you@example.com"
                           Keyboard="Email"
                           IsEnabled="{Binding IsNotBusy}" />

                    <Label Text="Password" TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                    <Entry Text="{Binding Password}"
                           IsPassword="True"
                           Placeholder="••••••••"
                           IsEnabled="{Binding IsNotBusy}" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#D32F2F" FontSize="13"
                           IsVisible="{Binding HasError}"
                           LineBreakMode="WordWrap" />

                    <Button Text="Sign in"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#1976D2"
                            TextColor="White"
                            IsEnabled="{Binding IsNotBusy}" />

                    <Button Text="Create account with these credentials"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#1976D2"
                            BorderColor="#1976D2"
                            BorderWidth="1"
                            IsEnabled="{Binding IsNotBusy}" />

                    <Label Text="Signing in…"
                           TextColor="#78909C" FontSize="12"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <Label Text="External providers (Google / Microsoft) are available on the web sign-in for now — mobile external sign-in is coming in a follow-up."
                   TextColor="#78909C" FontSize="11"
                   LineBreakMode="WordWrap"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
