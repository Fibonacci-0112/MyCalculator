<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             x:Class="PaycheckCalc.App.Views.InputsPage"
             Title="Inputs"
             BackgroundColor="#F0F4FF">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#1565C0" Padding="16,20,16,20">
            <Label Text="Paycheck Calculator"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <!-- Section Tab Bar -->
        <Grid Grid.Row="1" BackgroundColor="#1976D2" Padding="10,8,10,8"
              ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
            <Border Grid.Column="0" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab0Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab0Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="0" />
                </Border.GestureRecognizers>
                <Label Text="Pay &amp; Hours" Padding="4,8"
                       FontSize="11" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab0Visible}" Value="True">
                            <Setter Property="TextColor" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab0Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
            <Border Grid.Column="1" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab1Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab1Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="1" />
                </Border.GestureRecognizers>
                <Label Text="Federal" Padding="4,8"
                       FontSize="11" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab1Visible}" Value="True">
                            <Setter Property="TextColor" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab1Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
            <Border Grid.Column="2" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab2Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab2Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="2" />
                </Border.GestureRecognizers>
                <Label Text="State" Padding="4,8"
                       FontSize="11" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab2Visible}" Value="True">
                            <Setter Property="TextColor" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab2Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
            <Border Grid.Column="3" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab3Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsTab3Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="3" />
                </Border.GestureRecognizers>
                <Label Text="Deductions" Padding="4,8"
                       FontSize="11" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab3Visible}" Value="True">
                            <Setter Property="TextColor" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsTab3Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </Grid>

        <!-- Tab Content -->
        <ScrollView Grid.Row="2">
            <ScrollView.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left" Swiped="OnSwipedLeft" />
                <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipedRight" />
            </ScrollView.GestureRecognizers>
            <VerticalStackLayout Padding="16" Spacing="10">

                <!-- Pay Rate &amp; Hours Tab -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16"
                        IsVisible="{Binding IsTab0Visible}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="14">
                        <Label Text="Pay Frequency" Grid.Row="0" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Picker ItemsSource="{Binding Frequencies}" SelectedItem="{Binding Frequency}"
                                Grid.Row="0" Grid.Column="1" TextColor="Black" />
                        <Label Text="Hourly Rate" Grid.Row="1" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding HourlyRate}" Keyboard="Numeric" Grid.Row="1" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Regular Hours" Grid.Row="2" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding RegularHours}" Keyboard="Numeric" Grid.Row="2" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Overtime Hours" Grid.Row="3" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding OvertimeHours}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="OT Multiplier" Grid.Row="4" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding OvertimeMultiplier}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior />
                            </Entry.Behaviors>
                        </Entry>
                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                Grid.Row="5" Grid.ColumnSpan="2"
                                BackgroundColor="#1565C0" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </Grid>
                </Border>

                <!-- Federal Withholding Tab -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16"
                        IsVisible="{Binding IsTab1Visible}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="14">
                        <Label Text="Filing Status" Grid.Row="0" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Picker ItemsSource="{Binding FederalStatuses}" SelectedItem="{Binding SelectedFederalPickerItem}"
                                Grid.Row="0" Grid.Column="1" TextColor="Black" />
                        <Label Text="Step 2 checked?" Grid.Row="1" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Switch IsToggled="{Binding FederalStep2Checked}" Grid.Row="1" Grid.Column="1"
                                OnColor="#1565C0" />
                        <Label Text="Step 3 credits (annual)" Grid.Row="2" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding FederalStep3Credits}" Keyboard="Numeric" Grid.Row="2" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Step 4(a) other income (annual)" Grid.Row="3" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding FederalStep4aOtherIncome}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Step 4(b) deductions (annual)" Grid.Row="4" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding FederalStep4bDeductions}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Step 4(c) extra per pay" Grid.Row="5" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding FederalStep4cExtraWithholding}" Keyboard="Numeric" Grid.Row="5" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#EEF2FF">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                Grid.Row="6" Grid.ColumnSpan="2"
                                BackgroundColor="#1565C0" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </Grid>
                </Border>

                <!-- State Withholding Tab (dynamic fields driven by schema metadata) -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16"
                        IsVisible="{Binding IsTab2Visible}">
                    <VerticalStackLayout Spacing="14">
                        <!-- State picker is always shown -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Label Text="State" Grid.Column="0"
                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                            <Picker ItemsSource="{Binding StatePickerItems}" SelectedItem="{Binding SelectedStatePickerItem}"
                                    Grid.Column="1" TextColor="Black" />
                        </Grid>

                        <!-- Dynamic fields rendered from the state calculator's schema -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding StateFields}" Spacing="14">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <Label Text="{Binding Label}" Grid.Column="0"
                                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                                        <!-- Picker control for Picker fields -->
                                        <Picker IsVisible="{Binding IsPicker}"
                                                ItemsSource="{Binding Options}"
                                                SelectedItem="{Binding SelectedOption}"
                                                Grid.Column="1" TextColor="Black" />
                                        <!-- Entry control for Integer/Decimal fields -->
                                        <Entry IsVisible="{Binding IsNumeric}"
                                               Text="{Binding StringValue}"
                                               Keyboard="Numeric"
                                               Grid.Column="1"
                                               TextColor="Black" BackgroundColor="#EEF2FF" />
                                        <!-- Switch control for Toggle fields -->
                                        <Switch IsVisible="{Binding IsToggle}"
                                                IsToggled="{Binding BoolValue}"
                                                Grid.Column="1"
                                                OnColor="#1565C0" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                BackgroundColor="#1565C0" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- Deductions Tab -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16"
                        IsVisible="{Binding IsTab3Visible}">
                    <VerticalStackLayout Spacing="10">

                        <!-- Deduction items list -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Deductions}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFF" StrokeThickness="1" Stroke="#E0E0E0"
                                            StrokeShape="RoundRectangle 8" Padding="12">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto"
                                              RowSpacing="8" ColumnSpacing="8">
                                            <!-- Name -->
                                            <Entry Grid.Row="0" Grid.Column="0" Placeholder="Name (e.g. 401k)"
                                                   Text="{Binding Name}" TextColor="Black" BackgroundColor="#EEF2FF"
                                                   FontSize="14" />
                                            <!-- Remove button -->
                                            <Button Grid.Row="0" Grid.Column="1" Text="✕"
                                                    FontSize="14" Padding="6,2"
                                                    BackgroundColor="#EF5350" TextColor="White" CornerRadius="4"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveDeductionCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <!-- Amount -->
                                            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Label Text="Amount" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <Entry Grid.Column="1" Text="{Binding Amount}" Keyboard="Numeric"
                                                       TextColor="Black" BackgroundColor="#EEF2FF" FontSize="14">
                                                    <Entry.Behaviors>
                                                        <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                                    </Entry.Behaviors>
                                                </Entry>
                                            </Grid>
                                            <!-- Amount Type picker (Dollar or Percentage) -->
                                            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Label Text="Amount Type" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <Picker Grid.Column="1" ItemsSource="{Binding AmountTypes}"
                                                        SelectedItem="{Binding AmountType}" TextColor="Black" />
                                            </Grid>
                                            <!-- Type picker -->
                                            <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Label Text="Type" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <Picker Grid.Column="1" ItemsSource="{Binding DeductionTypes}"
                                                        SelectedItem="{Binding Type}" TextColor="Black" />
                                            </Grid>
                                            <!-- ReducesStateTaxableWages toggle -->
                                            <Grid Grid.Row="4" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label Text="Reduces State Taxable Wages" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <Switch Grid.Column="1" IsToggled="{Binding ReducesStateTaxableWages}"
                                                        OnColor="#1565C0" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Add Deduction button -->
                        <Button Text="+ Add Deduction" Command="{Binding AddDeductionCommand}"
                                BackgroundColor="#E3F2FD" TextColor="#1565C0"
                                FontAttributes="Bold" CornerRadius="8" />

                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                BackgroundColor="#1565C0" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
