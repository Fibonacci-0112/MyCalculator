<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             x:Class="PaycheckCalc.App.Views.SelfEmploymentPage"
             Title="Self-Employment"
             BackgroundColor="#FAFAFA">
    <Grid RowDefinitions="Auto,*">

        <!-- Tab header row -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*"
              BackgroundColor="#455A64" Padding="0" ColumnSpacing="0">
            <Button x:Name="TabIncome" Text="Income"
                    Clicked="OnTabClicked"
                    BackgroundColor="#00897B" TextColor="White"
                    FontSize="13" FontAttributes="Bold"
                    CornerRadius="0" BorderWidth="0"
                    Padding="4,10" Grid.Column="0" />
            <Button x:Name="TabTaxInfo" Text="Tax Info"
                    Clicked="OnTabClicked"
                    BackgroundColor="#455A64" TextColor="#B0BEC5"
                    FontSize="13"
                    CornerRadius="0" BorderWidth="0"
                    Padding="4,10" Grid.Column="1" />
            <Button x:Name="TabQbi" Text="QBI / 8995"
                    Clicked="OnTabClicked"
                    BackgroundColor="#455A64" TextColor="#B0BEC5"
                    FontSize="13"
                    CornerRadius="0" BorderWidth="0"
                    Padding="4,10" Grid.Column="2" />
        </Grid>

        <!-- Income tab -->
        <ScrollView Grid.Row="1" x:Name="IncomeContent" IsVisible="True">
            <VerticalStackLayout Padding="16" Spacing="10">
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="14">
                        <Label Text="Gross Revenue" Grid.Row="0" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding GrossRevenue}" Keyboard="Numeric" Grid.Row="0" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#E0F2F1">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Cost of Goods Sold" Grid.Row="1" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding CostOfGoodsSold}" Keyboard="Numeric" Grid.Row="1" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#E0F2F1">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Business Expenses" Grid.Row="2" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding TotalBusinessExpenses}" Keyboard="Numeric" Grid.Row="2" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#E0F2F1">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Other Income (W-2, etc.)" Grid.Row="3" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding OtherIncome}" Keyboard="Numeric" Grid.Row="3" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#E0F2F1">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Est. Tax Payments Made" Grid.Row="4" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding EstimatedTaxPayments}" Keyboard="Numeric" Grid.Row="4" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#E0F2F1">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                Grid.Row="5" Grid.ColumnSpan="2"
                                BackgroundColor="#00897B" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </Grid>
                </Border>

                <!-- W-2 FICA Coordination -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="W-2 FICA Coordination" FontSize="15" FontAttributes="Bold"
                               TextColor="#1565C0" />
                        <Label Text="If you also have W-2 wages, enter your W-2 Box 3 and Box 5 amounts to correctly coordinate the Social Security wage base and Additional Medicare Tax threshold."
                               TextColor="#78909C" FontSize="12" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                              ColumnSpacing="12" RowSpacing="14">
                            <Label Text="W-2 SS Wages (Box 3)" Grid.Row="0" Grid.Column="0"
                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                            <Entry Text="{Binding W2SocialSecurityWages}" Keyboard="Numeric"
                                   Grid.Row="0" Grid.Column="1"
                                   TextColor="Black" BackgroundColor="#E3F2FD">
                                <Entry.Behaviors>
                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                </Entry.Behaviors>
                            </Entry>
                            <Label Text="W-2 Medicare Wages (Box 5)" Grid.Row="1" Grid.Column="0"
                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                            <Entry Text="{Binding W2MedicareWages}" Keyboard="Numeric"
                                   Grid.Row="1" Grid.Column="1"
                                   TextColor="Black" BackgroundColor="#E3F2FD">
                                <Entry.Behaviors>
                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                </Entry.Behaviors>
                            </Entry>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Tax Info tab -->
        <ScrollView Grid.Row="1" x:Name="TaxInfoContent" IsVisible="False">
            <VerticalStackLayout Padding="16" Spacing="10">
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="12" RowSpacing="14">
                            <Label Text="Filing Status" Grid.Row="0" Grid.Column="0"
                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                            <Picker ItemsSource="{Binding FederalStatuses}" SelectedItem="{Binding SelectedFederalPickerItem}"
                                    Grid.Row="0" Grid.Column="1" TextColor="Black" />
                            <Label Text="State" Grid.Row="1" Grid.Column="0"
                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                            <Picker ItemsSource="{Binding StatePickerItems}" SelectedItem="{Binding SelectedStatePickerItem}"
                                    Grid.Row="1" Grid.Column="1" TextColor="Black" />
                            <Label Text="Itemized Over Standard" Grid.Row="2" Grid.Column="0"
                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                            <Entry Text="{Binding ItemizedDeductionsOverStandard}" Keyboard="Numeric"
                                   Grid.Row="2" Grid.Column="1"
                                   TextColor="Black" BackgroundColor="#E8EAF6">
                                <Entry.Behaviors>
                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                </Entry.Behaviors>
                            </Entry>
                        </Grid>

                        <Label Text="No extra inputs required for this state."
                               IsVisible="{Binding HasNoStateFields}"
                               TextColor="#78909C" FontSize="13"
                               FontAttributes="Italic"
                               HorizontalTextAlignment="Center"
                               Margin="0,8,0,0" />

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding StateFields}" Spacing="14">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Label Text="{Binding Label}" Grid.Column="0"
                                                   VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                                            <Picker IsVisible="{Binding IsPicker}"
                                                    ItemsSource="{Binding Options}"
                                                    SelectedItem="{Binding SelectedOption}"
                                                    Grid.Column="1" TextColor="Black" />
                                            <Entry IsVisible="{Binding IsNumeric}"
                                                   Text="{Binding StringValue}"
                                                   Keyboard="Numeric"
                                                   Grid.Column="1"
                                                   TextColor="Black" BackgroundColor="#F3E5F5" />
                                            <Entry IsVisible="{Binding IsText}"
                                                   Text="{Binding StringValue}"
                                                   Keyboard="Default"
                                                   Grid.Column="1"
                                                   TextColor="Black" BackgroundColor="#F3E5F5" />
                                            <Switch IsVisible="{Binding IsToggle}"
                                                    IsToggled="{Binding BoolValue}"
                                                    Grid.Column="1"
                                                    OnColor="#7B1FA2" />
                                        </Grid>
                                        <Label Text="{Binding ErrorMessage}"
                                               IsVisible="{Binding HasError}"
                                               TextColor="#D32F2F" FontSize="11"
                                               Margin="0,-2,0,0" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding StateValidationErrors}"
                                             IsVisible="{Binding HasStateValidationErrors}"
                                             Spacing="2" Margin="0,4,0,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Label Text="{Binding .}" TextColor="#D32F2F" FontSize="12" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                BackgroundColor="#3949AB" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- QBI / Form 8995 tab -->
        <ScrollView Grid.Row="1" x:Name="QbiContent" IsVisible="False">
            <VerticalStackLayout Padding="16" Spacing="10">
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="14">
                        <Label Text="SSTB (Service Business)?" Grid.Row="0" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Switch IsToggled="{Binding IsSpecifiedServiceBusiness}" Grid.Row="0" Grid.Column="1"
                                OnColor="#7B1FA2" />
                        <Label Text="Business W-2 Wages Paid" Grid.Row="1" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding QualifiedBusinessW2Wages}" Keyboard="Numeric"
                               Grid.Row="1" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#F3E5F5">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Label Text="Qualified Property (UBIA)" Grid.Row="2" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding QualifiedPropertyUbia}" Keyboard="Numeric"
                               Grid.Row="2" Grid.Column="1"
                               TextColor="Black" BackgroundColor="#F3E5F5">
                            <Entry.Behaviors>
                                <behaviors:DecimalFormatBehavior IsCurrency="True" />
                            </Entry.Behaviors>
                        </Entry>
                        <Button Text="Calculate" Command="{Binding CalculateCommand}"
                                Grid.Row="3" Grid.ColumnSpan="2"
                                BackgroundColor="#7B1FA2" TextColor="White"
                                FontAttributes="Bold" CornerRadius="8"
                                Margin="0,6,0,0" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
