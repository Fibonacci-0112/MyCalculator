<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             x:Class="PaycheckCalc.App.Views.AnnualProjectionPage"
             Title="Annual Projection"
             BackgroundColor="#FAFAFA">
    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Basics block: tax year + filing status + residence state. -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Annual Basics" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="14">
                        <Label Text="Tax Year" Grid.Row="0" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding Session.TaxYear}" Keyboard="Numeric"
                               Grid.Row="0" Grid.Column="1" TextColor="Black" BackgroundColor="#E3F2FD" />

                        <Label Text="Filing Status" Grid.Row="1" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Picker ItemsSource="{Binding Session.FederalStatuses}"
                                SelectedItem="{Binding Session.SelectedFederalPickerItem}"
                                Grid.Row="1" Grid.Column="1" TextColor="Black" />

                        <Label Text="Residence State" Grid.Row="2" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Picker ItemsSource="{Binding Session.StatePickerItems}"
                                SelectedItem="{Binding Session.SelectedStatePickerItem}"
                                Grid.Row="2" Grid.Column="1" TextColor="Black" />

                        <Label Text="Qualifying Children" Grid.Row="3" Grid.Column="0"
                               VerticalTextAlignment="Center" TextColor="#37474F" FontSize="14" />
                        <Entry Text="{Binding Session.QualifyingChildren}" Keyboard="Numeric"
                               Grid.Row="3" Grid.Column="1" TextColor="Black" BackgroundColor="#E3F2FD" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Empty state: nothing computed on the Inputs page yet. -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16"
                    IsVisible="{Binding HasProjection, Converter={StaticResource InvertBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="No projection yet" FontSize="16" FontAttributes="Bold" TextColor="#455A64" />
                    <Label Text="Calculate a paycheck on the Inputs page first — Annual Projection scales that result up to the full year."
                           FontSize="13" TextColor="#607D8B" />
                    <Button Text="Jump to Inputs" Command="{Binding JumpToInputsCommand}"
                            BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold"
                            CornerRadius="8" HorizontalOptions="Start" Margin="0,6,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Projection summary — reuses Projection.* bindings already defined on ResultsPage. -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16"
                    IsVisible="{Binding HasProjection}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Annualized Projection" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />

                    <Grid ColumnDefinitions="*,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Pay periods per year" TextColor="#37474F" FontSize="14" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Projection.PayPeriodsPerYear}" FontAttributes="Bold" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Gross pay" TextColor="#37474F" FontSize="14" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Projection.AnnualizedGrossPay, StringFormat='{0:C}'}" FontAttributes="Bold" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Federal withholding" TextColor="#37474F" FontSize="14" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Projection.AnnualizedFederalWithholding, StringFormat='{0:C}'}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="State withholding" TextColor="#37474F" FontSize="14" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Projection.AnnualizedStateWithholding, StringFormat='{0:C}'}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="FICA" TextColor="#37474F" FontSize="14" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding Projection.AnnualizedFica, StringFormat='{0:C}'}" />

                        <Label Grid.Row="5" Grid.Column="0" Text="Net pay" TextColor="#2E7D32" FontSize="14" FontAttributes="Bold" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding Projection.AnnualizedNetPay, StringFormat='{0:C}'}" TextColor="#2E7D32" FontAttributes="Bold" />

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                    </Grid>

                    <Label Text="{Binding Projection.OverUnderLabel}" FontSize="13" TextColor="#455A64" Margin="0,10,0,0" />
                    <Label Text="{Binding Projection.OverUnderAmount, StringFormat='{0:C}'}" FontSize="18" FontAttributes="Bold" TextColor="#1565C0" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Recompute (re-run Inputs)" Command="{Binding RefreshCommand}"
                    BackgroundColor="#455A64" TextColor="White" FontAttributes="Bold"
                    CornerRadius="8" Margin="0,4,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
