<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             xmlns:vm="clr-namespace:PaycheckCalc.App.ViewModels"
             xmlns:services="clr-namespace:PaycheckCalc.App.Services"
             x:Class="PaycheckCalc.App.Views.CreditsPage"
             x:DataType="vm:CreditsViewModel"
             Title="Credits"
             BackgroundColor="#FAFAFA">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Child Tax Credit (structured) -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Child Tax Credit (Form 8812)" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding Session.UseStructuredChildTaxCredit}" OnColor="#1565C0" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10"
                          IsVisible="{Binding Session.UseStructuredChildTaxCredit}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Qualifying Children (under 17)" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.CtcQualifyingChildren}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Other Dependents" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.CtcOtherDependents}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Earned Income" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Session.CtcEarnedIncome}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Education credits (Form 8863) -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Education Credits (Form 8863)" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding Session.UseStructuredEducationCredits}" OnColor="#1565C0" />
                    </Grid>
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding Session.UseStructuredEducationCredits}">
                        <Button Text="+ Add Student" Command="{Binding AddStudentCommand}"
                                BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold" CornerRadius="8"
                                HorizontalOptions="Start" Padding="12,6" />
                        <CollectionView ItemsSource="{Binding Session.EducationStudents}" EmptyView="No students added.">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="services:EducationStudentItemViewModel">
                                    <Border BackgroundColor="#F5F7FA" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8" Padding="10" Margin="0,0,0,8">
                                        <VerticalStackLayout Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Entry Grid.Column="0" Text="{Binding Name}" Placeholder="Student name"
                                                       BackgroundColor="White" TextColor="Black" />
                                                <Button Grid.Column="1" Text="Remove"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreditsViewModel}}, Path=RemoveStudentCommand}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="#D32F2F" TextColor="White" CornerRadius="6" Padding="10,4" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="Qualified Expenses" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <Entry Grid.Column="1" Text="{Binding QualifiedExpenses}" Keyboard="Numeric"
                                                       BackgroundColor="White" TextColor="Black">
                                                    <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                                                </Entry>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="Claim AOTC" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <CheckBox Grid.Column="1" IsChecked="{Binding ClaimAmericanOpportunityCredit}" Color="#1565C0" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="Claim LLC" TextColor="#37474F" FontSize="13"
                                                       VerticalTextAlignment="Center" />
                                                <CheckBox Grid.Column="1" IsChecked="{Binding ClaimLifetimeLearningCredit}" Color="#1565C0" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Saver's Credit (Form 8880) -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Saver's Credit (Form 8880)" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding Session.UseStructuredSaversCredit}" OnColor="#1565C0" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10"
                          IsVisible="{Binding Session.UseStructuredSaversCredit}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Taxpayer Contributions" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.SaversTaxpayerContributions}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="1" Grid.Column="0" Text="Spouse Contributions (MFJ)" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.SaversSpouseContributions}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- NIIT (Form 8960) -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Net Investment Income Tax (Form 8960)" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding Session.UseStructuredNiit}" OnColor="#1565C0" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10"
                          IsVisible="{Binding Session.UseStructuredNiit}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Net Investment Income" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.NiitNetInvestmentIncome}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="1" Grid.Column="0" Text="MAGI Override (optional)" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.NiitModifiedAgiOverride}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Legacy pre-computed lump sums -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Pre-computed Credit Totals (optional)" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Nonrefundable Credits" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.NonrefundableCredits}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="1" Grid.Column="0" Text="Refundable Credits" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.RefundableCredits}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="2" Grid.Column="0" Text="CTC (lump sum)" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Session.PrecomputedChildTaxCredit}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
