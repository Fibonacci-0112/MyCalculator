<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaycheckCalc.App.Views.SelfEmploymentResultsPage"
             Title="SE Results"
             BackgroundColor="#FAFAFA">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#00695C" Padding="16,20,16,20">
            <Label Text="Self-Employment Tax Summary"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <!-- Tab bar: Tax Breakdown / Quarterly Estimates -->
        <Grid Grid.Row="1" BackgroundColor="#00897B" Padding="10,8,10,8"
              ColumnDefinitions="*,*" ColumnSpacing="6">
            <Border Grid.Column="0" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab0Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab0Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectResultTabCommand}" CommandParameter="0" />
                </Border.GestureRecognizers>
                <Label Text="Tax Breakdown" Padding="4,8"
                       FontSize="13" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab0Visible}" Value="True">
                            <Setter Property="TextColor" Value="#00695C" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab0Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
            <Border Grid.Column="1" StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab1Visible}" Value="True">
                        <Setter Property="BackgroundColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsResultTab1Visible}" Value="False">
                        <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectResultTabCommand}" CommandParameter="1" />
                </Border.GestureRecognizers>
                <Label Text="Estimates" Padding="4,8"
                       FontSize="13" FontAttributes="Bold"
                       HorizontalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab1Visible}" Value="True">
                            <Setter Property="TextColor" Value="#00695C" />
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsResultTab1Visible}" Value="False">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </Grid>

        <!-- Tax Breakdown tab (0) -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsResultTab0Visible}">
            <VerticalStackLayout Padding="16" Spacing="10"
                                 BindingContext="{Binding ResultModel}">

                <!-- Schedule C -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Schedule C — Net Profit" FontSize="15" FontAttributes="Bold"
                               TextColor="#00695C" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                            <Label Text="Gross Revenue" Grid.Row="0" TextColor="#37474F" />
                            <Label Text="{Binding GrossRevenue, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1" TextColor="Black" />
                            <Label Text="Cost of Goods Sold" Grid.Row="1" TextColor="#37474F"
                                   IsVisible="{Binding ShowCogs}" />
                            <Label Text="{Binding CostOfGoodsSold, StringFormat='{0:C}'}" Grid.Row="1" Grid.Column="1"
                                   TextColor="Black" IsVisible="{Binding ShowCogs}" />
                            <Label Text="Business Expenses" Grid.Row="2" TextColor="#37474F" />
                            <Label Text="{Binding TotalExpenses, StringFormat='{0:C}'}" Grid.Row="2" Grid.Column="1" TextColor="Black" />
                            <Label Text="Net Profit" Grid.Row="3" TextColor="#00695C" FontAttributes="Bold" />
                            <Label Text="{Binding NetProfit, StringFormat='{0:C}'}" Grid.Row="3" Grid.Column="1"
                                   TextColor="#00695C" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- SE Tax -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Self-Employment Tax" FontSize="15" FontAttributes="Bold"
                               TextColor="#E65100" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />

                        <!-- W-2 FICA coordination note (shown only when W-2 wages were entered) -->
                        <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowW2Wages}">
                            <Label Text="W-2 FICA Coordination" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1565C0" />
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                                <Label Text="W-2 SS Wages (Box 3)" Grid.Row="0" TextColor="#546E7A" FontSize="13" />
                                <Label Text="{Binding W2SocialSecurityWages, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1"
                                       TextColor="#546E7A" FontSize="13" />
                                <Label Text="W-2 Medicare Wages (Box 5)" Grid.Row="1" TextColor="#546E7A" FontSize="13" />
                                <Label Text="{Binding W2MedicareWages, StringFormat='{0:C}'}" Grid.Row="1" Grid.Column="1"
                                       TextColor="#546E7A" FontSize="13" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                            <Label Text="SE Taxable (92.35%)" Grid.Row="0" TextColor="#37474F" />
                            <Label Text="{Binding SeTaxableEarnings, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1" TextColor="Black" />
                            <Label Text="Social Security (12.4%)" Grid.Row="1" TextColor="#37474F" />
                            <Label Text="{Binding SocialSecurityTax, StringFormat='{0:C}'}" Grid.Row="1" Grid.Column="1" TextColor="Black" />
                            <Label Text="Medicare (2.9%)" Grid.Row="2" TextColor="#37474F" />
                            <Label Text="{Binding MedicareTax, StringFormat='{0:C}'}" Grid.Row="2" Grid.Column="1" TextColor="Black" />
                            <Label Text="Addl. Medicare (0.9%)" Grid.Row="3" TextColor="#37474F"
                                   IsVisible="{Binding ShowAdditionalMedicare}" />
                            <Label Text="{Binding AdditionalMedicareTax, StringFormat='{0:C}'}" Grid.Row="3" Grid.Column="1"
                                   TextColor="Black" IsVisible="{Binding ShowAdditionalMedicare}" />
                            <Label Text="Total SE Tax" Grid.Row="4" TextColor="#E65100" FontAttributes="Bold" />
                            <Label Text="{Binding TotalSeTax, StringFormat='{0:C}'}" Grid.Row="4" Grid.Column="1"
                                   TextColor="#E65100" FontAttributes="Bold" />
                            <Label Text="Deductible Half" Grid.Row="5" TextColor="#78909C" FontSize="13" />
                            <Label Text="{Binding DeductibleHalfOfSeTax, StringFormat='{0:C}'}" Grid.Row="5" Grid.Column="1"
                                   TextColor="#78909C" FontSize="13" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Income Tax -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Income Tax" FontSize="15" FontAttributes="Bold"
                               TextColor="#3949AB" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                            <Label Text="Adjusted Gross Income" Grid.Row="0" TextColor="#37474F" />
                            <Label Text="{Binding AdjustedGrossIncome, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1" TextColor="Black" />
                            <Label Text="Standard Deduction" Grid.Row="1" TextColor="#37474F" />
                            <Label Text="{Binding StandardDeduction, StringFormat='{0:C}'}" Grid.Row="1" Grid.Column="1" TextColor="Black" />
                            <Label Text="QBI Deduction (§199A)" Grid.Row="2" TextColor="#37474F"
                                   IsVisible="{Binding ShowQbi}" />
                            <Label Text="{Binding QbiDeduction, StringFormat='{0:C}'}" Grid.Row="2" Grid.Column="1"
                                   TextColor="Black" IsVisible="{Binding ShowQbi}" />
                            <Label Text="Taxable Income" Grid.Row="3" TextColor="#37474F" FontAttributes="Bold" />
                            <Label Text="{Binding TaxableIncome, StringFormat='{0:C}'}" Grid.Row="3" Grid.Column="1"
                                   TextColor="Black" FontAttributes="Bold" />
                            <Label Text="Federal Income Tax" Grid.Row="4" TextColor="#37474F" />
                            <Label Text="{Binding FederalIncomeTax, StringFormat='{0:C}'}" Grid.Row="4" Grid.Column="1" TextColor="Black" />
                            <Label Text="{Binding StateName, StringFormat='State Tax ({0})'}" Grid.Row="5" TextColor="#37474F"
                                   IsVisible="{Binding ShowStateTax}" />
                            <Label Text="{Binding StateIncomeTax, StringFormat='{0:C}'}" Grid.Row="5" Grid.Column="1"
                                   TextColor="Black" IsVisible="{Binding ShowStateTax}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Total Summary -->
                <Border BackgroundColor="#E8F5E9" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Summary" FontSize="15" FontAttributes="Bold"
                               TextColor="#2E7D32" />
                        <BoxView HeightRequest="1" Color="#C8E6C9" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                            <Label Text="Total Federal Tax" Grid.Row="0" TextColor="#37474F" />
                            <Label Text="{Binding TotalFederalTax, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1" TextColor="Black" />
                            <Label Text="Total State Tax" Grid.Row="1" TextColor="#37474F" />
                            <Label Text="{Binding TotalStateTax, StringFormat='{0:C}'}" Grid.Row="1" Grid.Column="1" TextColor="Black" />
                            <Label Text="Total Tax" Grid.Row="2" TextColor="#D32F2F" FontAttributes="Bold" FontSize="16" />
                            <Label Text="{Binding TotalTax, StringFormat='{0:C}'}" Grid.Row="2" Grid.Column="1"
                                   TextColor="#D32F2F" FontAttributes="Bold" FontSize="16" />
                            <Label Text="Effective Tax Rate" Grid.Row="3" TextColor="#78909C" />
                            <Label Text="{Binding EffectiveTaxRateFormatted}" Grid.Row="3" Grid.Column="1"
                                   TextColor="#78909C" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Export buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0"
                      IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.HasResult}">
                    <Button Text="Export CSV" Grid.Column="0"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportCsvCommand}"
                            BackgroundColor="#00897B" TextColor="White"
                            FontAttributes="Bold" CornerRadius="8" />
                    <Button Text="Export PDF" Grid.Column="1"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ExportPdfCommand}"
                            BackgroundColor="#00695C" TextColor="White"
                            FontAttributes="Bold" CornerRadius="8" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Estimates tab (1) -->
        <ScrollView Grid.Row="2" IsVisible="{Binding IsResultTab1Visible}">
            <VerticalStackLayout Padding="16" Spacing="10"
                                 BindingContext="{Binding ResultModel}">

                <!-- Quarterly Payments -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Quarterly Estimated Payments" FontSize="15" FontAttributes="Bold"
                               TextColor="#00695C" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Label Text="Form 1040-ES — pay by Apr 15, Jun 15, Sep 15, Jan 15"
                               TextColor="#78909C" FontSize="12" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10" Margin="0,8,0,0">
                            <Label Text="Each Quarterly Payment" Grid.Row="0" TextColor="#37474F" FontAttributes="Bold" FontSize="16" />
                            <Label Text="{Binding EstimatedQuarterlyPayment, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1"
                                   TextColor="#00695C" FontAttributes="Bold" FontSize="16" />
                            <Label Text="Annual Tax Liability" Grid.Row="1" TextColor="#37474F" />
                            <Label Text="{Binding TotalTax, StringFormat='{0:C}'}" Grid.Row="1" Grid.Column="1" TextColor="Black" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Over/Under Payment -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16"
                        IsVisible="{Binding ShowOverUnder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding OverUnderLabel}" FontSize="15" FontAttributes="Bold"
                               TextColor="#E65100" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Label Text="{Binding OverUnderAbsolute, StringFormat='{0:C}'}"
                               TextColor="#E65100" FontAttributes="Bold" FontSize="20"
                               HorizontalTextAlignment="Center" Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
