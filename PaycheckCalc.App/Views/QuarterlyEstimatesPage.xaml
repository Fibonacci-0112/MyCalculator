<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             xmlns:models="clr-namespace:PaycheckCalc.App.Models"
             xmlns:vm="clr-namespace:PaycheckCalc.App.ViewModels"
             x:Class="PaycheckCalc.App.Views.QuarterlyEstimatesPage"
             x:DataType="vm:QuarterlyEstimatesViewModel"
             Title="Quarterly Estimates"
             BackgroundColor="#FAFAFA">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Inputs -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Form 1040-ES Worksheet" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Override projected total tax?" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding UseProjectedTotalTaxOverride}" OnColor="#1565C0" />
                    </Grid>
                    <Entry Text="{Binding ProjectedTotalTaxOverride}" Keyboard="Numeric"
                           BackgroundColor="#EEF2FF" TextColor="Black"
                           IsVisible="{Binding UseProjectedTotalTaxOverride}">
                        <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                    </Entry>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Override expected withholding?" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding UseExpectedWithholdingOverride}" OnColor="#1565C0" />
                    </Grid>
                    <Entry Text="{Binding ExpectedWithholdingOverride}" Keyboard="Numeric"
                           BackgroundColor="#EEF2FF" TextColor="Black"
                           IsVisible="{Binding UseExpectedWithholdingOverride}">
                        <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                    </Entry>

                    <Label Text="Additional Expected Withholding (annual)" TextColor="#37474F" FontSize="13" />
                    <Entry Text="{Binding Session.AdditionalExpectedWithholding}" Keyboard="Numeric"
                           BackgroundColor="#EEF2FF" TextColor="Black">
                        <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                    </Entry>
                </VerticalStackLayout>
            </Border>

            <!-- Prior-year safe harbor -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Use Prior-Year Safe Harbor" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding Session.UsePriorYearSafeHarbor}" OnColor="#1565C0" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10"
                          IsVisible="{Binding Session.UsePriorYearSafeHarbor}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Prior-Year Total Tax" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Session.PriorYearTotalTax}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="1" Grid.Column="0" Text="Prior-Year AGI" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Session.PriorYearAdjustedGrossIncome}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="2" Grid.Column="0" Text="Prior year was a full 12 months?" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding Session.PriorYearWasFullYear}" Color="#1565C0" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button Text="Calculate Quarterly Estimates" Command="{Binding CalculateCommand}"
                    BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold"
                    CornerRadius="8" />

            <!-- Result card -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16"
                    IsVisible="{Binding HasResult}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding Result.StatusLabel}" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Tax Year" TextColor="#37474F" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Result.TaxYear}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Projected Tax (CY)" TextColor="#37474F" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Result.CurrentYearProjectedTax, StringFormat='{0:C}'}" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Expected Withholding" TextColor="#37474F" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Result.ExpectedWithholding, StringFormat='{0:C}'}" />
                        <Label Grid.Row="3" Grid.Column="0" Text="Safe Harbor Basis" TextColor="#37474F" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Result.SafeHarborBasisDisplay}" FontAttributes="Bold" />
                        <Label Grid.Row="4" Grid.Column="0" Text="Required Annual Payment" TextColor="#37474F" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding Result.RequiredAnnualPayment, StringFormat='{0:C}'}" FontAttributes="Bold" />
                    </Grid>

                    <Label Text="Quarterly Installments" FontSize="14" FontAttributes="Bold" TextColor="#455A64" Margin="0,8,0,0" />
                    <CollectionView ItemsSource="{Binding Result.Installments}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:QuarterlyEstimateRowModel">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4"
                                      ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="{Binding Period}" FontAttributes="Bold" TextColor="#1565C0" />
                                    <Label Grid.Column="1" Text="{Binding DueDateDisplay}" TextColor="#37474F" />
                                    <Label Grid.Column="2" Text="{Binding Amount, StringFormat='{0:C}'}" FontAttributes="Bold" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
