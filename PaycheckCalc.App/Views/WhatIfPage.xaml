<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             xmlns:models="clr-namespace:PaycheckCalc.App.Models"
             xmlns:vm="clr-namespace:PaycheckCalc.App.ViewModels"
             x:Class="PaycheckCalc.App.Views.WhatIfPage"
             x:DataType="vm:WhatIfViewModel"
             Title="What-If"
             BackgroundColor="#FAFAFA">
    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Baseline snapshot -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Baseline" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Button Grid.Column="1" Text="Capture Baseline" Command="{Binding CaptureBaselineCommand}"
                                BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold" CornerRadius="8"
                                Padding="12,6" />
                    </Grid>
                    <Label Text="Baseline not yet captured. Tap Capture Baseline to snapshot the current Annual Tax inputs and result."
                           TextColor="#78909C" FontSize="13"
                           IsVisible="{Binding HasBaseline, Converter={StaticResource InvertBoolConverter}}" />
                    <Grid ColumnDefinitions="*,Auto" RowSpacing="4" IsVisible="{Binding HasBaseline}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="AGI" TextColor="#37474F" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Baseline.AdjustedGrossIncome, StringFormat='{0:C}'}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Total Tax" TextColor="#37474F" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Baseline.TotalTax, StringFormat='{0:C}'}" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Refund / (Owe)" TextColor="#37474F" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Baseline.RefundOrOwe, StringFormat='{0:C}'}" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Variant editor -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Variant Deltas" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Filing Status" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Picker Grid.Row="0" Grid.Column="1" ItemsSource="{Binding FederalStatuses}"
                                SelectedItem="{Binding VariantFilingStatusPickerItem}" TextColor="Black" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Residence State" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Picker Grid.Row="1" Grid.Column="1" ItemsSource="{Binding StatePickerItems}"
                                SelectedItem="{Binding VariantStatePickerItem}" TextColor="Black" />
                        <Label Grid.Row="2" Grid.Column="0" Text="Additional Pre-Tax 401(k)" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="2" Grid.Column="1" Text="{Binding VariantAdditionalPreTax401k}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="3" Grid.Column="0" Text="Extra Federal Withholding" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="3" Grid.Column="1" Text="{Binding VariantAdditionalExpectedWithholding}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black">
                            <Entry.Behaviors><behaviors:DecimalFormatBehavior IsCurrency="True" /></Entry.Behaviors>
                        </Entry>
                        <Label Grid.Row="4" Grid.Column="0" Text="CTC Qualifying Children Δ" TextColor="#37474F" VerticalTextAlignment="Center" />
                        <Entry Grid.Row="4" Grid.Column="1" Text="{Binding VariantQualifyingChildrenDelta}" Keyboard="Numeric"
                               BackgroundColor="#EEF2FF" TextColor="Black" />
                    </Grid>

                    <Button Text="Run What-If" Command="{Binding RunVariantCommand}"
                            BackgroundColor="#2E7D32" TextColor="White" FontAttributes="Bold"
                            CornerRadius="8" Margin="0,6,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Side-by-side comparison -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="16"
                    IsVisible="{Binding HasVariant}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Comparison" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,*,*,*" Padding="0,0,0,6">
                        <Label Grid.Column="0" Text="Metric" FontAttributes="Bold" TextColor="#455A64" />
                        <Label Grid.Column="1" Text="{Binding Comparison.BaselineLabel}" FontAttributes="Bold" TextColor="#1565C0" HorizontalTextAlignment="End" />
                        <Label Grid.Column="2" Text="{Binding Comparison.VariantLabel}" FontAttributes="Bold" TextColor="#2E7D32" HorizontalTextAlignment="End" />
                        <Label Grid.Column="3" Text="Δ" FontAttributes="Bold" TextColor="#455A64" HorizontalTextAlignment="End" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding Comparison.Rows}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WhatIfRowModel">
                                <Grid ColumnDefinitions="*,*,*,*" Padding="0,3">
                                    <Label Grid.Column="0" Text="{Binding Label}" TextColor="#37474F" />
                                    <Label Grid.Column="1" Text="{Binding Baseline, StringFormat='{0:C}'}" HorizontalTextAlignment="End" TextColor="#1565C0" />
                                    <Label Grid.Column="2" Text="{Binding Variant, StringFormat='{0:C}'}" HorizontalTextAlignment="End" TextColor="#2E7D32" />
                                    <Label Grid.Column="3" Text="{Binding DeltaFormatted}" HorizontalTextAlignment="End" FontAttributes="Bold" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
