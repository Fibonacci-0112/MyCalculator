<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PaycheckCalc.App.Behaviors"
             xmlns:vm="clr-namespace:PaycheckCalc.App.ViewModels"
             x:Class="PaycheckCalc.App.Views.JobsAndYtdPage"
             x:DataType="vm:JobsAndYtdViewModel"
             Title="Jobs &amp; YTD"
             BackgroundColor="#FAFAFA">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- YTD rollup summary -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="YTD Totals Across W-2 Jobs" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                    <Grid ColumnDefinitions="*,Auto" RowSpacing="4" IsVisible="{Binding Summary.HasJobs, FallbackValue=False}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Text="Box 1 Wages" TextColor="#37474F" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding Summary.TotalBox1Wages, StringFormat='{0:C}'}" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="0" Text="Federal Withholding" TextColor="#37474F" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding Summary.TotalFederalWithholding, StringFormat='{0:C}'}" />
                        <Label Grid.Row="2" Grid.Column="0" Text="SS + Medicare Tax" TextColor="#37474F" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding Summary.TotalFicaTax, StringFormat='{0:C}'}" />
                        <Label Grid.Row="3" Grid.Column="0" Text="State Wages" TextColor="#37474F" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding Summary.TotalStateWages, StringFormat='{0:C}'}" />
                        <Label Grid.Row="4" Grid.Column="0" Text="State Withholding" TextColor="#37474F" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding Summary.TotalStateWithholding, StringFormat='{0:C}'}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Jobs list -->
            <Border BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="W-2 Jobs" FontSize="15" FontAttributes="Bold" TextColor="#1565C0"
                               VerticalTextAlignment="Center" />
                        <Button Grid.Column="1" Text="+ Add Job" Command="{Binding AddW2JobCommand}"
                                BackgroundColor="#1565C0" TextColor="White" FontAttributes="Bold" CornerRadius="8"
                                Padding="12,6" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding Session.W2Jobs}" EmptyView="No W-2 jobs yet.">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:W2JobItemViewModel">
                                <Border BackgroundColor="#F5F7FA" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8" Padding="10" Margin="0,0,0,8">
                                    <VerticalStackLayout Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <Entry Grid.Column="0" Text="{Binding Name}" Placeholder="Employer name"
                                                   BackgroundColor="White" TextColor="Black" />
                                            <Button Grid.Column="1" Text="Remove"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobsAndYtdViewModel}}, Path=RemoveW2JobCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#D32F2F" TextColor="White" CornerRadius="6" Padding="10,4" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto"
                                              ColumnSpacing="8" RowSpacing="6">
                                            <Label Grid.Row="0" Grid.Column="0" Text="Box 1 (Wages)" TextColor="#37474F" FontSize="13" />
                                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding WagesBox1}" Keyboard="Numeric"
                                                   BackgroundColor="White" TextColor="Black">
                                                <Entry.Behaviors>
                                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                            <Label Grid.Row="1" Grid.Column="0" Text="Box 2 (Fed WH)" TextColor="#37474F" FontSize="13" />
                                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding FederalWithholdingBox2}" Keyboard="Numeric"
                                                   BackgroundColor="White" TextColor="Black">
                                                <Entry.Behaviors>
                                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                            <Label Grid.Row="2" Grid.Column="0" Text="Box 3 (SS Wages)" TextColor="#37474F" FontSize="13" />
                                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding SocialSecurityWagesBox3}" Keyboard="Numeric"
                                                   BackgroundColor="White" TextColor="Black">
                                                <Entry.Behaviors>
                                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                            <Label Grid.Row="3" Grid.Column="0" Text="Box 4 (SS Tax)" TextColor="#37474F" FontSize="13" />
                                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding SocialSecurityTaxBox4}" Keyboard="Numeric"
                                                   BackgroundColor="White" TextColor="Black">
                                                <Entry.Behaviors>
                                                    <behaviors:DecimalFormatBehavior IsCurrency="True" />
                                                </Entry.Behaviors>
                                            </Entry>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="Spouse's job?" TextColor="#37474F" FontSize="13"
                                                   VerticalTextAlignment="Center" />
                                            <CheckBox Grid.Column="1" IsChecked="{Binding IsSpouse}" Color="#1565C0" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="Refresh Summary" Command="{Binding RebuildSummaryCommand}"
                            BackgroundColor="#455A64" TextColor="White" FontAttributes="Bold" CornerRadius="8" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
