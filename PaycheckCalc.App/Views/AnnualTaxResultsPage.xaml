<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             x:Class="PaycheckCalc.App.Views.AnnualTaxResultsPage"
             Title="Annual Results"
             BackgroundColor="#FAFAFA">

    <ContentPage.Resources>
        <helpers:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Page header -->
        <Grid Grid.Row="0" BackgroundColor="#0D47A1" Padding="16,20,16,20">
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="Annual Form 1040 Summary"
                       TextColor="White"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Label Text="{Binding ResultModel.TaxYear, StringFormat='Tax Year {0}'}"
                       TextColor="#BBDEFB"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="12"
                                 IsVisible="{Binding HasResult}">

                <!-- Refund / Owe summary -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="18">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="{Binding ResultModel.RefundOrOweLabel}"
                               FontSize="15" TextColor="#455A64"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding ResultModel.RefundOrOweAbsolute, StringFormat='${0:N2}'}"
                               FontSize="34" FontAttributes="Bold"
                               HorizontalTextAlignment="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding ResultModel.IsRefund}" Value="True">
                                    <Setter Property="TextColor" Value="#2E7D32" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding ResultModel.IsBalanceDue}" Value="True">
                                    <Setter Property="TextColor" Value="#C62828" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="{Binding ResultModel.FilingStatusDisplay}"
                               FontSize="12" TextColor="#78909C"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Federal breakdown -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Federal Income Tax"
                               FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />

                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Total W-2 Wages" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.TotalW2Wages, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                              IsVisible="{Binding ResultModel.ShowScheduleC}">
                            <Label Text="Schedule C Net Profit" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.ScheduleCNetProfit, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Other Income" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.AdditionalIncome, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Adjustments to Income" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.TotalAdjustments, StringFormat='-${0:N2}'}"
                                   TextColor="#B71C1C" FontSize="13" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Adjusted Gross Income" TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.AdjustedGrossIncome, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" FontAttributes="Bold" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Standard Deduction" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.StandardDeduction, StringFormat='-${0:N2}'}"
                                   TextColor="#B71C1C" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                              IsVisible="{Binding ResultModel.ShowQbi}">
                            <Label Text="QBI Deduction" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.QbiDeduction, StringFormat='-${0:N2}'}"
                                   TextColor="#B71C1C" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Taxable Income" TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.TaxableIncome, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" FontAttributes="Bold" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Income Tax (Before Credits)" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.IncomeTaxBeforeCredits, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                              IsVisible="{Binding ResultModel.ShowCtc}">
                            <Label Text="Child Tax Credit" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.ChildTaxCredit, StringFormat='-${0:N2}'}"
                                   TextColor="#2E7D32" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                              IsVisible="{Binding ResultModel.ShowEducationCredits}">
                            <Label Text="Education Credits" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.EducationCreditsNonrefundable, StringFormat='-${0:N2}'}"
                                   TextColor="#2E7D32" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                              IsVisible="{Binding ResultModel.ShowSaversCredit}">
                            <Label Text="Saver's Credit" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.SaversCredit, StringFormat='-${0:N2}'}"
                                   TextColor="#2E7D32" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Income Tax (After Credits)" TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.IncomeTaxAfterCredits, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" FontAttributes="Bold" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4"
                              IsVisible="{Binding ResultModel.SelfEmploymentTax, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Self-Employment Tax" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.SelfEmploymentTax, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <Label Text="Total Tax" TextColor="#37474F" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.TotalTax, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="14" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Federal payments -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Federal Payments" FontSize="15" FontAttributes="Bold" TextColor="#1565C0" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="W-2 Federal Withholding" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.FederalWithholdingFromW2s, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding ResultModel.EstimatedTaxPayments, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Estimated Tax Payments" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.EstimatedTaxPayments, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding ResultModel.ShowExcessSsCredit}">
                            <Label Text="Excess Social Security Credit" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.ExcessSocialSecurityCredit, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding ResultModel.RefundableCredits, Converter={StaticResource GreaterThanZeroConverter}}">
                            <Label Text="Refundable Credits" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.RefundableCredits, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding ResultModel.ShowAdditionalCtc}">
                            <Label Text="Additional Child Tax Credit" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.RefundableAdditionalChildTaxCredit, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total Payments" TextColor="#37474F" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.TotalPayments, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="14" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- State tax section -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16"
                        IsVisible="{Binding ResultModel.ShowStateSection}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding ResultModel.StateName, StringFormat='State Tax — {0}'}"
                               FontSize="15" FontAttributes="Bold" TextColor="#3949AB" />
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="State Taxable Wages" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.StateWages, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Estimated State Income Tax" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.StateIncomeTax, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding ResultModel.ShowStateDisability}">
                            <Label Text="{Binding ResultModel.StateDisabilityInsuranceLabel}" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.StateDisabilityInsurance, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="State Tax Withheld (Box 17)" TextColor="#37474F" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.StateTaxWithheld, StringFormat='${0:N2}'}"
                                   TextColor="Black" FontSize="13" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E0E0E0" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding ResultModel.StateRefundOrOweLabel}" TextColor="#37474F" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="{Binding ResultModel.StateRefundOrOweAbsolute, StringFormat='${0:N2}'}"
                                   FontSize="14" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding ResultModel.IsStateRefund}" Value="True">
                                        <Setter Property="TextColor" Value="#2E7D32" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ResultModel.IsStateBalanceDue}" Value="True">
                                        <Setter Property="TextColor" Value="#C62828" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Rates -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Grid ColumnDefinitions="*,*" RowSpacing="4">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="Effective Rate" TextColor="#78909C" FontSize="12"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding ResultModel.EffectiveTaxRateFormatted}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#1565C0"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="Marginal Rate" TextColor="#78909C" FontSize="12"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding ResultModel.MarginalTaxRateFormatted}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#1565C0"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Empty state -->
        <Label Grid.Row="1"
               IsVisible="{Binding HasResult, Converter={StaticResource InvertBoolConverter}}"
               Text="Run a calculation from the Annual Tax page to see your federal and state summary here."
               TextColor="#78909C" FontSize="13"
               Padding="24"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center" />
    </Grid>
</ContentPage>
