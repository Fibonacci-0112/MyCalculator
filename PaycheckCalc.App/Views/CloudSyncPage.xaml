<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PaycheckCalc.App.ViewModels"
             x:Class="PaycheckCalc.App.Views.CloudSyncPage"
             x:DataType="vm:CloudSyncViewModel"
             Title="Cloud Sync"
             BackgroundColor="#F0F4FF">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <Label Text="Cloud Sync Settings"
                   TextColor="#0D47A1"
                   FontSize="26"
                   FontAttributes="Bold" />

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <!-- Enable toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Enable Azure Cosmos DB Sync"
                                   TextColor="#37474F"
                                   FontSize="15"
                                   FontAttributes="Bold" />
                            <Label Text="Sync saved paychecks across devices."
                                   TextColor="#78909C"
                                   FontSize="12" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsCloudSyncEnabled}"
                                OnColor="#1565C0"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="#E3F2FD"
                             IsVisible="{Binding IsCloudSyncEnabled}" />

                    <!-- Connection string -->
                    <VerticalStackLayout Spacing="6"
                                         IsVisible="{Binding IsCloudSyncEnabled}">
                        <Label Text="Connection String"
                               TextColor="#546E7A"
                               FontSize="13" />
                        <Entry Text="{Binding ConnectionString}"
                               Placeholder="AccountEndpoint=https://..."
                               IsPassword="true"
                               BackgroundColor="#F8F9FA" />
                    </VerticalStackLayout>

                    <!-- Sync token display -->
                    <VerticalStackLayout Spacing="6"
                                         IsVisible="{Binding IsCloudSyncEnabled}">
                        <Label Text="Sync Token"
                               TextColor="#546E7A"
                               FontSize="13" />
                        <Label Text="Share this token with another device to access the same data."
                               TextColor="#78909C"
                               FontSize="11" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="#F0F4FF"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12,8">
                                <Label Text="{Binding SyncToken}"
                                       TextColor="#37474F"
                                       FontSize="12"
                                       LineBreakMode="MiddleTruncation" />
                            </Border>
                            <Button Grid.Column="1"
                                    Text="Copy"
                                    Command="{Binding CopyTokenCommand}"
                                    BackgroundColor="#1565C0"
                                    TextColor="White"
                                    FontSize="12"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    HeightRequest="36" />
                        </Grid>

                        <!-- Import token from another device -->
                        <Label Text="Or import a token from another device:"
                               TextColor="#78909C"
                               FontSize="11"
                               Margin="0,4,0,0" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding TokenInput}"
                                   Placeholder="Paste token here"
                                   BackgroundColor="#F8F9FA" />
                            <Button Grid.Column="1"
                                    Text="Set"
                                    Command="{Binding SetTokenCommand}"
                                    BackgroundColor="#546E7A"
                                    TextColor="White"
                                    FontSize="12"
                                    CornerRadius="8"
                                    Padding="12,6"
                                    HeightRequest="36" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Save button -->
                    <Button Text="Save Settings"
                            Command="{Binding SaveSettingsCommand}"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            Padding="16,10" />

                    <!-- Status feedback -->
                    <Label Text="{Binding StatusMessage}"
                           TextColor="#546E7A"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding HasStatusMessage}" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
