<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaycheckCalc.App.Views.ComparePage"
             Title="Compare"
             BackgroundColor="#F0F4FF">

    <Grid RowDefinitions="Auto,*">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#1565C0" Padding="16,20,16,20">
            <Label Text="Compare Paychecks"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Grid>

        <!-- No saved comparison message -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding HasNoSavedComparison}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="32">
            <Label Text="No Saved Comparison"
                   TextColor="#78909C" FontSize="20" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Go to the Results tab and tap &quot;Save to Compare&quot; to save a set of results, then change your inputs and come back here."
                   TextColor="#90A4AE" FontSize="14"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Comparison content -->
        <ScrollView Grid.Row="1" IsVisible="{Binding HasSavedComparison}">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Column Headers -->
                <Grid ColumnDefinitions="*,*,*" Padding="4,0">
                    <Label Grid.Column="1" Text="Saved"
                           TextColor="#1565C0" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="Current"
                           TextColor="#2E7D32" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                </Grid>

                <!-- Inputs Comparison Card -->
                <Label Text="INPUTS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,0,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <!-- Pay Frequency -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Pay Frequency" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Frequency}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Frequency}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Hourly Rate -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Hourly Rate" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.HourlyRate, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding HourlyRate, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Regular Hours -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Regular Hours" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.RegularHours, StringFormat='{0:F2}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding RegularHours, StringFormat='{0:F2}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Overtime Hours -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Overtime Hours" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.OvertimeHours, StringFormat='{0:F2}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding OvertimeHours, StringFormat='{0:F2}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- OT Multiplier -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="OT Multiplier" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.OvertimeMultiplier, StringFormat='{0:F2}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding OvertimeMultiplier, StringFormat='{0:F2}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Filing Status -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Filing Status" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.FilingStatus}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding FilingStatus}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- State -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="State" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.State}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding SelectedState}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Pre-tax Deductions -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Pre-tax Deductions" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.PretaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding PretaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Post-tax Deductions -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Post-tax Deductions" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.PosttaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding PosttaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Results Comparison -->
                <Label Text="RESULTS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <!-- Gross Pay -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Gross Pay" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.GrossPay, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.GrossPay, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Federal Taxable Income -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Federal Taxable" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.FederalTaxableIncome, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.FederalTaxableIncome, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- State Taxable Wages -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="State Taxable" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.StateTaxableWages, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.StateTaxableWages, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Tax Withholdings Comparison -->
                <Label Text="TAX WITHHOLDINGS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <!-- Federal Tax -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Federal Tax" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.FederalWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.FederalWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Social Security Tax -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Social Security" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.SocialSecurityWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.SocialSecurityWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- Medicare Tax -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Medicare Tax" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.MedicareWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.MedicareWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <!-- State Tax -->
                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="State Tax" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding SavedComparison.Result.StateWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Result.StateWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Net Pay Comparison -->
                <Border BackgroundColor="#2E7D32" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20,14">
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                        <Label Grid.ColumnSpan="3" Text="NET PAY" TextColor="#A5D6A7"
                               FontSize="12" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="1" Text="Saved" TextColor="#A5D6A7"
                               FontSize="11" HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="2" Text="Current" TextColor="#A5D6A7"
                               FontSize="11" HorizontalTextAlignment="Center" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding SavedComparison.Result.NetPay, StringFormat='{0:C}'}"
                               TextColor="White" FontAttributes="Bold" FontSize="22"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="2" Grid.Column="2"
                               Text="{Binding Result.NetPay, StringFormat='{0:C}'}"
                               TextColor="White" FontAttributes="Bold" FontSize="22"
                               HorizontalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Difference card -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Net Pay Difference" TextColor="#37474F" FontSize="15"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" Text="{Binding NetPayDifference, StringFormat='{0:C}'}"
                               TextColor="#37474F" FontAttributes="Bold"
                               FontSize="16" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
