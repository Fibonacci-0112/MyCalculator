<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:PaycheckCalc.App.Helpers"
             xmlns:models="clr-namespace:PaycheckCalc.App.Models"
             x:Class="PaycheckCalc.App.Views.ComparePage"
             Title="Compare"
             BackgroundColor="#F0F4FF">

    <ContentPage.Resources>
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter" />
        <helpers:NonEmptyStringConverter x:Key="NonEmptyStringConverter" />
        <helpers:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Page Header -->
        <Grid Grid.Row="0" BackgroundColor="#1565C0" Padding="16,20,16,20" ColumnDefinitions="*,Auto">
            <Label Text="Compare Paychecks"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Center" />
            <Button Grid.Column="1"
                    Text="Clear"
                    Command="{Binding ClearCompareCommand}"
                    IsVisible="{Binding HasMultiScenarios}"
                    BackgroundColor="#0D47A1" TextColor="White"
                    FontSize="12" FontAttributes="Bold"
                    CornerRadius="8" Padding="12,6" HeightRequest="32" />
        </Grid>

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding ShowEmptyState}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="32">
            <Label Text="No Comparison"
                   TextColor="#78909C" FontSize="20" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Go to Saved Paychecks, tap &quot;Select&quot; and pick 2 or more scenarios to compare side-by-side — or go to the Results tab and tap &quot;Save to Compare&quot;."
                   TextColor="#90A4AE" FontSize="14"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- ── Multi-scenario (N-way) card strip ─────────────────── -->
        <ScrollView Grid.Row="1" Orientation="Vertical"
                    IsVisible="{Binding HasMultiScenarios}">
            <VerticalStackLayout Padding="16,12" Spacing="12">

                <Label Text="SCENARIOS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold" />

                <!-- Horizontal list: one card per scenario -->
                <CollectionView ItemsSource="{Binding Scenarios}"
                                HeightRequest="620">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ScenarioSnapshot">
                            <Border WidthRequest="260"
                                    BackgroundColor="White" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12" Padding="14,12">
                                <VerticalStackLayout Spacing="8">

                                    <!-- Scenario header -->
                                    <Label Text="{Binding Name}"
                                           TextColor="#1565C0" FontSize="15"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation" />

                                    <BoxView HeightRequest="1" Color="#ECEFF1" />

                                    <!-- Inputs section -->
                                    <Label Text="INPUTS" TextColor="#78909C"
                                           FontSize="10" FontAttributes="Bold" />

                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Frequency" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding Frequency}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="State" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding State}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Hourly Rate" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding HourlyRate, StringFormat='{0:C}'}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Reg / OT Hrs" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" FontSize="12" FontAttributes="Bold"
                                               TextColor="#37474F">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding RegularHours, StringFormat='{0:F2}'}" />
                                                    <Span Text=" / " />
                                                    <Span Text="{Binding OvertimeHours, StringFormat='{0:F2}'}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Federal Filing" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding FederalFilingStatusDisplay}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2"
                                          IsVisible="{Binding StateFilingStatusDisplay, Converter={StaticResource NonEmptyStringConverter}}">
                                        <Label Text="State Filing" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding StateFilingStatusDisplay}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2"
                                          IsVisible="{Binding StateAllowancesDisplay, Converter={StaticResource NonEmptyStringConverter}}">
                                        <Label Text="State Allowances" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding StateAllowancesDisplay}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Pre-tax Ded." TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding PretaxDeductions, StringFormat='{0:C}'}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Post-tax Ded." TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding PosttaxDeductions, StringFormat='{0:C}'}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#ECEFF1" />

                                    <!-- Income section -->
                                    <Label Text="INCOME" TextColor="#78909C"
                                           FontSize="10" FontAttributes="Bold" />

                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Gross Pay" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.GrossPay, StringFormat='{0:C}'}"
                                               TextColor="#2E7D32" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Fed Taxable" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.FederalTaxableIncome, StringFormat='{0:C}'}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="State Taxable" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.StateTaxableWages, StringFormat='{0:C}'}"
                                               TextColor="#37474F" FontSize="12" FontAttributes="Bold" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#ECEFF1" />

                                    <!-- Tax withholdings -->
                                    <Label Text="TAX WITHHOLDINGS" TextColor="#78909C"
                                           FontSize="10" FontAttributes="Bold" />

                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Federal" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.FederalWithholding, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Social Security" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.SocialSecurityWithholding, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Medicare" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.MedicareWithholding, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2"
                                          IsVisible="{Binding ResultCard.AdditionalMedicareWithholding, Converter={StaticResource GreaterThanZeroConverter}}">
                                        <Label Text="Addl Medicare" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.AdditionalMedicareWithholding, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="State" TextColor="#37474F" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.StateWithholding, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2"
                                          IsVisible="{Binding ResultCard.ShowStateDisabilityInsurance}">
                                        <Label Text="{Binding ResultCard.StateDisabilityInsuranceLabel}"
                                               TextColor="#37474F" FontSize="12"
                                               LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.StateDisabilityInsurance, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" RowSpacing="2">
                                        <Label Text="Total Taxes" TextColor="#37474F" FontSize="12"
                                               FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding ResultCard.TotalTaxes, StringFormat='{0:C}'}"
                                               TextColor="#C62828" FontSize="12" FontAttributes="Bold" />
                                    </Grid>

                                    <BoxView HeightRequest="1" Color="#ECEFF1" />

                                    <!-- Net pay (hero) -->
                                    <Border BackgroundColor="#2E7D32" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10" Padding="12,10">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="NET PAY" TextColor="#A5D6A7"
                                                   FontSize="10" FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center" />
                                            <Label Text="{Binding ResultCard.NetPay, StringFormat='{0:C}'}"
                                                   TextColor="White" FontAttributes="Bold"
                                                   FontSize="20"
                                                   HorizontalTextAlignment="Center" />
                                        </VerticalStackLayout>
                                    </Border>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Swipe horizontally to see every scenario. Tap &quot;Clear&quot; above to choose a new set."
                       TextColor="#90A4AE" FontSize="11"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,0" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Legacy 1-vs-1 Saved vs Current ──────────────────────── -->
        <ScrollView Grid.Row="1" IsVisible="{Binding HasLegacyCompare}">
            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- Column Headers -->
                <Grid ColumnDefinitions="*,*,*" Padding="4,0">
                    <Label Grid.Column="1" Text="Saved"
                           TextColor="#1565C0" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="Current"
                           TextColor="#2E7D32" FontSize="13" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                </Grid>

                <!-- Inputs Comparison Card -->
                <Label Text="INPUTS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,0,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Pay Frequency" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.Frequency}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.Frequency}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Hourly Rate" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.HourlyRate, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.HourlyRate, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Regular Hours" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.RegularHours, StringFormat='{0:F2}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.RegularHours, StringFormat='{0:F2}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Overtime Hours" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.OvertimeHours, StringFormat='{0:F2}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.OvertimeHours, StringFormat='{0:F2}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="OT Multiplier" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.OvertimeMultiplier, StringFormat='{0:F2}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.OvertimeMultiplier, StringFormat='{0:F2}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="State" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.State}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.SelectedState}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Pre-tax Deductions" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.PretaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.TotalPretaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Post-tax Deductions" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.PosttaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.TotalPosttaxDeductions, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Results Comparison -->
                <Label Text="RESULTS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Gross Pay" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.GrossPay, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.GrossPay, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Federal Taxable" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.FederalTaxableIncome, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.FederalTaxableIncome, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="State Taxable" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.StateTaxableWages, StringFormat='{0:C}'}"
                                   TextColor="#1565C0" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.StateTaxableWages, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Tax Withholdings Comparison -->
                <Label Text="TAX WITHHOLDINGS" TextColor="#78909C"
                       FontSize="11" FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,8">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Federal Tax" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.FederalWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.FederalWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Social Security" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.SocialSecurityWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.SocialSecurityWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="Medicare Tax" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.MedicareWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.MedicareWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#F0F0F0" />

                        <Grid ColumnDefinitions="*,*,*" Padding="0,8">
                            <Label Text="State Tax" TextColor="#37474F" FontSize="13" VerticalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="{Binding Calculator.SavedScenario.ResultCard.StateWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="{Binding Calculator.ResultCard.StateWithholding, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Net Pay Comparison -->
                <Border BackgroundColor="#2E7D32" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16" Padding="20,14">
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                        <Label Grid.ColumnSpan="3" Text="NET PAY" TextColor="#A5D6A7"
                               FontSize="12" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="1" Text="Saved" TextColor="#A5D6A7"
                               FontSize="11" HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="2" Text="Current" TextColor="#A5D6A7"
                               FontSize="11" HorizontalTextAlignment="Center" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding Calculator.SavedScenario.ResultCard.NetPay, StringFormat='{0:C}'}"
                               TextColor="White" FontAttributes="Bold" FontSize="22"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="2" Grid.Column="2"
                               Text="{Binding Calculator.ResultCard.NetPay, StringFormat='{0:C}'}"
                               TextColor="White" FontAttributes="Bold" FontSize="22"
                               HorizontalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Difference card -->
                <Border BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Net Pay Difference" TextColor="#37474F" FontSize="15"
                               VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" Text="{Binding NetPayDifference, StringFormat='{0:C}'}"
                               TextColor="#37474F" FontAttributes="Bold"
                               FontSize="16" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
