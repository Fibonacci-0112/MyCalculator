<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PaycheckCalc.App.Views.DashboardPage"
             Title="Dashboard"
             BackgroundColor="#F0F4FF">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- ── Header ──────────────────────────────────────── -->
            <VerticalStackLayout Spacing="4">
                <Label Text="💰 Dashboard"
                       TextColor="#0D47A1" FontSize="26" FontAttributes="Bold" />
                <Label Text="Quick actions, your most recent paycheck, and year-to-date progress at a glance."
                       TextColor="#78909C" FontSize="13" />
            </VerticalStackLayout>

            <!-- ── Quick Actions ───────────────────────────────── -->
            <Label Text="QUICK ACTIONS"
                   TextColor="#37474F" FontSize="12" FontAttributes="Bold"
                   CharacterSpacing="1" Margin="0,8,0,0" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12">

                <!-- New Paycheck -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NewPaycheckCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📝" FontSize="28" />
                        <Label Text="New Paycheck"
                               TextColor="#0D47A1" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Enter hours, W-4, and deductions to calculate take-home pay."
                               TextColor="#78909C" FontSize="12" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Saved Paychecks -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSavedCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="💾" FontSize="28" />
                        <Label Text="Saved Paychecks"
                               TextColor="#0D47A1" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Reload, rename, or compare paychecks you've saved."
                               TextColor="#78909C" FontSize="12" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Self-Employment -->
                <Border Grid.Row="1" Grid.Column="0"
                        BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSelfEmploymentCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🧾" FontSize="28" />
                        <Label Text="Self-Employment"
                               TextColor="#0D47A1" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Schedule C, SE tax, QBI, and quarterly estimates."
                               TextColor="#78909C" FontSize="12" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Annual Tax Planner -->
                <Border Grid.Row="1" Grid.Column="1"
                        BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAnnualPlannerCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅" FontSize="28" />
                        <Label Text="Annual Tax Planner"
                               TextColor="#0D47A1" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Multi-job income, credits, what-if scenarios, and Form 1040 estimation."
                               TextColor="#78909C" FontSize="12" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ── Empty state ────────────────────────────────── -->
            <Border IsVisible="{Binding IsEmpty}"
                    BackgroundColor="White" StrokeThickness="1" Stroke="#90CAF9"
                    StrokeShape="RoundRectangle 12" Padding="24" Margin="0,8,0,0">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="👋" FontSize="40" HorizontalTextAlignment="Center" />
                    <Label Text="Welcome to PaycheckCalc"
                           TextColor="#0D47A1" FontSize="20" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    <Label Text="You haven't saved a paycheck yet. Start one now and we'll begin tracking your YTD progress automatically."
                           TextColor="#78909C" FontSize="13"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Start your first paycheck →"
                            Command="{Binding NewPaycheckCommand}"
                            BackgroundColor="#1565C0" TextColor="White"
                            FontSize="14" FontAttributes="Bold"
                            CornerRadius="10" Padding="20,10" Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- ── Previous Paycheck ──────────────────────────── -->
            <Label Text="PREVIOUS PAYCHECK"
                   IsVisible="{Binding HasContent}"
                   TextColor="#37474F" FontSize="12" FontAttributes="Bold"
                   CharacterSpacing="1" Margin="0,8,0,0" />

            <Border IsVisible="{Binding HasContent}"
                    BackgroundColor="White" StrokeThickness="0"
                    StrokeShape="RoundRectangle 12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding LatestName}"
                               TextColor="#0D47A1" FontSize="18" FontAttributes="Bold"
                               LineBreakMode="TailTruncation" />
                        <Label Grid.Row="1" Grid.Column="0"
                               TextColor="#78909C" FontSize="12">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding LatestStateName}" />
                                    <Span Text=" · Saved " />
                                    <Span Text="{Binding LatestUpdatedAtDisplay}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Button Grid.RowSpan="2" Grid.Column="1"
                                Text="Load →"
                                Command="{Binding LoadLatestIntoCalculatorCommand}"
                                BackgroundColor="#1565C0" TextColor="White"
                                FontSize="13" FontAttributes="Bold"
                                CornerRadius="10" Padding="14,8" VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                          ColumnSpacing="8" RowSpacing="8">
                        <Border Grid.Row="0" Grid.Column="0"
                                BackgroundColor="#F0F4FF" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8" Padding="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="GROSS" TextColor="#78909C" FontSize="10" CharacterSpacing="1" />
                                <Label Text="{Binding LatestResult.GrossPay, StringFormat='{0:C}'}"
                                       TextColor="#37474F" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1"
                                BackgroundColor="#F0F4FF" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8" Padding="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="FEDERAL" TextColor="#78909C" FontSize="10" CharacterSpacing="1" />
                                <Label Text="{Binding LatestResult.FederalWithholding, StringFormat='-{0:C}'}"
                                       TextColor="#C62828" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0"
                                BackgroundColor="#F0F4FF" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8" Padding="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="STATE" TextColor="#78909C" FontSize="10" CharacterSpacing="1" />
                                <Label Text="{Binding LatestResult.StateWithholding, StringFormat='-{0:C}'}"
                                       TextColor="#C62828" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1"
                                BackgroundColor="#F0F4FF" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8" Padding="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="FICA" TextColor="#78909C" FontSize="10" CharacterSpacing="1" />
                                <Label Text="{Binding LatestFica, StringFormat='-{0:C}'}"
                                       TextColor="#C62828" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Padding="0,8,0,0">
                        <BoxView Grid.ColumnSpan="2" HeightRequest="1" BackgroundColor="#E3F2FD"
                                 VerticalOptions="Start" />
                        <Label Grid.Column="0" Text="Net Pay"
                               TextColor="#37474F" FontSize="15"
                               VerticalTextAlignment="Center" Margin="0,8,0,0" />
                        <Label Grid.Column="1"
                               Text="{Binding LatestResult.NetPay, StringFormat='{0:C}'}"
                               TextColor="#2E7D32" FontSize="22" FontAttributes="Bold"
                               Margin="0,8,0,0" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── Year-to-Date ───────────────────────────────── -->
            <Label IsVisible="{Binding HasContent}"
                   TextColor="#37474F" FontSize="12" FontAttributes="Bold"
                   CharacterSpacing="1" Margin="0,8,0,0">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="YEAR-TO-DATE — " />
                        <Span Text="{Binding YtdYear}" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Grid IsVisible="{Binding HasContent}"
                  ColumnDefinitions="*,*" ColumnSpacing="12">

                <!-- YTD Actual -->
                <Border Grid.Column="0"
                        BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="YTD Actual"
                                   TextColor="#1565C0" FontSize="15" FontAttributes="Bold" />
                            <Label TextColor="#78909C" FontSize="11">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="From " />
                                        <Span Text="{Binding YtdPaycheckCount}" FontAttributes="Bold" />
                                        <Span Text=" saved paycheck(s)" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                        <BoxView HeightRequest="1" BackgroundColor="#E3F2FD" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0" Text="Gross earned"
                                   TextColor="#546E7A" FontSize="13" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding YtdGross, StringFormat='{0:C}'}"
                                   TextColor="#37474F" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Taxes withheld"
                                   TextColor="#546E7A" FontSize="13" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding YtdTaxes, StringFormat='{0:C}'}"
                                   TextColor="#C62828" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="0" Text="Net take-home"
                                   TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding YtdNet, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="16" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Projected Annual -->
                <Border Grid.Column="1"
                        BackgroundColor="White" StrokeThickness="0"
                        StrokeShape="RoundRectangle 12" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Projected Annual"
                                   TextColor="#1565C0" FontSize="15" FontAttributes="Bold" />
                            <Label TextColor="#78909C" FontSize="11">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Projection.RemainingPaychecks}" FontAttributes="Bold" />
                                        <Span Text=" of " />
                                        <Span Text="{Binding Projection.PayPeriodsPerYear}" />
                                        <Span Text=" paychecks remaining" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                        <BoxView HeightRequest="1" BackgroundColor="#E3F2FD" />
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0" Text="Annualized gross"
                                   TextColor="#546E7A" FontSize="13" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Projection.AnnualizedGrossPay, StringFormat='{0:C}'}"
                                   TextColor="#37474F" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.Column="0" Text="Annualized net"
                                   TextColor="#546E7A" FontSize="13" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Projection.AnnualizedNetPay, StringFormat='{0:C}'}"
                                   TextColor="#37474F" FontSize="14" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{Binding Projection.OverUnderLabel}"
                                   TextColor="#37474F" FontSize="13" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Projection.OverUnderAmount, StringFormat='{0:C}'}"
                                   TextColor="#2E7D32" FontSize="16" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding Projection.IsUnderWithholding}" Value="True">
                                        <Setter Property="TextColor" Value="#C62828" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
