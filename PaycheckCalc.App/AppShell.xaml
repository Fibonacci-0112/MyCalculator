<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:PaycheckCalc.App.Views"
       x:Class="PaycheckCalc.App.AppShell"
       Shell.TabBarBackgroundColor="#1565C0"
       Shell.TabBarForegroundColor="White"
       Shell.TabBarUnselectedColor="#90CAF9"
       Shell.TabBarTitleColor="White"
       Shell.NavBarHasShadow="False"
       Shell.BackgroundColor="#1565C0"
       Shell.TitleColor="White"
       Shell.FlyoutBackgroundColor="#F0F4FF"
       FlyoutBehavior="Flyout">

    <FlyoutItem Title="Dashboard" Route="Dashboard">
        <ShellContent Route="Home"
                      ContentTemplate="{DataTemplate views:DashboardPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Paycheck Calculator" Route="Paycheck">
        <Tab Title="Inputs">
            <ShellContent Route="Inputs"
                          ContentTemplate="{DataTemplate views:InputsPage}" />
        </Tab>
        <Tab Title="Results">
            <ShellContent Route="Results"
                          ContentTemplate="{DataTemplate views:ResultsPage}" />
        </Tab>
        <Tab Title="Compare">
            <ShellContent Route="Compare"
                          ContentTemplate="{DataTemplate views:ComparePage}" />
        </Tab>
        <Tab Title="Saved">
            <ShellContent Route="Saved"
                          ContentTemplate="{DataTemplate views:SavedPaychecksPage}" />
        </Tab>
    </FlyoutItem>
    <FlyoutItem Title="Self-Employment" Route="SelfEmploymentHub">
        <Tab Title="SE Inputs">
            <ShellContent Route="SelfEmployment"
                          ContentTemplate="{DataTemplate views:SelfEmploymentPage}" />
        </Tab>
        <Tab Title="SE Results">
            <ShellContent Route="SEResults"
                          ContentTemplate="{DataTemplate views:SelfEmploymentResultsPage}" />
        </Tab>
    </FlyoutItem>
    <FlyoutItem Title="Annual Tax Planner" Route="AnnualPlanner">
        <Tab Title="Jobs &amp; YTD">
            <ShellContent Route="JobsAndYtd"
                          ContentTemplate="{DataTemplate views:JobsAndYtdPage}" />
        </Tab>
        <Tab Title="Adjustments">
            <ShellContent Route="OtherIncomeAdjustments"
                          ContentTemplate="{DataTemplate views:OtherIncomeAdjustmentsPage}" />
        </Tab>
        <Tab Title="Credits">
            <ShellContent Route="Credits"
                          ContentTemplate="{DataTemplate views:CreditsPage}" />
        </Tab>
        <Tab Title="Estimates">
            <ShellContent Route="QuarterlyEstimates"
                          ContentTemplate="{DataTemplate views:QuarterlyEstimatesPage}" />
        </Tab>
        <Tab Title="What-If">
            <ShellContent Route="WhatIf"
                          ContentTemplate="{DataTemplate views:WhatIfPage}" />
        </Tab>
        <Tab Title="Projection">
            <ShellContent Route="AnnualProjection"
                          ContentTemplate="{DataTemplate views:AnnualProjectionPage}" />
        </Tab>
        <Tab Title="Annual Results">
            <ShellContent Route="AnnualResults"
                          ContentTemplate="{DataTemplate views:AnnualTaxResultsPage}" />
        </Tab>
    </FlyoutItem>
</Shell>
